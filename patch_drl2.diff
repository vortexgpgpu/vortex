-    // 6. Lane Mask
-    // ----------------------------------------------------------------------
+    // ======================================================================
+    // 4. Lane Mask
+    // ======================================================================
+
     VX_tcu_drl_lane_mask #(
         .N   (N),
         .TCK (TCK)
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_f16.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_f16.sv
new file mode 100644
index 00000000..a76964b9
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_f16.sv
@@ -0,0 +1,222 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_f16 import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [TCU_MAX_INPUTS-1:0] vld_mask,
+    input wire [2:0]                fmt_f,
+
+    // Raw Inputs (No pre-classification)
+    input wire [N-1:0][31:0]        a_row,
+    input wire [N-1:0][31:0]        b_col,
+
+    // Outputs (Result only, no flags)
+    output logic [TCK-1:0][24:0]      result_sig,
+    output logic [TCK-1:0][EXP_W-1:0] result_exp
+);
+    `UNUSED_VAR (vld_mask)
+
+    // ======================================================================
+    // 1. Internal Classification (Replicated Logic)
+    // ======================================================================
+
+    fedp_class_t [N-1:0]   cls_tf32 [2];
+    fedp_class_t [TCK-1:0] cls_fp16 [2];
+    fedp_class_t [TCK-1:0] cls_bf16 [2];
+
+    VX_tcu_drl_classifier #(.N(N), .WIDTH(32), .FMT(TCU_TF32_ID)) c_a_tf32 (.val(a_row), .cls(cls_tf32[0]));
+    VX_tcu_drl_classifier #(.N(N), .WIDTH(32), .FMT(TCU_TF32_ID)) c_b_tf32 (.val(b_col), .cls(cls_tf32[1]));
+
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_FP16_ID)) c_a_fp16 (.val(a_row), .cls(cls_fp16[0]));
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_FP16_ID)) c_b_fp16 (.val(b_col), .cls(cls_fp16[1]));
+
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_BF16_ID)) c_a_bf16 (.val(a_row), .cls(cls_bf16[0]));
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_BF16_ID)) c_b_bf16 (.val(b_col), .cls(cls_bf16[1]));
+
+    // ======================================================================
+    // 2. Constants & Parameters
+    // ======================================================================
+
+    localparam F32_BIAS     = 127;
+    localparam F32_SIG_BITS = 23;
+    localparam MUL_WIDTH    = 22;
+    localparam ALIGN_SHIFT  = F32_SIG_BITS - MUL_WIDTH;
+
+    localparam E_TF32 = VX_tcu_pkg::exp_bits(TCU_TF32_ID);
+    localparam S_TF32 = VX_tcu_pkg::sign_pos(TCU_TF32_ID);
+    localparam B_TF32 = (1 << (E_TF32 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_TF32 = 8'(F32_BIAS - 2*B_TF32 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_FP16 = VX_tcu_pkg::exp_bits(TCU_FP16_ID);
+    localparam S_FP16 = VX_tcu_pkg::sign_pos(TCU_FP16_ID);
+    localparam B_FP16 = (1 << (E_FP16 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_FP16 = 8'(F32_BIAS - 2*B_FP16 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_BF16 = VX_tcu_pkg::exp_bits(TCU_BF16_ID);
+    localparam S_BF16 = VX_tcu_pkg::sign_pos(TCU_BF16_ID);
+    localparam B_BF16 = (1 << (E_BF16 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_BF16 = 8'(F32_BIAS - 2*B_BF16 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    // ======================================================================
+    // 3. Main Loop (Per TCK Lane)
+    // ======================================================================
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_f16_lane
+
+        logic [7:0] ea_sel, eb_sel;
+        logic [7:0] bias_sel;
+        logic       is_zero;
+        logic [10:0] man_a_f16, man_b_f16;
+        logic        sign_f16;
+
+        // ------------------------------------------------------------------
+        // 3a. Pre-Calculation (Extraction outside always_comb)
+        // ------------------------------------------------------------------
+        // Extract signals for all formats in parallel using constant offsets.
+
+        // --- FP16 Signals ---
+        logic [7:0] ea_fp16_w, eb_fp16_w;
+        logic       z_fp16_w;
+        logic [10:0] ma_fp16_w, mb_fp16_w;
+        logic        s_fp16_w;
+
+        localparam OFF_16 = (i % 2) * 16;
+        assign ea_fp16_w = cls_fp16[0][i].is_sub ? 8'd1 : 8'(a_row[i/2][S_FP16-1+OFF_16 -: E_FP16]);
+        assign eb_fp16_w = cls_fp16[1][i].is_sub ? 8'd1 : 8'(b_col[i/2][S_FP16-1+OFF_16 -: E_FP16]);
+        assign z_fp16_w  = cls_fp16[0][i].is_zero | cls_fp16[1][i].is_zero | ~vld_mask[i*4];
+
+        // Mantissa & Sign (FP16)
+        assign ma_fp16_w = cls_fp16[0][i].is_zero ? 11'd0 : { !cls_fp16[0][i].is_sub, a_row[i/2][9+OFF_16 -: 10] };
+        assign mb_fp16_w = cls_fp16[1][i].is_zero ? 11'd0 : { !cls_fp16[1][i].is_sub, b_col[i/2][9+OFF_16 -: 10] };
+        assign s_fp16_w  = a_row[i/2][15+OFF_16] ^ b_col[i/2][15+OFF_16];
+
+        // --- BF16 Signals ---
+        logic [7:0] ea_bf16_w, eb_bf16_w;
+        logic       z_bf16_w;
+        logic [10:0] ma_bf16_w, mb_bf16_w;
+        logic        s_bf16_w;
+
+        assign ea_bf16_w = cls_bf16[0][i].is_sub ? 8'd1 : a_row[i/2][S_BF16-1+OFF_16 -: E_BF16];
+        assign eb_bf16_w = cls_bf16[1][i].is_sub ? 8'd1 : b_col[i/2][S_BF16-1+OFF_16 -: E_BF16];
+        assign z_bf16_w  = cls_bf16[0][i].is_zero | cls_bf16[1][i].is_zero | ~vld_mask[i*4];
+
+        // Mantissa & Sign (BF16 - Padded to 11 bits)
+        assign ma_bf16_w = cls_bf16[0][i].is_zero ? 11'd0 : { 3'd0, !cls_bf16[0][i].is_sub, a_row[i/2][6+OFF_16 -: 7] };
+        assign mb_bf16_w = cls_bf16[1][i].is_zero ? 11'd0 : { 3'd0, !cls_bf16[1][i].is_sub, b_col[i/2][6+OFF_16 -: 7] };
+        assign s_bf16_w  = a_row[i/2][15+OFF_16] ^ b_col[i/2][15+OFF_16];
+
+        // --- TF32 Signals ---
+        logic [7:0] ea_tf32_w, eb_tf32_w;
+        logic       z_tf32_w;
+        logic [10:0] ma_tf32_w, mb_tf32_w;
+        logic        s_tf32_w;
+
+        if ((i % 2) == 0) begin : g_tf32_valid
+            assign ea_tf32_w = cls_tf32[0][i/2].is_sub ? 8'd1 : a_row[i/2][S_TF32-1 -: E_TF32];
+            assign eb_tf32_w = cls_tf32[1][i/2].is_sub ? 8'd1 : b_col[i/2][S_TF32-1 -: E_TF32];
+            assign z_tf32_w  = cls_tf32[0][i/2].is_zero | cls_tf32[1][i/2].is_zero | ~vld_mask[i*4];
+
+            assign ma_tf32_w = cls_tf32[0][i/2].is_zero ? 11'd0 : { !cls_tf32[0][i/2].is_sub, a_row[i/2][9:0] };
+            assign mb_tf32_w = cls_tf32[1][i/2].is_zero ? 11'd0 : { !cls_tf32[1][i/2].is_sub, b_col[i/2][9:0] };
+            assign s_tf32_w  = a_row[i/2][18] ^ b_col[i/2][18];
+        end else begin : g_tf32_invalid
+            assign ea_tf32_w = 8'd0;
+            assign eb_tf32_w = 8'd0;
+            assign z_tf32_w = 1'b1;
+            assign ma_tf32_w = 11'd0;
+            assign mb_tf32_w = 11'd0;
+            assign s_tf32_w = 1'b0;
+        end
+
+        // ------------------------------------------------------------------
+        // 3b. Muxing (Clean always_comb)
+        // ------------------------------------------------------------------
+        always_comb begin
+            case(fmt_f)
+                TCU_FP16_ID: begin
+                    ea_sel = ea_fp16_w; eb_sel = eb_fp16_w; is_zero = z_fp16_w;
+                    man_a_f16 = ma_fp16_w; man_b_f16 = mb_fp16_w; sign_f16 = s_fp16_w;
+                    bias_sel = BIAS_CONST_FP16;
+                end
+            `ifdef TCU_BF16_ENABLE
+                TCU_BF16_ID: begin
+                    ea_sel = ea_bf16_w; eb_sel = eb_bf16_w; is_zero = z_bf16_w;
+                    man_a_f16 = ma_bf16_w; man_b_f16 = mb_bf16_w; sign_f16 = s_bf16_w;
+                    bias_sel = BIAS_CONST_BF16;
+                end
+            `endif
+            `ifdef TCU_TF32_ENABLE
+                TCU_TF32_ID: begin
+                    ea_sel = ea_tf32_w; eb_sel = eb_tf32_w; is_zero = z_tf32_w;
+                    man_a_f16 = ma_tf32_w; man_b_f16 = mb_tf32_w; sign_f16 = s_tf32_w;
+                    bias_sel = BIAS_CONST_TF32;
+                end
+            `endif
+                default: begin
+                    ea_sel = 'x; eb_sel = 'x; is_zero = 'x; bias_sel = 'x;
+                    man_a_f16 = 'x; man_b_f16 = 'x; sign_f16 = 'x;
+                end
+            endcase
+        end
+
+        // ------------------------------------------------------------------
+        // 3c. Exponent Adder
+        // ------------------------------------------------------------------
+        wire [EXP_W-1:0] sum_f16;
+        VX_csa_tree #(
+            .N (3),
+            .W (EXP_W),
+            .S (EXP_W),
+            .CPA_KS (!`FORCE_BUILTIN_ADDER(EXP_W))
+        ) exp_adder_f16 (
+            .operands ({EXP_W'($signed(bias_sel)), EXP_W'(ea_sel), EXP_W'(eb_sel)}),
+            .sum      (sum_f16),
+            `UNUSED_PIN (cout)
+        );
+
+        assign result_exp[i] = is_zero ? EXP_NEG_INF : sum_f16;
+
+        // ------------------------------------------------------------------
+        // 3d. Mantissa Multiplier
+        // ------------------------------------------------------------------
+        wire [21:0] y_raw_f16;
+        VX_wallace_mul #(
+            .N (11),
+            .CPA_KS (!`FORCE_BUILTIN_ADDER(11*2))
+        ) wtmul_f16 (
+            .a(man_a_f16),
+            .b(man_b_f16),
+            .p(y_raw_f16)
+        );
+
+        // Output Formatting
+        always_comb begin
+            case (fmt_f)
+                TCU_FP16_ID:
+                    result_sig[i] = {sign_f16, y_raw_f16, 2'd0};
+            `ifdef TCU_BF16_ENABLE
+                TCU_BF16_ID:
+                    result_sig[i] = {sign_f16, y_raw_f16[15:0], 8'd0};
+            `endif
+            `ifdef TCU_TF32_ENABLE
+                TCU_TF32_ID:
+                    result_sig[i] = {sign_f16, y_raw_f16, 2'd0};
+            `endif
+                default:
+                    result_sig[i] = 'x;
+            endcase
+        end
+    end
+
+endmodule
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_f8.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_f8.sv
new file mode 100644
index 00000000..ca5f15ee
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_f8.sv
@@ -0,0 +1,224 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_f8 import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [TCU_MAX_INPUTS-1:0] vld_mask,
+    input wire [2:0]                fmt_f,
+
+    // Raw Inputs (No pre-classification)
+    input wire [N-1:0][31:0]        a_row,
+    input wire [N-1:0][31:0]        b_col,
+
+    // Outputs (Result only, no flags)
+    output logic [TCK-1:0][24:0]      result_sig,
+    output logic [TCK-1:0][EXP_W-1:0] result_exp
+);
+    `UNUSED_VAR (vld_mask)
+
+    wire tmt_is_bfloat = tcu_fmt_is_bfloat(fmt_f);
+
+    // ======================================================================
+    // 1. Internal Classification (Replicated Logic)
+    // ======================================================================
+
+    fedp_class_t [2*TCK-1:0] cls_fp8 [2];
+    fedp_class_t [2*TCK-1:0] cls_bf8 [2];
+
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_FP8_ID)) c_a_fp8 (.val(a_row), .cls(cls_fp8[0]));
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_FP8_ID)) c_b_fp8 (.val(b_col), .cls(cls_fp8[1]));
+
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_BF8_ID)) c_a_bf8 (.val(a_row), .cls(cls_bf8[0]));
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_BF8_ID)) c_b_bf8 (.val(b_col), .cls(cls_bf8[1]));
+
+    // ======================================================================
+    // 2. Constants & Parameters
+    // ======================================================================
+
+    localparam F32_BIAS     = 127;
+    localparam F32_SIG_BITS = 23;
+    localparam MUL_WIDTH    = 22;
+    localparam ALIGN_SHIFT  = F32_SIG_BITS - MUL_WIDTH;
+
+    localparam E_FP8 = VX_tcu_pkg::exp_bits(TCU_FP8_ID);
+    localparam S_FP8 = VX_tcu_pkg::sign_pos(TCU_FP8_ID);
+    localparam B_FP8 = (1 << (E_FP8 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_FP8  = 8'(F32_BIAS - 2*B_FP8  + 2*ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_BF8 = VX_tcu_pkg::exp_bits(TCU_BF8_ID);
+    localparam S_BF8 = VX_tcu_pkg::sign_pos(TCU_BF8_ID);
+    localparam B_BF8 = (1 << (E_BF8 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_BF8  = 8'(F32_BIAS - 2*B_BF8  + 2*ALIGN_SHIFT - W + WA - 1);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    // ======================================================================
+    // 3. Main Loop (Per TCK Lane)
+    // ======================================================================
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_f8_lane
+
+        logic [1:0][4:0] ea_sel, eb_sel;
+        logic [7:0]      bias_sel;
+        logic [1:0]      is_zero;
+
+        // ------------------------------------------------------------------
+        // 3a. Pre-Calculation (Extraction outside always_comb)
+        // ------------------------------------------------------------------
+        // We use a nested generate loop to handle extraction.
+        // This ensures slice offsets are constant, avoiding "non-constant range" errors.
+
+        wire [1:0][4:0] ea_fp8_w, eb_fp8_w;
+        wire [1:0]      z_fp8_w;
+        wire [1:0][4:0] ea_bf8_w, eb_bf8_w;
+        wire [1:0]      z_bf8_w;
+
+        for (genvar j = 0; j < 2; ++j) begin : g_f8_extract
+            localparam idx = i * 2 + j;
+            localparam OFF = (i % 2) * 16 + j * 8;
+
+            // FP8 Extraction
+            assign ea_fp8_w[j] = cls_fp8[0][idx].is_sub ? 5'd1 : 5'(a_row[i/2][S_FP8-1+OFF -: E_FP8]);
+            assign eb_fp8_w[j] = cls_fp8[1][idx].is_sub ? 5'd1 : 5'(b_col[i/2][S_FP8-1+OFF -: E_FP8]);
+            assign z_fp8_w[j]  = cls_fp8[0][idx].is_zero | cls_fp8[1][idx].is_zero | ~vld_mask[idx*2];
+
+            // BF8 Extraction
+            assign ea_bf8_w[j] = cls_bf8[0][idx].is_sub ? 5'd1 : a_row[i/2][S_BF8-1+OFF -: E_BF8];
+            assign eb_bf8_w[j] = cls_bf8[1][idx].is_sub ? 5'd1 : b_col[i/2][S_BF8-1+OFF -: E_BF8];
+            assign z_bf8_w[j]  = cls_bf8[0][idx].is_zero | cls_bf8[1][idx].is_zero | ~vld_mask[idx*2];
+        end
+
+        // ------------------------------------------------------------------
+        // 3b. Muxing (Clean always_comb)
+        // ------------------------------------------------------------------
+        always_comb begin
+            case (fmt_f)
+                TCU_FP8_ID: begin
+                    ea_sel   = ea_fp8_w;
+                    eb_sel   = eb_fp8_w;
+                    is_zero  = z_fp8_w;
+                    bias_sel = BIAS_CONST_FP8;
+                end
+                TCU_BF8_ID: begin
+                    ea_sel   = ea_bf8_w;
+                    eb_sel   = eb_bf8_w;
+                    is_zero  = z_bf8_w;
+                    bias_sel = BIAS_CONST_BF8;
+                end
+                default: begin
+                    ea_sel = 'x; eb_sel = 'x; bias_sel = 'x; is_zero = 'x;
+                end
+            endcase
+        end
+
+        // Calculate Pre-Sums (Exponent A + Exponent B)
+        wire [5:0] pre_sum_0, pre_sum_1;
+
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) exp_add1_0 (
+            .dataa(6'(ea_sel[0])), .datab(6'(eb_sel[0])), .cin(1'b0), .sum(pre_sum_0), `UNUSED_PIN(cout));
+
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) exp_add1_1 (
+            .dataa(6'(ea_sel[1])), .datab(6'(eb_sel[1])), .cin(1'b0), .sum(pre_sum_1), `UNUSED_PIN(cout));
+
+        // Calculate Final Exponents (Pre-Sum + Bias)
+        wire [EXP_W-1:0] sum_f8_0, sum_f8_1;
+
+        VX_ks_adder #(.N(EXP_W), .BYPASS(`FORCE_BUILTIN_ADDER(EXP_W))) exp_add2_0 (
+            .dataa(EXP_W'(pre_sum_0)), .datab(EXP_W'(bias_sel)), .cin(1'b0), .sum(sum_f8_0), `UNUSED_PIN(cout));
+
+        VX_ks_adder #(.N(EXP_W), .BYPASS(`FORCE_BUILTIN_ADDER(EXP_W))) exp_add2_1 (
+            .dataa(EXP_W'(pre_sum_1)), .datab(EXP_W'(bias_sel)), .cin(1'b0), .sum(sum_f8_1), `UNUSED_PIN(cout));
+
+        // ------------------------------------------------------------------
+        // 3c. Exponent Difference (LOCALIZED!)
+        // ------------------------------------------------------------------
+        wire diff_sign = (pre_sum_1 < pre_sum_0);
+        wire [5:0] max_pre_sum = diff_sign ? pre_sum_0 : pre_sum_1;
+        wire [5:0] min_pre_sum = diff_sign ? pre_sum_1 : pre_sum_0;
+
+        wire [5:0] diff_abs;
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) ks_diff_f8 (
+            .dataa(max_pre_sum), .datab(~min_pre_sum), .cin(1'b1), .sum(diff_abs), `UNUSED_PIN(cout));
+        `UNUSED_VAR (diff_abs[5])
+
+        wire [5:0] exp_diff_f8 = {diff_sign, diff_abs[4:0]};
+
+        // Output Max Exponent (Muxed)
+        assign result_exp[i] = diff_sign ?
+            (is_zero[0] ? EXP_NEG_INF : sum_f8_0) :
+            (is_zero[1] ? EXP_NEG_INF : sum_f8_1);
+
+        // ------------------------------------------------------------------
+        // 3d. Mantissa Multiplication & Alignment
+        // ------------------------------------------------------------------
+        wire [1:0][7:0] y_raw_f8;
+        wire [1:0]      sign_f8;
+
+        for (genvar j = 0; j < 2; ++j) begin : g_f8_mul_sub
+            // Mux Mantissas and Signs
+            localparam idx = i * 2 + j;
+            localparam OFF = (i % 2) * 16 + j * 8;
+            wire [7:0] va = a_row[i/2][OFF +: 8];
+            wire [7:0] vb = b_col[i/2][OFF +: 8];
+            `UNUSED_VAR ({va, vb})
+
+            wire [3:0] ma_f8 = tmt_is_bfloat ?
+                (cls_bf8[0][idx].is_zero ? 4'd0 : {1'b0, !cls_bf8[0][idx].is_sub, va[1:0]}) :
+                (cls_fp8[0][idx].is_zero ? 4'd0 : {      !cls_fp8[0][idx].is_sub, va[2:0]});
+
+            wire [3:0] mb_f8 = tmt_is_bfloat ?
+                (cls_bf8[1][idx].is_zero ? 4'd0 : {1'b0, !cls_bf8[1][idx].is_sub, vb[1:0]}) :
+                (cls_fp8[1][idx].is_zero ? 4'd0 : {      !cls_fp8[1][idx].is_sub, vb[2:0]});
+
+            assign sign_f8[j] = va[7] ^ vb[7];
+
+            // 4x4 Multiplier
+            VX_wallace_mul #(.N(4), .CPA_KS(!`FORCE_BUILTIN_ADDER(4*2))) wtmul_f8 (
+                .a(ma_f8), .b(mb_f8), .p(y_raw_f8[j]));
+        end
+
+        // Align Products
+        wire [7:0] y_f8_low_raw  = y_raw_f8[0];
+        wire [7:0] y_f8_high_raw = y_raw_f8[1];
+
+        wire [22:0] base_low  = {y_f8_low_raw,  15'd0};
+        wire [22:0] base_high = {y_f8_high_raw, 15'd0};
+
+        wire [22:0] aligned_sig_low;
+        wire [22:0] aligned_sig_high;
+
+        assign aligned_sig_low  = exp_diff_f8[5] ? base_low : (base_low >> exp_diff_f8[4:0]);
+        assign aligned_sig_high = exp_diff_f8[5] ? (base_high >> exp_diff_f8[4:0]) : base_high;
+
+        // ------------------------------------------------------------------
+        // 3e. Absolute Difference / Addition
+        // ------------------------------------------------------------------
+        wire [23:0] mag_0 = {1'b0, aligned_sig_low};
+        wire [23:0] mag_1 = {1'b0, aligned_sig_high};
+        wire mag_0_is_larger = (mag_0 > mag_1);
+
+        wire [23:0] op_a = mag_0_is_larger ? mag_0 : mag_1;
+        wire [23:0] op_b = mag_0_is_larger ? mag_1 : mag_0;
+
+        wire do_sub = sign_f8[0] ^ sign_f8[1];
+
+        wire [23:0] adder_result;
+        VX_ks_adder #(.N(24), .BYPASS(`FORCE_BUILTIN_ADDER(24))) sig_adder_f8 (
+            .cin(do_sub), .dataa(op_a), .datab(do_sub ? ~op_b : op_b), .sum(adder_result), `UNUSED_PIN(cout));
+
+        wire [23:0] y_f8_add = adder_result;
+        wire sign_f8_add = mag_0_is_larger ? sign_f8[0] : sign_f8[1];
+
+        assign result_sig[i] = {sign_f8_add, y_f8_add};
+    end
+
+endmodule
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv
new file mode 100644
index 00000000..8798e9aa
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv
@@ -0,0 +1,116 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_int import VX_tcu_pkg::*;
+#(
+    parameter N   = 2,
+    parameter TCK = 2 * N
+) (
+    input wire [2:0]             fmt_i,
+    input wire [N-1:0][31:0]     a_row,
+    input wire [N-1:0][31:0]     b_col,
+
+    // Output width matches the standard accumulation width (25 bits)
+    output logic [TCK-1:0][24:0] result
+);
+    wire fmt_is_signed_int = tcu_fmt_is_signed_int(fmt_i);
+
+    // ----------------------------------------------------------------------
+    // 1. Operand Extraction (Zero Cost wiring)
+    // ----------------------------------------------------------------------
+    wire [TCK-1:0][1:0][7:0] raw_a_i8, raw_b_i8;
+    wire [TCK-1:0][3:0][3:0] raw_a_i4, raw_b_i4;
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_prep_int
+        // Extract 8-bit operands (2 per lane)
+        for (genvar j = 0; j < 2; ++j) begin : g_i8
+            assign raw_a_i8[i][j] = a_row[i/2][(i%2)*16 + j*8 +: 8];
+            assign raw_b_i8[i][j] = b_col[i/2][(i%2)*16 + j*8 +: 8];
+        end
+        // Extract 4-bit operands (4 per lane)
+        for (genvar j = 0; j < 4; ++j) begin : g_i4
+            assign raw_a_i4[i][j] = a_row[i/2][(i%2)*16 + j*4 +: 4];
+            assign raw_b_i4[i][j] = b_col[i/2][(i%2)*16 + j*4 +: 4];
+        end
+    end
+
+    // ----------------------------------------------------------------------
+    // 2. Multiplication & Accumulation
+    // ----------------------------------------------------------------------
+    for (genvar i = 0; i < TCK; ++i) begin : g_mul_int
+
+        // --- I8/U8 Processing ---------------------------------------------
+        wire signed [16:0] y_prod_i8 [2];
+
+        for (genvar j = 0; j < 2; ++j) begin : g_mul_i8
+            // Sign extension handling
+            wire signed [8:0] s_a = fmt_is_signed_int ?
+                $signed({raw_a_i8[i][j][7], raw_a_i8[i][j]}) :
+                $signed({1'b0, raw_a_i8[i][j]});
+
+            wire signed [8:0] s_b = fmt_is_signed_int ?
+                $signed({raw_b_i8[i][j][7], raw_b_i8[i][j]}) :
+                $signed({1'b0, raw_b_i8[i][j]});
+
+            wire signed [17:0] prod_full = s_a * s_b;
+            `UNUSED_VAR (prod_full[17])
+            assign y_prod_i8[j] = prod_full[16:0];
+        end
+
+        wire [16:0] y_i8_add_res;
+        VX_ks_adder #(
+            .N(17),
+            .BYPASS (`FORCE_BUILTIN_ADDER(17))
+        ) i8_adder (
+            .cin   (1'b0),
+            .dataa (y_prod_i8[0]),
+            .datab (y_prod_i8[1]),
+            .sum   (y_i8_add_res),
+            `UNUSED_PIN(cout)
+        );
+
+        // --- I4/U4 Processing ---------------------------------------------
+        wire signed [3:0][9:0] y_prod_i4;
+
+        for (genvar j = 0; j < 4; ++j) begin : g_mul_i4
+            // Sign extension handling
+            wire signed [4:0] s_a = fmt_is_signed_int ?
+                $signed({raw_a_i4[i][j][3], raw_a_i4[i][j]}) :
+                $signed({1'b0, raw_a_i4[i][j]});
+
+            wire signed [4:0] s_b = fmt_is_signed_int ?
+                $signed({raw_b_i4[i][j][3], raw_b_i4[i][j]}) :
+                $signed({1'b0, raw_b_i4[i][j]});
+
+            wire signed [9:0] prod_full = s_a * s_b;
+            assign y_prod_i4[j] = prod_full;
+        end
+
+        wire [9:0] y_i4_add_res;
+        VX_csa_tree #(
+            .N (4),
+            .W (10),
+            .S (10),
+            .CPA_KS (!`FORCE_BUILTIN_ADDER(10))
+        ) i4_adder (
+            .operands (y_prod_i4),
+            .sum      (y_i4_add_res),
+            `UNUSED_PIN (cout)
+        );
+
+        // --- Output Muxing ------------------------------------------------
+        always_comb begin
+            case ({1'b1, fmt_i})
+                TCU_I8_ID: result[i] = 25'($signed(y_i8_add_res));
+                TCU_U8_ID: result[i] = {8'd0, y_i8_add_res};
+                TCU_I4_ID: result[i] = 25'($signed(y_i4_add_res));
+                TCU_U4_ID: result[i] = {15'd0, y_i4_add_res};
+                default:               result[i] = 'x;
+            endcase
+        end
+    end
+
+endmodule
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv
new file mode 100644
index 00000000..1d015f96
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv
@@ -0,0 +1,144 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_join import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [3:0]                  fmt_s,
+    input wire [31:0]                 c_val,
+
+    // Inputs from the Split Paths
+    input wire [TCK-1:0][24:0]        sig_f16,
+    input wire [TCK-1:0][EXP_W-1:0]   exp_f16,
+
+    input wire [TCK-1:0][24:0]        sig_f8,
+    input wire [TCK-1:0][EXP_W-1:0]   exp_f8,
+
+    input wire [TCK-1:0][24:0]        sig_int,
+    // (Integer path has no exponent)
+
+    // Unified Outputs to Stage 2 (Alignment)
+    output logic [EXP_W-1:0]          max_exp,
+    output logic [TCK:0][7:0]         shift_amt, // TCK+1 for C-term
+    output logic [TCK:0][24:0]        joined_sigs
+);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    // ======================================================================
+    // 1. Path Selection (Muxing)
+    // ======================================================================
+
+    logic [TCK-1:0][24:0]      sel_sigs;
+    logic [TCK-1:0][EXP_W-1:0] sel_exps;
+
+    always_comb begin
+        case (fmt_s[3:0])
+            // --- F16 / BF16 / TF32 ---
+            TCU_FP16_ID: begin
+                sel_sigs = sig_f16;
+                sel_exps = exp_f16;
+            end
+            `ifdef TCU_BF16_ENABLE
+            TCU_BF16_ID: begin
+                sel_sigs = sig_f16;
+                sel_exps = exp_f16;
+            end
+            `endif
+            `ifdef TCU_TF32_ENABLE
+            TCU_TF32_ID: begin
+                sel_sigs = sig_f16;
+                sel_exps = exp_f16;
+            end
+            `endif
+
+            // --- FP8 / BF8 ---
+            `ifdef TCU_FP8_ENABLE
+            TCU_FP8_ID, TCU_BF8_ID: begin
+                sel_sigs = sig_f8;
+                sel_exps = exp_f8;
+            end
+            `endif
+
+            // --- Integers ---
+            // Integers treat Exponents as "don't care" (or zero/neg_inf)
+            // to prevent max_exp logic from toggling unnecessarily.
+            `ifdef TCU_INT_ENABLE
+            TCU_I8_ID, TCU_U8_ID, TCU_I4_ID, TCU_U4_ID: begin
+                sel_sigs = sig_int;
+                sel_exps = {TCK{EXP_NEG_INF}};
+            end
+            `endif
+
+            default: begin
+                sel_sigs = 'x;
+                sel_exps = 'x;
+            end
+        endcase
+    end
+
+    // ======================================================================
+    // 2. C-Term Handling
+    // ======================================================================
+    // We process C-term here to append it to the lanes.
+
+    // 2a. Local Classifier for C (Check for Zero)
+    fedp_class_t cls_c;
+    VX_tcu_drl_classifier #(.N(1), .WIDTH(32), .FMT(TCU_FP32_ID)) c_c (
+        .val(c_val),
+        .cls(cls_c)
+    );
+    `UNUSED_VAR (cls_c)
+
+    // 2b. C-Term Signal Extraction
+    // If format is INT, we just take the bits. If float, we add hidden bit.
+    logic [24:0] c_sig_final;
+    wire c_is_int = tcu_fmt_is_int(fmt_s); // Helper from pkg
+
+    assign c_sig_final = c_is_int ?
+        c_val[24:0] :
+        {c_val[31], 1'b1, c_val[22:0]};
+
+    // 2c. C-Term Exponent Calculation
+    // Corresponds to original logic in VX_tcu_drl_exp_bias
+    wire [7:0] c_exp_raw = c_val[30:23];
+    // Adjustment: c_exp - (W - 1) + WA - 1
+    wire [EXP_W-1:0] c_exp_adj = EXP_W'(c_exp_raw) - EXP_W'(W-1) + EXP_W'(WA-1);
+
+    wire [EXP_W-1:0] c_exp_final = (cls_c.is_zero) ? EXP_NEG_INF : c_exp_adj;
+
+    // ======================================================================
+    // 3. Final Aggregation
+    // ======================================================================
+
+    wire [TCK:0][EXP_W-1:0] unified_exps;
+
+    // Combine Lanes + C-Term
+    assign joined_sigs  = {c_sig_final, sel_sigs};
+    assign unified_exps = {c_exp_final, sel_exps};
+
+    // ======================================================================
+    // 4. Max Exponent & Shift Calculation
+    // ======================================================================
+
+    // This finds the maximum exponent across all lanes AND the C-term.
+    // By placing it after the Mux, it only sees stable selected exponents.
+
+    VX_tcu_drl_max_exp #(
+        .N     (TCK+1),
+        .WIDTH (EXP_W)
+    ) find_max_exp (
+        .exponents (unified_exps),
+        .max_exp   (max_exp),
+        .shift_amt (shift_amt)
+    );
+
+endmodule
