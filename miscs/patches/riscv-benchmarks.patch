+// handshake needs memory coherence Vortex's caches do not provide.
+#define VX_IO_COUT_ADDR  0x40
+#define VX_IO_COUT_SIZE  64
+#define VX_IO_EXIT_CODE  (VX_IO_COUT_ADDR + VX_IO_COUT_SIZE + 8)
 
