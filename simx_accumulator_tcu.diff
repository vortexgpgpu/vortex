-    `STATIC_ASSERT(`IS_POW2(CL_SIZE), ("CL_SIZE must be power of 2"))
-    `STATIC_ASSERT(`IS_POW2(SMEM_WORD_SIZE), ("SMEM_WORD_SIZE must be power of 2"))
