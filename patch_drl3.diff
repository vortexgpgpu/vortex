index 00000000..d5fff406
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_f16.sv
@@ -0,0 +1,272 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_f16 import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [TCU_MAX_INPUTS-1:0] vld_mask,
+    input wire [2:0]                fmt_f,
+
+    // Raw Inputs (No pre-classification)
+    input wire [N-1:0][31:0]        a_row,
+    input wire [N-1:0][31:0]        b_col,
+
+    // Outputs
+    output logic [TCK-1:0][24:0]      result_sig,
+    output logic [TCK-1:0][EXP_W-1:0] result_exp,
+    output fedp_excep_t [TCK-1:0]     exceptions
+);
+    `UNUSED_VAR (vld_mask)
+
+    // ======================================================================
+    // 1. Internal Classification (Replicated Logic)
+    // ======================================================================
+
+    fedp_class_t [N-1:0]   cls_tf32 [2];
+    fedp_class_t [TCK-1:0] cls_fp16 [2];
+    fedp_class_t [TCK-1:0] cls_bf16 [2];
+
+    VX_tcu_drl_classifier #(.N(N), .WIDTH(32), .FMT(TCU_TF32_ID)) c_a_tf32 (.val(a_row), .cls(cls_tf32[0]));
+    VX_tcu_drl_classifier #(.N(N), .WIDTH(32), .FMT(TCU_TF32_ID)) c_b_tf32 (.val(b_col), .cls(cls_tf32[1]));
+
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_FP16_ID)) c_a_fp16 (.val(a_row), .cls(cls_fp16[0]));
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_FP16_ID)) c_b_fp16 (.val(b_col), .cls(cls_fp16[1]));
+
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_BF16_ID)) c_a_bf16 (.val(a_row), .cls(cls_bf16[0]));
+    VX_tcu_drl_classifier #(.N(TCK), .WIDTH(16), .FMT(TCU_BF16_ID)) c_b_bf16 (.val(b_col), .cls(cls_bf16[1]));
+
+    // ======================================================================
+    // 2. Constants & Parameters
+    // ======================================================================
+
+    localparam F32_BIAS     = 127;
+    localparam F32_SIG_BITS = 23;
+    localparam MUL_WIDTH    = 22;
+    localparam ALIGN_SHIFT  = F32_SIG_BITS - MUL_WIDTH;
+
+    localparam E_TF32 = VX_tcu_pkg::exp_bits(TCU_TF32_ID);
+    localparam S_TF32 = VX_tcu_pkg::sign_pos(TCU_TF32_ID);
+    localparam B_TF32 = (1 << (E_TF32 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_TF32 = 8'(F32_BIAS - 2*B_TF32 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_FP16 = VX_tcu_pkg::exp_bits(TCU_FP16_ID);
+    localparam S_FP16 = VX_tcu_pkg::sign_pos(TCU_FP16_ID);
+    localparam B_FP16 = (1 << (E_FP16 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_FP16 = 8'(F32_BIAS - 2*B_FP16 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_BF16 = VX_tcu_pkg::exp_bits(TCU_BF16_ID);
+    localparam S_BF16 = VX_tcu_pkg::sign_pos(TCU_BF16_ID);
+    localparam B_BF16 = (1 << (E_BF16 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_BF16 = 8'(F32_BIAS - 2*B_BF16 + ALIGN_SHIFT - W + WA - 1);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    // ======================================================================
+    // 3. Main Loop (Per TCK Lane)
+    // ======================================================================
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_f16_lane
+
+        // Selected Signals (Mux Output)
+        logic [7:0]  ea_sel, eb_sel;
+        logic [7:0]  bias_sel;
+        logic [10:0] man_a_sel, man_b_sel;
+        logic        sign_sel;
+
+        // Selected Flags
+        logic        lane_nan, lane_inf, lane_sign;
+
+        // ------------------------------------------------------------------
+        // 3a. Pre-Calculation (Independent Paths)
+        // ------------------------------------------------------------------
+
+        // Lane Masking (All these formats align to 32-bit boundaries)
+        wire lane_vld = vld_mask[i*4];
+        localparam OFF_16 = (i % 2) * 16;
+
+        // --- FP16 Signals -------------------------------------------------
+        wire [7:0]  ea_fp16 = cls_fp16[0][i].is_sub ? 8'd1 : 8'(a_row[i/2][S_FP16-1+OFF_16 -: E_FP16]);
+        wire [7:0]  eb_fp16 = cls_fp16[1][i].is_sub ? 8'd1 : 8'(b_col[i/2][S_FP16-1+OFF_16 -: E_FP16]);
+
+        // Mantissa (padded to 11)
+        wire [10:0] ma_fp16 = cls_fp16[0][i].is_zero ? 11'd0 : { !cls_fp16[0][i].is_sub, a_row[i/2][9+OFF_16 -: 10] };
+        wire [10:0] mb_fp16 = cls_fp16[1][i].is_zero ? 11'd0 : { !cls_fp16[1][i].is_sub, b_col[i/2][9+OFF_16 -: 10] };
+        wire        s_fp16  = cls_fp16[0][i].sign ^ cls_fp16[1][i].sign;
+
+        // Exception Logic
+        wire nan_in_fp16 = cls_fp16[0][i].is_nan | cls_fp16[1][i].is_nan;
+        wire inf_z_fp16  = (cls_fp16[0][i].is_inf & cls_fp16[1][i].is_zero) |
+                           (cls_fp16[0][i].is_zero & cls_fp16[1][i].is_inf);
+        wire inf_op_fp16 = cls_fp16[0][i].is_inf | cls_fp16[1][i].is_inf;
+
+        wire exc_nan_fp16 = (nan_in_fp16 | inf_z_fp16) & lane_vld;
+        wire exc_inf_fp16 = (inf_op_fp16 & ~inf_z_fp16) & lane_vld;
+
+
+        // --- BF16 Signals -------------------------------------------------
+        wire [7:0]  ea_bf16 = cls_bf16[0][i].is_sub ? 8'd1 : a_row[i/2][S_BF16-1+OFF_16 -: E_BF16];
+        wire [7:0]  eb_bf16 = cls_bf16[1][i].is_sub ? 8'd1 : b_col[i/2][S_BF16-1+OFF_16 -: E_BF16];
+
+        // Mantissa (padded to 11, 7 bits data)
+        wire [10:0] ma_bf16 = cls_bf16[0][i].is_zero ? 11'd0 : { 3'd0, !cls_bf16[0][i].is_sub, a_row[i/2][6+OFF_16 -: 7] };
+        wire [10:0] mb_bf16 = cls_bf16[1][i].is_zero ? 11'd0 : { 3'd0, !cls_bf16[1][i].is_sub, b_col[i/2][6+OFF_16 -: 7] };
+        wire        s_bf16  = cls_bf16[0][i].sign ^ cls_bf16[1][i].sign;
+
+        // Exception Logic
+        wire nan_in_bf16 = cls_bf16[0][i].is_nan | cls_bf16[1][i].is_nan;
+        wire inf_z_bf16  = (cls_bf16[0][i].is_inf & cls_bf16[1][i].is_zero) |
+                           (cls_bf16[0][i].is_zero & cls_bf16[1][i].is_inf);
+        wire inf_op_bf16 = cls_bf16[0][i].is_inf | cls_bf16[1][i].is_inf;
+
+        wire exc_nan_bf16 = (nan_in_bf16 | inf_z_bf16) & lane_vld;
+        wire exc_inf_bf16 = (inf_op_bf16 & ~inf_z_bf16) & lane_vld;
+
+
+        // --- TF32 Signals -------------------------------------------------
+        wire [7:0]  ea_tf32, eb_tf32;
+        wire [10:0] ma_tf32, mb_tf32;
+        wire        s_tf32;
+        wire        exc_nan_tf32, exc_inf_tf32;
+
+        if ((i % 2) == 0) begin : g_tf32_even
+            assign ea_tf32 = cls_tf32[0][i/2].is_sub ? 8'd1 : a_row[i/2][S_TF32-1 -: E_TF32];
+            assign eb_tf32 = cls_tf32[1][i/2].is_sub ? 8'd1 : b_col[i/2][S_TF32-1 -: E_TF32];
+
+            // Mantissa (10 bits data)
+            assign ma_tf32 = cls_tf32[0][i/2].is_zero ? 11'd0 : { !cls_tf32[0][i/2].is_sub, a_row[i/2][9:0] };
+            assign mb_tf32 = cls_tf32[1][i/2].is_zero ? 11'd0 : { !cls_tf32[1][i/2].is_sub, b_col[i/2][9:0] };
+            assign s_tf32  = cls_tf32[0][i/2].sign ^ cls_tf32[1][i/2].sign;
+
+            // Exception Logic
+            wire nan_in_tf32 = cls_tf32[0][i/2].is_nan | cls_tf32[1][i/2].is_nan;
+            wire inf_z_tf32  = (cls_tf32[0][i/2].is_inf & cls_tf32[1][i/2].is_zero) |
+                               (cls_tf32[0][i/2].is_zero & cls_tf32[1][i/2].is_inf);
+            wire inf_op_tf32 = cls_tf32[0][i/2].is_inf | cls_tf32[1][i/2].is_inf;
+
+            assign exc_nan_tf32 = (nan_in_tf32 | inf_z_tf32) & lane_vld;
+            assign exc_inf_tf32 = (inf_op_tf32 & ~inf_z_tf32) & lane_vld;
+        end else begin : g_tf32_odd
+            assign ea_tf32 = '0; assign eb_tf32 = '0;
+            assign ma_tf32 = '0; assign mb_tf32 = '0;
+            assign s_tf32  = '0;
+            assign exc_nan_tf32 = 1'b0;
+            assign exc_inf_tf32 = 1'b0;
+        end
+
+        // ------------------------------------------------------------------
+        // 3b. Muxing (Selection Only)
+        // ------------------------------------------------------------------
+        always_comb begin
+            case(fmt_f)
+                TCU_FP16_ID: begin
+                    ea_sel      = ea_fp16;
+                    eb_sel      = eb_fp16;
+                    man_a_sel   = ma_fp16;
+                    man_b_sel   = mb_fp16;
+                    sign_sel    = s_fp16;
+                    bias_sel    = BIAS_CONST_FP16;
+
+                    lane_nan    = exc_nan_fp16;
+                    lane_inf    = exc_inf_fp16;
+                    lane_sign   = s_fp16;
+                end
+            `ifdef TCU_BF16_ENABLE
+                TCU_BF16_ID: begin
+                    ea_sel      = ea_bf16;
+                    eb_sel      = eb_bf16;
+                    man_a_sel   = ma_bf16;
+                    man_b_sel   = mb_bf16;
+                    sign_sel    = s_bf16;
+                    bias_sel    = BIAS_CONST_BF16;
+
+                    lane_nan    = exc_nan_bf16;
+                    lane_inf    = exc_inf_bf16;
+                    lane_sign   = s_bf16;
+                end
+            `endif
+            `ifdef TCU_TF32_ENABLE
+                TCU_TF32_ID: begin
+                    ea_sel      = ea_tf32;
+                    eb_sel      = eb_tf32;
+                    man_a_sel   = ma_tf32;
+                    man_b_sel   = mb_tf32;
+                    sign_sel    = s_tf32;
+                    bias_sel    = BIAS_CONST_TF32;
+
+                    lane_nan    = exc_nan_tf32;
+                    lane_inf    = exc_inf_tf32;
+                    lane_sign   = s_tf32;
+                end
+            `endif
+                default: begin
+                    ea_sel      = 'x;
+                    eb_sel      = 'x;
+                    man_a_sel   = 'x;
+                    man_b_sel   = 'x;
+                    sign_sel    = 'x;
+                    bias_sel    = 'x;
+
+                    lane_nan    = 'x;
+                    lane_inf    = 'x;
+                    lane_sign   = 'x;
+                end
+            endcase
+        end
+
+        // ------------------------------------------------------------------
+        // 3c. Arithmetic Path
+        // ------------------------------------------------------------------
+
+        // Exponent Addition
+        wire [EXP_W-1:0] sum_f16;
+        VX_csa_tree #(
+            .N (3), .W (EXP_W), .S (EXP_W),
+            .CPA_KS (!`FORCE_BUILTIN_ADDER(EXP_W))
+        ) exp_adder_f16 (
+            .operands ({EXP_W'($signed(bias_sel)), EXP_W'(ea_sel), EXP_W'(eb_sel)}),
+            .sum      (sum_f16),
+            `UNUSED_PIN (cout)
+        );
+
+        assign result_exp[i] = lane_vld ? sum_f16 : EXP_NEG_INF;
+
+        // Mantissa Multiplication
+        wire [21:0] y_raw_f16;
+        VX_wallace_mul #(
+            .N (11), .CPA_KS (!`FORCE_BUILTIN_ADDER(11*2))
+        ) wtmul_f16 (
+            .a(man_a_sel),
+            .b(man_b_sel),
+            .p(y_raw_f16)
+        );
+
+        // Output Formatting
+        always_comb begin
+            case (fmt_f)
+                TCU_FP16_ID: result_sig[i] = {sign_sel, y_raw_f16, 2'd0};
+            `ifdef TCU_BF16_ENABLE
+                TCU_BF16_ID: result_sig[i] = {sign_sel, y_raw_f16[15:0], 8'd0};
+            `endif
+            `ifdef TCU_TF32_ENABLE
+                TCU_TF32_ID: result_sig[i] = {sign_sel, y_raw_f16, 2'd0};
+            `endif
+                default:     result_sig[i] = 'x;
+            endcase
+        end
+
+        // Exception Outputs
+        assign exceptions[i].is_nan = lane_nan;
+        assign exceptions[i].is_inf = lane_inf;
+        assign exceptions[i].sign   = lane_sign;
+
+    end
+
+endmodule
