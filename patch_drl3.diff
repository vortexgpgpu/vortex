+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_f8 import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [TCU_MAX_INPUTS-1:0] vld_mask,
+    input wire [2:0]                fmt_f,
+
+    // Raw Inputs (No pre-classification)
+    input wire [N-1:0][31:0]        a_row,
+    input wire [N-1:0][31:0]        b_col,
+
+    // Outputs
+    output logic [TCK-1:0][24:0]      result_sig,
+    output logic [TCK-1:0][EXP_W-1:0] result_exp,
+    output fedp_excep_t [TCK-1:0]     exceptions
+);
+
+    // ======================================================================
+    // 1. Internal Classification (Replicated Logic)
+    // ======================================================================
+
+    fedp_class_t [2*TCK-1:0] cls_fp8 [2];
+    fedp_class_t [2*TCK-1:0] cls_bf8 [2];
+
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_FP8_ID)) c_a_fp8 (.val(a_row), .cls(cls_fp8[0]));
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_FP8_ID)) c_b_fp8 (.val(b_col), .cls(cls_fp8[1]));
+
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_BF8_ID)) c_a_bf8 (.val(a_row), .cls(cls_bf8[0]));
+    VX_tcu_drl_classifier #(.N(4*N), .WIDTH(8), .FMT(TCU_BF8_ID)) c_b_bf8 (.val(b_col), .cls(cls_bf8[1]));
+
+    // ======================================================================
+    // 2. Constants & Parameters
+    // ======================================================================
+
+    localparam F32_BIAS     = 127;
+    localparam F32_SIG_BITS = 23;
+    localparam MUL_WIDTH    = 22;
+    localparam ALIGN_SHIFT  = F32_SIG_BITS - MUL_WIDTH;
+
+    localparam E_FP8 = VX_tcu_pkg::exp_bits(TCU_FP8_ID);
+    localparam S_FP8 = VX_tcu_pkg::sign_pos(TCU_FP8_ID);
+    localparam B_FP8 = (1 << (E_FP8 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_FP8  = 8'(F32_BIAS - 2*B_FP8  + 2*ALIGN_SHIFT - W + WA - 1);
+
+    localparam E_BF8 = VX_tcu_pkg::exp_bits(TCU_BF8_ID);
+    localparam S_BF8 = VX_tcu_pkg::sign_pos(TCU_BF8_ID);
+    localparam B_BF8 = (1 << (E_BF8 - 1)) - 1;
+    localparam [7:0] BIAS_CONST_BF8  = 8'(F32_BIAS - 2*B_BF8  + 2*ALIGN_SHIFT - W + WA - 1);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    wire tmt_is_bfloat = tcu_fmt_is_bfloat(fmt_f);
+
+    // ======================================================================
+    // 3. Main Loop (Per TCK Lane)
+    // ======================================================================
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_f8_lane
+
+        logic [1:0][4:0] ea_sel, eb_sel;
+        logic [7:0]      bias_sel;
+        // Exception Aggregation Signals
+        logic [1:0]      lane_nan, lane_inf, lane_sign;
+
+        // Per-element valid bits for FP8/BF8 lane i (2 elements -> 1 lane)
+        // 8-bit element k validity is stored at vld_mask[2*k].
+        // Lane i consumes elements (2*i) and (2*i+1) -> indices 4*i and 4*i+2.
+        wire v0 = vld_mask[i * 4 + 0];
+        wire v1 = vld_mask[i * 4 + 2];
+        wire lane_valid = v0 | v1;
+
+        // ------------------------------------------------------------------
+        // 3a. Pre-Calculation (Extraction outside always_comb)
+        // ------------------------------------------------------------------
+
+        wire [1:0][4:0] ea_fp8_w, eb_fp8_w;
+        wire [1:0][4:0] ea_bf8_w, eb_bf8_w;
+
+        // Exception wires per format
+        wire [1:0]      nan_fp8_w, inf_fp8_w, sign_fp8_w;
+        wire [1:0]      nan_bf8_w, inf_bf8_w, sign_bf8_w;
+
+        for (genvar j = 0; j < 2; ++j) begin : g_f8_extract
+            localparam idx = i * 2 + j;
+            localparam OFF = (i % 2) * 16 + j * 8;
+
+            // Per-element masking (8-bit element k -> vld_mask[2*k])
+            wire sublane_vld = vld_mask[idx*2];
+
+            // --- FP8 Logic ---
+            assign ea_fp8_w[j] = cls_fp8[0][idx].is_sub ? 5'd1 : 5'(a_row[i/2][S_FP8-1+OFF -: E_FP8]);
+            assign eb_fp8_w[j] = cls_fp8[1][idx].is_sub ? 5'd1 : 5'(b_col[i/2][S_FP8-1+OFF -: E_FP8]);
+
+            // FP8 Exceptions (gated per element)
+            wire nan_in_fp8 = cls_fp8[0][idx].is_nan | cls_fp8[1][idx].is_nan;
+            wire inf_z_fp8  = (cls_fp8[0][idx].is_inf & cls_fp8[1][idx].is_zero) |
+                              (cls_fp8[0][idx].is_zero & cls_fp8[1][idx].is_inf);
+            wire inf_op_fp8 = cls_fp8[0][idx].is_inf | cls_fp8[1][idx].is_inf;
+
+            assign nan_fp8_w[j]  = (nan_in_fp8 | inf_z_fp8) & sublane_vld; // Inf*0 is NaN
+            assign inf_fp8_w[j]  = (inf_op_fp8 & ~inf_z_fp8) & sublane_vld;
+            assign sign_fp8_w[j] = cls_fp8[0][idx].sign ^ cls_fp8[1][idx].sign;
+
+            // --- BF8 Logic ---
+            assign ea_bf8_w[j] = cls_bf8[0][idx].is_sub ? 5'd1 : 5'(a_row[i/2][S_BF8-1+OFF -: E_BF8]);
+            assign eb_bf8_w[j] = cls_bf8[1][idx].is_sub ? 5'd1 : 5'(b_col[i/2][S_BF8-1+OFF -: E_BF8]);
+
+            // BF8 Exceptions (gated per element)
+            wire nan_in_bf8 = cls_bf8[0][idx].is_nan | cls_bf8[1][idx].is_nan;
+            wire inf_z_bf8  = (cls_bf8[0][idx].is_inf & cls_bf8[1][idx].is_zero) |
+                              (cls_bf8[0][idx].is_zero & cls_bf8[1][idx].is_inf);
+            wire inf_op_bf8 = cls_bf8[0][idx].is_inf | cls_bf8[1][idx].is_inf;
+
+            assign nan_bf8_w[j]  = (nan_in_bf8 | inf_z_bf8) & sublane_vld;
+            assign inf_bf8_w[j]  = (inf_op_bf8 & ~inf_z_bf8) & sublane_vld;
+            assign sign_bf8_w[j] = cls_bf8[0][idx].sign ^ cls_bf8[1][idx].sign;
+        end
+
+        // ------------------------------------------------------------------
+        // 3b. Muxing (Clean always_comb)
+        // ------------------------------------------------------------------
+        always_comb begin
+            case (fmt_f)
+                TCU_FP8_ID: begin
+                    ea_sel   = ea_fp8_w;
+                    eb_sel   = eb_fp8_w;
+                    bias_sel = BIAS_CONST_FP8;
+
+                    lane_nan  = nan_fp8_w;
+                    lane_inf  = inf_fp8_w;
+                    lane_sign = sign_fp8_w;
+                end
+                TCU_BF8_ID: begin
+                    ea_sel   = ea_bf8_w;
+                    eb_sel   = eb_bf8_w;
+                    bias_sel = BIAS_CONST_BF8;
+
+                    lane_nan  = nan_bf8_w;
+                    lane_inf  = inf_bf8_w;
+                    lane_sign = sign_bf8_w;
+                end
+                default: begin
+                    ea_sel   = '0;
+                    eb_sel   = '0;
+                    bias_sel = '0;
+                    lane_nan  = '0;
+                    lane_inf  = '0;
+                    lane_sign = '0;
+                end
+            endcase
+        end
+
+        // Calculate Pre-Sums (Exponent A + Exponent B)
+        wire [5:0] pre_sum_0, pre_sum_1;
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) exp_add1_0 (
+            .dataa(6'(ea_sel[0])), .datab(6'(eb_sel[0])), .cin(1'b0), .sum(pre_sum_0), `UNUSED_PIN(cout));
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) exp_add1_1 (
+            .dataa(6'(ea_sel[1])), .datab(6'(eb_sel[1])), .cin(1'b0), .sum(pre_sum_1), `UNUSED_PIN(cout));
+
+        // ------------------------------------------------------------------
+        // Correctness: select max/min term using per-element validity bits.
+        // - If only one sublane is valid, it MUST be selected as max.
+        // - Only if both valid do we compare pre_sum_0 vs pre_sum_1.
+        // This avoids extra 6-bit muxing and avoids zero/asymmetric bugs.
+        // ------------------------------------------------------------------
+        wire term0_is_max = (v0 & ~v1) | ((v0 & v1) & (pre_sum_0 >= pre_sum_1));
+        wire diff_sign = term0_is_max;
+
+        wire [5:0] max_pre_sum = term0_is_max ? pre_sum_0 : pre_sum_1;
+        wire [5:0] min_pre_sum = term0_is_max ? pre_sum_1 : pre_sum_0;
+
+        wire [EXP_W-1:0] final_exp;
+        VX_ks_adder #(.N(EXP_W), .BYPASS(`FORCE_BUILTIN_ADDER(EXP_W))) exp_final_add (
+            .dataa(EXP_W'(max_pre_sum)), .datab(EXP_W'(bias_sel)), .cin(1'b0), .sum(final_exp), `UNUSED_PIN(cout));
+
+        // Exponent is meaningful only if lane has at least one valid contributing element.
+        assign result_exp[i] = lane_valid ? final_exp : EXP_NEG_INF;
+
+        // ------------------------------------------------------------------
+        // 3c. Mantissa Multiplication
+        // ------------------------------------------------------------------
+        wire [1:0][7:0] y_raw_f8;
+        wire [1:0]      sign_f8;
+
+        for (genvar j = 0; j < 2; ++j) begin : g_f8_mul_sub
+            // Mux Mantissas and Signs
+            localparam idx = i * 2 + j;
+            localparam OFF = (i % 2) * 16 + j * 8;
+            wire [7:0] va = a_row[i/2][OFF +: 8];
+            wire [7:0] vb = b_col[i/2][OFF +: 8];
+            `UNUSED_VAR ({va, vb})
+
+            wire [3:0] ma_f8 = tmt_is_bfloat ?
+                (cls_bf8[0][idx].is_zero ? 4'd0 : {1'b0, !cls_bf8[0][idx].is_sub, va[1:0]}) :
+                (cls_fp8[0][idx].is_zero ? 4'd0 : {      !cls_fp8[0][idx].is_sub, va[2:0]});
+
+            wire [3:0] mb_f8 = tmt_is_bfloat ?
+                (cls_bf8[1][idx].is_zero ? 4'd0 : {1'b0, !cls_bf8[1][idx].is_sub, vb[1:0]}) :
+                (cls_fp8[1][idx].is_zero ? 4'd0 : {      !cls_fp8[1][idx].is_sub, vb[2:0]});
+
+            assign sign_f8[j] = va[7] ^ vb[7];
+
+            // 4x4 Multiplier
+            VX_wallace_mul #(.N(4), .CPA_KS(!`FORCE_BUILTIN_ADDER(4*2))) wtmul_f8 (
+                .a(ma_f8), .b(mb_f8), .p(y_raw_f8[j]));
+        end
+
+        // ------------------------------------------------------------------
+        // 3d. Alignment & Reduction
+        // ------------------------------------------------------------------
+
+        wire [5:0] diff_abs;
+        VX_ks_adder #(.N(6), .BYPASS(`FORCE_BUILTIN_ADDER(6))) ks_diff_f8 (
+            .dataa(max_pre_sum), .datab(~min_pre_sum), .cin(1'b1), .sum(diff_abs), `UNUSED_PIN(cout));
+
+        wire [7:0] y_f8_low_raw  = y_raw_f8[0];
+        wire [7:0] y_f8_high_raw = y_raw_f8[1];
+
+        wire [22:0] base_low  = {y_f8_low_raw,  15'd0};
+        wire [22:0] base_high = {y_f8_high_raw, 15'd0};
+
+        wire [22:0] aligned_sig_low;
+        wire [22:0] aligned_sig_high;
+
+        // Prevent shift wrap when exponent diff >= 32:
+        // diff_abs[5] indicates diff >= 32 (since diff_abs is 6-bit).
+        // For such large diffs the smaller term is effectively zero.
+        wire diff_ge_32 = diff_abs[5];
+        wire [4:0] shamt = diff_abs[4:0];
+
+        assign aligned_sig_low  = diff_sign ? base_low : (diff_ge_32 ? 23'd0 : (base_low >> shamt));
+        assign aligned_sig_high = diff_sign ? (diff_ge_32 ? 23'd0 : (base_high >> shamt)) : base_high;
+
+        // ------------------------------------------------------------------
+        // 3e. Absolute Difference / Addition
+        // ------------------------------------------------------------------
+        wire [23:0] mag_0 = {1'b0, aligned_sig_low};
+        wire [23:0] mag_1 = {1'b0, aligned_sig_high};
+        wire mag_0_is_larger = (mag_0 > mag_1);
+
+        wire [23:0] op_a = mag_0_is_larger ? mag_0 : mag_1;
+        wire [23:0] op_b = mag_0_is_larger ? mag_1 : mag_0;
+
+        wire do_sub = sign_f8[0] ^ sign_f8[1];
+        wire [23:0] adder_result;
+        VX_ks_adder #(.N(24), .BYPASS(`FORCE_BUILTIN_ADDER(24))) sig_adder_f8 (
+            .cin(do_sub), .dataa(op_a), .datab(do_sub ? ~op_b : op_b), .sum(adder_result), `UNUSED_PIN(cout));
+
+        wire [23:0] y_f8_add = adder_result;
+        wire sign_f8_add_raw = mag_0_is_larger ? sign_f8[0] : sign_f8[1];
+
+        // Force +0 on exact cancellation
+        wire sign_f8_add = (y_f8_add == 24'd0) ? 1'b0 : sign_f8_add_raw;
+
+        assign result_sig[i] = {sign_f8_add, y_f8_add};
+
+        // ------------------------------------------------------------------
+        // 3f. Exception Merging (Merge 2 sub-products per lane)
+        // ------------------------------------------------------------------
+
+        // Check for +Inf + -Inf (Generates NaN)
+        wire pos_inf_0 = lane_inf[0] & ~lane_sign[0];
+        wire neg_inf_0 = lane_inf[0] &  lane_sign[0];
+        wire pos_inf_1 = lane_inf[1] & ~lane_sign[1];
+        wire neg_inf_1 = lane_inf[1] &  lane_sign[1];
+
+        wire add_nan = (pos_inf_0 & neg_inf_1) | (neg_inf_0 & pos_inf_1);
+
+        wire any_nan = (|lane_nan) | add_nan;
+        wire any_inf = (|lane_inf) & ~any_nan;
+
+        // Result Sign:
+        // If one is Inf, take its sign.
+        // If both are Inf (same sign), take that sign.
+        // If neither is Inf, we rely on the arithmetic result sign (computed above).
+        wire final_sign_inf = lane_inf[0] ? lane_sign[0] : lane_sign[1];
+
+        assign exceptions[i].is_nan = any_nan;
+        assign exceptions[i].is_inf = any_inf;
+        assign exceptions[i].sign   = any_inf ? final_sign_inf : sign_f8_add;
+
+    end
+
+endmodule
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv
new file mode 100644
index 00000000..c8471086
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_int.sv
@@ -0,0 +1,116 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_int import VX_tcu_pkg::*;
+#(
+    parameter N   = 2,
+    parameter TCK = 2 * N
+) (
+    input wire [2:0]             fmt_i,
+    input wire [N-1:0][31:0]     a_row,
+    input wire [N-1:0][31:0]     b_col,
+
+    // Output width matches the standard accumulation width (25 bits)
+    output logic [TCK-1:0][24:0] result
+);
+    wire fmt_is_signed_int = tcu_fmt_is_signed_int(fmt_i);
+
+    // ----------------------------------------------------------------------
+    // 1. Operand Extraction (Zero Cost wiring)
+    // ----------------------------------------------------------------------
+    wire [TCK-1:0][1:0][7:0] raw_a_i8, raw_b_i8;
+    wire [TCK-1:0][3:0][3:0] raw_a_i4, raw_b_i4;
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_prep_int
+        // Extract 8-bit operands (2 per lane)
+        for (genvar j = 0; j < 2; ++j) begin : g_i8
+            assign raw_a_i8[i][j] = a_row[i/2][(i%2)*16 + j*8 +: 8];
+            assign raw_b_i8[i][j] = b_col[i/2][(i%2)*16 + j*8 +: 8];
+        end
+        // Extract 4-bit operands (4 per lane)
+        for (genvar j = 0; j < 4; ++j) begin : g_i4
+            assign raw_a_i4[i][j] = a_row[i/2][(i%2)*16 + j*4 +: 4];
+            assign raw_b_i4[i][j] = b_col[i/2][(i%2)*16 + j*4 +: 4];
+        end
+    end
+
+    // ----------------------------------------------------------------------
+    // 2. Multiplication & Accumulation
+    // ----------------------------------------------------------------------
+    for (genvar i = 0; i < TCK; ++i) begin : g_mul_int
+
+        // --- I8/U8 Processing ---------------------------------------------
+        wire signed [16:0] y_prod_i8 [2];
+
+        for (genvar j = 0; j < 2; ++j) begin : g_mul_i8
+            // Sign extension handling
+            wire signed [8:0] s_a = fmt_is_signed_int ?
+                $signed({raw_a_i8[i][j][7], raw_a_i8[i][j]}) :
+                $signed({1'b0, raw_a_i8[i][j]});
+
+            wire signed [8:0] s_b = fmt_is_signed_int ?
+                $signed({raw_b_i8[i][j][7], raw_b_i8[i][j]}) :
+                $signed({1'b0, raw_b_i8[i][j]});
+
+            wire signed [17:0] prod_full = s_a * s_b;
+            `UNUSED_VAR (prod_full[17])
+            assign y_prod_i8[j] = prod_full[16:0];
+        end
+
+        wire [16:0] y_i8_add_res;
+        VX_ks_adder #(
+            .N(17),
+            .BYPASS (`FORCE_BUILTIN_ADDER(17))
+        ) i8_adder (
+            .cin   (1'b0),
+            .dataa (y_prod_i8[0]),
+            .datab (y_prod_i8[1]),
+            .sum   (y_i8_add_res),
+            `UNUSED_PIN(cout)
+        );
+
+        // --- I4/U4 Processing ---------------------------------------------
+        wire signed [3:0][9:0] y_prod_i4;
+
+        for (genvar j = 0; j < 4; ++j) begin : g_mul_i4
+            // Sign extension handling
+            wire signed [4:0] s_a = fmt_is_signed_int ?
+                $signed({raw_a_i4[i][j][3], raw_a_i4[i][j]}) :
+                $signed({1'b0, raw_a_i4[i][j]});
+
+            wire signed [4:0] s_b = fmt_is_signed_int ?
+                $signed({raw_b_i4[i][j][3], raw_b_i4[i][j]}) :
+                $signed({1'b0, raw_b_i4[i][j]});
+
+            wire signed [9:0] prod_full = s_a * s_b;
+            assign y_prod_i4[j] = prod_full;
+        end
+
+        wire [9:0] y_i4_add_res;
+        VX_csa_tree #(
+            .N (4),
+            .W (10),
+            .S (10),
+            .CPA_KS (!`FORCE_BUILTIN_ADDER(10))
+        ) i4_adder (
+            .operands (y_prod_i4),
+            .sum      (y_i4_add_res),
+            `UNUSED_PIN (cout)
+        );
+
+        // --- Output Muxing ------------------------------------------------
+        always_comb begin
+            case ({1'b1, fmt_i})
+                TCU_I8_ID: result[i] = 25'($signed(y_i8_add_res));
+                TCU_U8_ID: result[i] = {8'd0, y_i8_add_res};
+                TCU_I4_ID: result[i] = 25'($signed(y_i4_add_res));
+                TCU_U4_ID: result[i] = {15'd0, y_i4_add_res};
+                default:   result[i] = 'x;
+            endcase
+        end
+    end
+
+endmodule
diff --git a/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv b/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv
new file mode 100644
index 00000000..c1fc6ac8
--- /dev/null
+++ b/hw/rtl/tcu/drl/VX_tcu_drl_mul_join.sv
@@ -0,0 +1,192 @@
+// Copyright © 2019-2023
+// Licensed under the Apache License, Version 2.0
+// See the License for the specific language governing permissions and limitations.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_mul_join import VX_tcu_pkg::*;
+#(
+    parameter N     = 2,
+    parameter TCK   = 2 * N,
+    parameter W     = 25,
+    parameter WA    = 28,
+    parameter EXP_W = 10
+) (
+    input wire [3:0]                  fmt_s,
+    input wire [31:0]                 c_val,
+
+    // Inputs from the Split Paths
+    input wire [TCK-1:0][24:0]        sig_f16,
+    input wire [TCK-1:0][EXP_W-1:0]   exp_f16,
+    input fedp_excep_t [TCK-1:0]      exceptions_f16,
+
+    input wire [TCK-1:0][24:0]        sig_f8,
+    input wire [TCK-1:0][EXP_W-1:0]   exp_f8,
+    input fedp_excep_t [TCK-1:0]      exceptions_f8,
+
+    input wire [TCK-1:0][24:0]        sig_int,
+    // (Integer path has no exponent and no FP exceptions)
+
+    // Unified Outputs to Stage 2 (Alignment)
+    output logic [TCK:0][24:0]        joined_sigs,
+    output logic [TCK:0][EXP_W-1:0]   joined_exps,
+
+    // Final Reduced Exception
+    output fedp_excep_t               exceptions
+);
+
+    localparam [EXP_W-1:0] EXP_NEG_INF = {1'b1, {(EXP_W-1){1'b0}}};
+
+    // ======================================================================
+    // 1. Path Selection (Muxing)
+    // ======================================================================
+
+    logic [TCK-1:0][24:0]      sel_sigs;
+    logic [TCK-1:0][EXP_W-1:0] sel_exps;
+    fedp_excep_t [TCK-1:0]     sel_exc;
+
+    always_comb begin
+        case (fmt_s)
+            // --- F16 / BF16 / TF32 ---
+        `ifdef TCU_BF16_ENABLE
+            TCU_BF16_ID,
+        `endif
+        `ifdef TCU_TF32_ENABLE
+            TCU_TF32_ID,
+        `endif
+            TCU_FP16_ID: begin
+                sel_sigs = sig_f16;
+                sel_exps = exp_f16;
+                sel_exc  = exceptions_f16;
+            end
+
+            // --- FP8 / BF8 ---
+            `ifdef TCU_FP8_ENABLE
+            TCU_FP8_ID, TCU_BF8_ID: begin
+                sel_sigs = sig_f8;
+                sel_exps = exp_f8;
+                sel_exc  = exceptions_f8;
+            end
+            `endif
+
+            // --- Integers ---
+            `ifdef TCU_INT_ENABLE
+            TCU_I8_ID, TCU_U8_ID, TCU_I4_ID, TCU_U4_ID: begin
+                sel_sigs = sig_int;
+                sel_exps = 'x;
+                // Integer paths do not generate FP exceptions
+                for (int i = 0; i < TCK; i++) begin
+                    sel_exc[i] = '0;
+                end
+            end
+            `endif
+
+            default: begin
+                sel_sigs = 'x;
+                sel_exps = 'x;
+                sel_exc  = 'x;
+            end
+        endcase
+    end
+
+    // ======================================================================
+    // 2. C-Term Handling
+    // ======================================================================
+
+    // 2a. Local Classifier for C (Check for Zero/Nan/Inf)
+    fedp_class_t cls_c;
+    VX_tcu_drl_classifier #(.N(1), .WIDTH(32), .FMT(TCU_FP32_ID)) c_c (
+        .val(c_val),
+        .cls(cls_c)
+    );
+    `UNUSED_VAR (cls_c)
+
+    // 2b. C-Term Signal Extraction
+    // If format is INT, we just take the bits. If float, we add hidden bit.
+    logic [24:0] c_sig_final;
+    wire c_is_int = tcu_fmt_is_int(fmt_s); // Helper from pkg
+
+    assign c_sig_final = c_is_int ?
+        c_val[24:0] :
+        {c_val[31], 1'b1, c_val[22:0]};
+
+    // 2c. C-Term Exponent Calculation
+    // Corresponds to original logic in VX_tcu_drl_exp_bias
+    wire [7:0] c_exp_raw = c_val[30:23];
+    // Adjustment: c_exp - (W - 1) + WA - 1
+    wire [EXP_W-1:0] c_exp_adj = EXP_W'(c_exp_raw) - EXP_W'(W-1) + EXP_W'(WA-1);
+    wire [EXP_W-1:0] c_exp_final = (cls_c.is_zero) ? EXP_NEG_INF : c_exp_adj;
+
+    // ======================================================================
+    // 3. Output Aggregation (Signal & Exponent)
+    // ======================================================================
+
+    // Combine Lanes + C-Term
+    // Index TCK is C-term, 0..TCK-1 are lanes
+    assign joined_sigs  = {c_sig_final, sel_sigs};
+    assign joined_exps  = {c_exp_final, sel_exps};
+
+    // Note: Max Exponent calculation has been moved to the parent module
+    // as per instructions.
+
+    // ======================================================================
+    // 4. Exception Reduction (Lanes + C-term)
+    // ======================================================================
+
+    // Unpack lane exceptions for vector operations
+    logic [TCK-1:0] lane_nan;
+    logic [TCK-1:0] lane_inf;
+    logic [TCK-1:0] lane_sign;
+
+    for (genvar i = 0; i < TCK; ++i) begin : g_unpack_exc
+        assign lane_nan[i]  = sel_exc[i].is_nan;
+        assign lane_inf[i]  = sel_exc[i].is_inf;
+        assign lane_sign[i] = sel_exc[i].sign;
+    end
+
+    // 4a. C-Term flags
+    // If Integer mode, C-term exceptions are suppressed (always valid)
+    wire c_is_nan = cls_c.is_nan & ~c_is_int;
+    wire c_is_inf = cls_c.is_inf & ~c_is_int;
+    wire c_sign   = cls_c.sign; // Relevant only if Inf
+
+    // 4b. Global Infinity Analysis
+    // We must detect if we are adding +Inf and -Inf anywhere in the dot product.
+    // This includes (Lane vs Lane) AND (Lanes vs C-term).
+
+    wire [TCK-1:0] p_pos_inf = lane_inf & ~lane_sign;
+    wire [TCK-1:0] p_neg_inf = lane_inf &  lane_sign;
+
+    wire c_pos_inf = c_is_inf & ~c_sign;
+    wire c_neg_inf = c_is_inf &  c_sign;
+
+    // Check if we have ANY positive infinity (Lanes or C)
+    wire has_pos = (|p_pos_inf) | c_pos_inf;
+
+    // Check if we have ANY negative infinity (Lanes or C)
+    wire has_neg = (|p_neg_inf) | c_neg_inf;
+
+    // 4c. Final Logic
+    // NaN if:
+    // 1. Any input (Lane product or C-term) is NaN
+    // 2. We have both +Inf and -Inf in the sum (Invalid Operation)
+    wire any_input_nan = (|lane_nan) | c_is_nan;
+    wire add_gen_nan   = has_pos & has_neg;
+    wire res_nan       = any_input_nan | add_gen_nan;
+
+    // Inf if:
+    // 1. We have an Inf (Pos or Neg)
+    // 2. Result is NOT NaN
+    wire res_inf = (has_pos | has_neg) & ~res_nan;
+
+    // Sign:
+    // If result is Inf, sign is 1 if we have NegInf (and no PosInf, implied by !NaN).
+    // If result is Normal/Zero, sign is determined by the final adder (Stage 3),
+    // but typically the exception structure reports the "Special Case" sign here.
+    wire res_sign = has_neg & ~has_pos;
+
+    assign exceptions.is_nan = res_nan;
+    assign exceptions.is_inf = res_inf;
+    assign exceptions.sign   = res_sign;
+
+endmodule
