   static inline int32_t asr32(int32_t x, uint32_t k) {
     if (k == 0) return x;
     if (k >= 31) return (x < 0) ? -1 : 0; // sign saturation after huge shift
     return (x >= 0) ? (x >> k) : ~((~x) >> k);
   }
