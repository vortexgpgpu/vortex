 // Build a smem descriptor from a pointer and row stride in bytes.
+// The offset field encodes the physical byte offset from the LMEM hardware
+// base address (0xffff0000), not the CTA-relative offset.  Because
+// LMEM_BASE_ADDR = 0xffff0000 its lower 16 bits are all zero, so
+// ptr & 0xFFFF == ptr - LMEM_BASE_ADDR for any LMEM pointer.
 static __attribute__((always_inline)) smem_matrix_desc vx_make_smem_desc(const void* ptr, uint32_t leading_bytes) {
-  uint32_t lmem_base = csr_read(VX_CSR_LOCAL_MEM_BASE);
-  uint32_t offset = static_cast<uint32_t>(reinterpret_cast<uintptr_t>(ptr)) - lmem_base;
-  return {((leading_bytes & 0xFFFFu) << 16) | (offset & 0xFFFFu)};
+  uint32_t offset = static_cast<uint32_t>(reinterpret_cast<uintptr_t>(ptr)) & 0xFFFFu;
+  return {((leading_bytes & 0xFFFFu) << 16) | offset};
 }

