+// distributed under the License is distributed on an "AS IS" BASIS,
+// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+// See the License for the specific language governing permissions and
+// limitations under the License.
+
+`include "VX_define.vh"
+
+module VX_tcu_drl_lza #(
+    parameter N = 30
+) (
+    input  wire [N-1:0]      op_a, // Redundant Sum Vector
+    input  wire [N-1:0]      op_b, // Redundant Carry Vector
+    output wire [$clog2(N)-1:0] lza_count
+);
+    // -------------------------------------------------------------------------
+    // 1. Pre-computation
+    // -------------------------------------------------------------------------
+    wire [N-1:0] p_str = op_a ^ op_b;      // Propagate
+    wire [N-1:0] k_str = op_a | op_b;      // Kill-Not (Generate or Propagate)
+
+    // The LZA pattern logic uses k_str[i-1], so the MSB k_str[N-1] is never accessed.
+    `UNUSED_VAR (k_str[N-1])
+
+    // -------------------------------------------------------------------------
+    // 2. Pattern String Generation (OpenSPARC T1 Logic)
+    // -------------------------------------------------------------------------
+    // f_raw[i] = p[i] XOR k[i-1]
+
+    wire [N-1:0] f_raw;
+
+    // Generate bits [N-1:1]
+    for (genvar i = 1; i < N; i++) begin : g_lza_pattern_raw
+        assign f_raw[i] = p_str[i] ^ k_str[i-1];
+    end
+
+    // Generate bit [0]
+    assign f_raw[0] = p_str[0];
+
+    // The bias correction shift below drops f_raw[0], so it is unused.
+    `UNUSED_VAR (f_raw[0])
+
+    // -------------------------------------------------------------------------
+    // 3. Bias Correction (Shift Right by 1)
+    // -------------------------------------------------------------------------
+    // By shifting f_str RIGHT, we effectively add +1 to the Zero Count.
+    // This forces the MSB to land at WA (Overshift) or WA-1 (Normal), avoiding
+    // the unhandled WA-2 (Undershift) case.
+
+    wire [N-1:0] f_str;
+    assign f_str = {1'b0, f_raw[N-1:1]};
+
+    // -------------------------------------------------------------------------
+    // 4. Leading One Detection (LOD)
+    // -------------------------------------------------------------------------
+
+    VX_lzc #(
+        .N(N)
+    ) lzc_inst (
+        .data_in   (f_str),
+        .data_out  (lza_count),
+        `UNUSED_PIN (valid_out)
+    );
+
+endmodule
