-                                                  b_col_2[k][2*EW +: EW];
-            wire [EW-1:0] sg2_1 = sg2_mask[3] ? b_col_2[k][3*EW +: EW] :
-                                    sg2_mask[2] ? b_col_2[k][2*EW +: EW] :
-                                                  b_col_2[k][1*EW +: EW];
-            wire [EW-1:0] sg3_0 = sg3_mask[0] ? b_col_2[k][4*EW +: EW] :
-                                    sg3_mask[1] ? b_col_2[k][5*EW +: EW] :
-                                                  b_col_2[k][6*EW +: EW];
-            wire [EW-1:0] sg3_1 = sg3_mask[3] ? b_col_2[k][7*EW +: EW] :
