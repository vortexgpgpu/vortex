include config.mk

.PHONY: third_party hardware software tests

all: third_party hardware software tests

third_party:
	$(MAKE) -C $(VORTEX_HOME)/third_party

hardware: third_party
	$(MAKE) -C hw
	$(MAKE) -C sim

software: third_party
	$(MAKE) -C sw/kernel
	$(MAKE) -C sw/runtime/stub

tests: software hardware
	$(MAKE) -C tests

clean:
	$(MAKE) -C sw clean
	$(MAKE) -C hw clean
	$(MAKE) -C sim clean
	$(MAKE) -C tests clean

clean-all: clean
	$(MAKE) -C $(VORTEX_HOME)/third_party clean

# Install setup
KERNEL_INC_DST = $(INSTALLDIR)/kernel/include
KERNEL_LIB_DST = $(INSTALLDIR)/kernel/lib$(XLEN)
RUNTIME_INC_DST = $(INSTALLDIR)/runtime/include
RUNTIME_LIB_DST = $(INSTALLDIR)/runtime/lib

KERNEL_HEADERS = $(wildcard $(VORTEX_HOME)/sw/kernel/include/*.h)
KERNEL_LIBS = $(wildcard sw/kernel/*.a)
RUNTIME_HEADERS = $(wildcard $(VORTEX_HOME)/sw/runtime/include/*.h)
RUNTIME_LIBS = $(wildcard sw/runtime/*.so)

INSTALL_DIRS = $(KERNEL_LIB_DST) $(RUNTIME_LIB_DST) $(KERNEL_INC_DST) $(RUNTIME_INC_DST)

$(INSTALL_DIRS):
	mkdir -p $@

$(KERNEL_INC_DST)/VX_types.h: sw/VX_types.h | $(KERNEL_INC_DST)
	cp $< $@

$(KERNEL_INC_DST)/%.h: $(VORTEX_HOME)/sw/kernel/include/%.h | $(KERNEL_INC_DST)
	cp $< $@

$(RUNTIME_INC_DST)/%.h: $(VORTEX_HOME)/sw/runtime/include/%.h | $(RUNTIME_INC_DST)
	cp $< $@

$(KERNEL_LIB_DST)/%.a: sw/kernel/%.a | $(KERNEL_LIB_DST)
	cp $< $@

$(RUNTIME_LIB_DST)/%.so: sw/runtime/%.so | $(RUNTIME_LIB_DST)
	cp $< $@

install: $(INSTALL_DIRS) \
         $(KERNEL_INC_DST)/VX_types.h \
		 $(KERNEL_HEADERS:$(VORTEX_HOME)/sw/kernel/include/%=$(KERNEL_INC_DST)/%) \
         $(RUNTIME_HEADERS:$(VORTEX_HOME)/sw/runtime/include/%=$(RUNTIME_INC_DST)/%) \
		 $(KERNEL_LIBS:sw/kernel/%=$(KERNEL_LIB_DST)/%) \
		 $(RUNTIME_LIBS:sw/runtime/%=$(RUNTIME_LIB_DST)/%)
