include config.mk

.PHONY: third_party hardware software tests

all: third_party hardware software tests

third_party:
	$(MAKE) -C $(VORTEX_HOME)/third_party

hardware: third_party
	$(MAKE) -C hw
	$(MAKE) -C sim

software: third_party
	$(MAKE) -C sw/kernel
	$(MAKE) -C sw/runtime/stub

tests: software hardware
	$(MAKE) -C tests

clean:
	$(MAKE) -C sw clean
	$(MAKE) -C hw clean
	$(MAKE) -C sim clean
	$(MAKE) -C tests clean

clean-all: clean
	$(MAKE) -C $(VORTEX_HOME)/third_party clean

# Install layout — mirrors the CUDA / ROCm / oneAPI SDK pattern so
# downstream consumers (mesa, pocl, chipstar) integrate via a single
# $VORTEX_PATH env var + pkg-config discovery. Source-tree paths
# ($VORTEX_HOME, $VORTEX_BUILD_DIR) never leak to consumers.
#
#   $INSTALLDIR/
#   ├── kernel/include/     ← public device-side headers (vx_*.h)
#   │   └── VX_types.h         (generated, copied from $BUILDDIR/sw/)
#   ├── kernel/lib<XLEN>/   ← libvx_runtime.a (per-XLEN)
#   ├── runtime/include/    ← public host-side headers (vortex.h, vortex2.h,
#   │                          graphics.h, tensor.h, dxa.h)
#   ├── runtime/lib/        ← libvortex.so + libvortex-{simx,xrt,rtlsim,opae}.so
#   └── lib/pkgconfig/      ← vortex-runtime.pc + vortex-kernel.pc

KERNEL_INC_DST  = $(INSTALLDIR)/kernel/include
KERNEL_LIB_DST  = $(INSTALLDIR)/kernel/lib$(XLEN)
RUNTIME_INC_DST = $(INSTALLDIR)/runtime/include
RUNTIME_LIB_DST = $(INSTALLDIR)/runtime/lib
PKGCONFIG_DST   = $(INSTALLDIR)/lib/pkgconfig

KERNEL_HEADERS  = $(wildcard $(VORTEX_HOME)/sw/kernel/include/*.h)
KERNEL_LIBS     = $(wildcard sw/kernel/*.a)
RUNTIME_HEADERS = $(wildcard $(VORTEX_HOME)/sw/runtime/include/*.h)
RUNTIME_LIBS    = $(wildcard sw/runtime/*.so)
PKGCONFIG_FILES = sw/runtime/vortex-runtime.pc sw/runtime/vortex-kernel.pc

INSTALL_DIRS = $(KERNEL_LIB_DST) $(RUNTIME_LIB_DST) \
               $(KERNEL_INC_DST) $(RUNTIME_INC_DST) \
               $(PKGCONFIG_DST)

$(INSTALL_DIRS):
	mkdir -p $@

# Generated VX_types.h ships in kernel/include alongside the public
# kernel API headers (it's read by both host and device code; the
# kernel-side install path is the canonical home).
$(KERNEL_INC_DST)/VX_types.h: sw/VX_types.h | $(KERNEL_INC_DST)
	cp $< $@

# tensor_cfg.h lives in sw/common/ (vortex-internal, shared by sw and
# sim per the sw/↔sim/+hw/ bidirectional isolation rule) but is pulled
# in transitively by both vx_tensor.h and tensor.h. Install it to
# kernel/include so downstream consumers' -I$VORTEX_PATH/kernel/include
# (added by vortex-runtime.pc + vortex-kernel.pc) resolves the include.
$(KERNEL_INC_DST)/tensor_cfg.h: $(VORTEX_HOME)/sw/common/tensor_cfg.h | $(KERNEL_INC_DST)
	cp $< $@

$(KERNEL_INC_DST)/%.h: $(VORTEX_HOME)/sw/kernel/include/%.h | $(KERNEL_INC_DST)
	cp $< $@

$(RUNTIME_INC_DST)/%.h: $(VORTEX_HOME)/sw/runtime/include/%.h | $(RUNTIME_INC_DST)
	cp $< $@

$(KERNEL_LIB_DST)/%.a: sw/kernel/%.a | $(KERNEL_LIB_DST)
	cp $< $@

$(RUNTIME_LIB_DST)/%.so: sw/runtime/%.so | $(RUNTIME_LIB_DST)
	cp $< $@

# pkg-config descriptors — generated by configure (substituting
# @INSTALLDIR@, @XLEN@, @VORTEX_VERSION@), copied as-is on install.
$(PKGCONFIG_DST)/%.pc: sw/runtime/%.pc | $(PKGCONFIG_DST)
	cp $< $@

install: $(INSTALL_DIRS) \
         $(KERNEL_INC_DST)/VX_types.h \
         $(KERNEL_INC_DST)/tensor_cfg.h \
         $(KERNEL_HEADERS:$(VORTEX_HOME)/sw/kernel/include/%=$(KERNEL_INC_DST)/%) \
         $(RUNTIME_HEADERS:$(VORTEX_HOME)/sw/runtime/include/%=$(RUNTIME_INC_DST)/%) \
         $(KERNEL_LIBS:sw/kernel/%=$(KERNEL_LIB_DST)/%) \
         $(RUNTIME_LIBS:sw/runtime/%=$(RUNTIME_LIB_DST)/%) \
         $(PKGCONFIG_FILES:sw/runtime/%=$(PKGCONFIG_DST)/%)
