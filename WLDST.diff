+#pragma once
+
+#include <vx_intrinsics.h>
+#include <stdint.h>
+
+namespace vortex {
+
+//
+// Warp-level bulk Load/Store extension
+//
+
+// Warp-Level Collaborative Bulk Load (2 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Swizzle):
+// The hardware crossbar directly routes memory fetched from one thread's
+// base address into the destination registers of a different thread.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int src_row_base = (t / 2) * 2;
+//     int src_col      = t % 2;
+//     warp_dst[t][0] = *(float*)(warp_base[src_row_base + 0] + src_col * stride);
+//     warp_dst[t][1] = *(float*)(warp_base[src_row_base + 1] + src_col * stride);
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wld_f2(float dst[2], const void* base, uint32_t stride) {
+  register float _d0 __asm__("f0");
+  register float _d1 __asm__("f1");
+  __asm__ volatile (".insn r %2, 1, 4, %0, %3, %4"
+    : "=f"(_d0), "=f"(_d1)
+    : "i"(RISCV_CUSTOM0), "r"(base), "r"(stride)
+    : "memory");
+  dst[0] = _d0;
+  dst[1] = _d1;
+}
+
+// Warp-Level Collaborative Bulk Load (4 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Swizzle):
+// The hardware crossbar directly routes memory fetched from one thread's
+// base address into the destination registers of a different thread.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int src_row_base = (t / 4) * 4;
+//     int src_col      = t % 4;
+//     warp_dst[t][0] = *(float*)(warp_base[src_row_base + 0] + src_col * stride);
+//     warp_dst[t][1] = *(float*)(warp_base[src_row_base + 1] + src_col * stride);
+//     warp_dst[t][2] = *(float*)(warp_base[src_row_base + 2] + src_col * stride);
+//     warp_dst[t][3] = *(float*)(warp_base[src_row_base + 3] + src_col * stride);
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wld_f4(float dst[4], const void* base, uint32_t stride) {
+  register float _d0 __asm__("f0");
+  register float _d1 __asm__("f1");
+  register float _d2 __asm__("f2");
+  register float _d3 __asm__("f3");
+  __asm__ volatile (".insn r %4, 2, 4, %0, %5, %6"
+    : "=f"(_d0), "=f"(_d1), "=f"(_d2), "=f"(_d3)
+    : "i"(RISCV_CUSTOM0), "r"(base), "r"(stride)
+    : "memory");
+  dst[0] = _d0;
+  dst[1] = _d1;
+  dst[2] = _d2;
+  dst[3] = _d3;
+}
+
+// Warp-Level Collaborative Bulk Load (8 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Swizzle):
+// The hardware crossbar directly routes memory fetched from one thread's
+// base address into the destination registers of a different thread.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int src_row_base = (t / 8) * 8;
+//     int src_col      = t % 8;
+//     warp_dst[t][0] = *(float*)(warp_base[src_row_base + 0] + src_col * stride);
+//     warp_dst[t][1] = *(float*)(warp_base[src_row_base + 1] + src_col * stride);
+//     warp_dst[t][2] = *(float*)(warp_base[src_row_base + 2] + src_col * stride);
+//     warp_dst[t][3] = *(float*)(warp_base[src_row_base + 3] + src_col * stride);
+//     warp_dst[t][4] = *(float*)(warp_base[src_row_base + 4] + src_col * stride);
+//     warp_dst[t][5] = *(float*)(warp_base[src_row_base + 5] + src_col * stride);
+//     warp_dst[t][6] = *(float*)(warp_base[src_row_base + 6] + src_col * stride);
+//     warp_dst[t][7] = *(float*)(warp_base[src_row_base + 7] + src_col * stride);
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wld_f8(float dst[8], const void* base, uint32_t stride) {
+  register float _d0 __asm__("f0");
+  register float _d1 __asm__("f1");
+  register float _d2 __asm__("f2");
+  register float _d3 __asm__("f3");
+  register float _d4 __asm__("f4");
+  register float _d5 __asm__("f5");
+  register float _d6 __asm__("f6");
+  register float _d7 __asm__("f7");
+  __asm__ volatile (".insn r %8, 3, 4, %0, %9, %10"
+    : "=f"(_d0), "=f"(_d1), "=f"(_d2), "=f"(_d3), "=f"(_d4), "=f"(_d5), "=f"(_d6), "=f"(_d7)
+    : "i"(RISCV_CUSTOM0), "r"(base), "r"(stride)
+    : "memory");
+  dst[0] = _d0;
+  dst[1] = _d1;
+  dst[2] = _d2;
+  dst[3] = _d3;
+  dst[4] = _d4;
+  dst[5] = _d5;
+  dst[6] = _d6;
+  dst[7] = _d7;
+}
+
+// Warp-Level Collaborative Bulk Store (2 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Un-swizzle):
+// The hardware crossbar directly routes registers from one thread
+// to the memory addresses originally provided by different threads.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int dst_row_base = (t / 2) * 2;
+//     int dst_col      = t % 2;
+//     *(float*)(warp_base[dst_row_base + 0] + dst_col * stride) = warp_src[t][0];
+//     *(float*)(warp_base[dst_row_base + 1] + dst_col * stride) = warp_src[t][1];
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wst_f2(void* base, const float src[2], uint32_t stride) {
+  register float _d0 __asm__("f0") = src[0];
+  register float _d1 __asm__("f1") = src[1];
+  __asm__ volatile (".insn r %0, 5, 4, %1, %3, %4" :
+    : "i"(RISCV_CUSTOM0), "f"(_d0), "f"(_d1), "r"(base), "r"(stride)
+    : "memory");
+}
+
+// Warp-Level Collaborative Bulk Store (4 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Un-swizzle):
+// The hardware crossbar directly routes registers from one thread
+// to the memory addresses originally provided by different threads.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int dst_row_base = (t / 4) * 4;
+//     int dst_col      = t % 4;
+//     *(float*)(warp_base[dst_row_base + 0] + dst_col * stride) = warp_src[t][0];
+//     *(float*)(warp_base[dst_row_base + 1] + dst_col * stride) = warp_src[t][1];
+//     *(float*)(warp_base[dst_row_base + 2] + dst_col * stride) = warp_src[t][2];
+//     *(float*)(warp_base[dst_row_base + 3] + dst_col * stride) = warp_src[t][3];
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wst_f4(void* base, const float src[4], uint32_t stride) {
+  register float _d0 __asm__("f0") = src[0];
+  register float _d1 __asm__("f1") = src[1];
+  register float _d2 __asm__("f2") = src[2];
+  register float _d3 __asm__("f3") = src[3];
+  __asm__ volatile (".insn r %0, 6, 4, %1, %5, %6"
+    :
+    : "i"(RISCV_CUSTOM0), "f"(_d0), "f"(_d1), "f"(_d2), "f"(_d3), "r"(base), "r"(stride)
+    : "memory");
+}
+
+// Warp-Level Collaborative Bulk Store (8 registers)
+// Formal Hardware Algorithm (Warp-Collaborative Un-swizzle):
+// The hardware crossbar directly routes registers from one thread
+// to the memory addresses originally provided by different threads.
+// for (int t = 0; t < WARP_SIZE; ++t) {
+//   if (warp_mask[t]) {
+//     int dst_row_base = (t / 8) * 8;
+//     int dst_col      = t % 8;
+//     *(float*)(warp_base[dst_row_base + 0] + dst_col * stride) = warp_src[t][0];
+//     *(float*)(warp_base[dst_row_base + 1] + dst_col * stride) = warp_src[t][1];
+//     *(float*)(warp_base[dst_row_base + 2] + dst_col * stride) = warp_src[t][2];
+//     *(float*)(warp_base[dst_row_base + 3] + dst_col * stride) = warp_src[t][3];
+//     *(float*)(warp_base[dst_row_base + 4] + dst_col * stride) = warp_src[t][4];
+//     *(float*)(warp_base[dst_row_base + 5] + dst_col * stride) = warp_src[t][5];
+//     *(float*)(warp_base[dst_row_base + 6] + dst_col * stride) = warp_src[t][6];
+//     *(float*)(warp_base[dst_row_base + 7] + dst_col * stride) = warp_src[t][7];
+//   }
+// }
+__attribute__((always_inline))
+inline void vx_wst_f8(void* base, const float src[8], uint32_t stride) {
+  register float _d0 __asm__("f0") = src[0];
+  register float _d1 __asm__("f1") = src[1];
+  register float _d2 __asm__("f2") = src[2];
+  register float _d3 __asm__("f3") = src[3];
+  register float _d4 __asm__("f4") = src[4];
+  register float _d5 __asm__("f5") = src[5];
+  register float _d6 __asm__("f6") = src[6];
+  register float _d7 __asm__("f7") = src[7];
+  __asm__ volatile (".insn r %0, 7, 4, %1, %9, %10" :
+    : "i"(RISCV_CUSTOM0), "f"(_d0), "f"(_d1), "f"(_d2), "f"(_d3), "f"(_d4), "f"(_d5), "f"(_d6), "f"(_d7), "r"(base), "r"(stride)
+    : "memory");
+}
+
+}
