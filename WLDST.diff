+    // uop_idx lives in op_args.lsu.offset[3:0]; stride is rs3_data (uniform across lanes).
+    // Multiply via shift-and-add on the 3-bit uop_idx (0-7), no dedicated multiplier needed.
+    wire is_bulk_lsu = operands_if.data.op_args.lsu.is_bulk;
+    wire [2:0] bulk_uop_idx = operands_if.data.op_args.lsu.offset[2:0];
+
+    wire [`SIMD_WIDTH-1:0][`XLEN-1:0] stride_off;
+    for (genvar j = 0; j < `SIMD_WIDTH; ++j) begin : g_stride_off
