+`include "VX_define.vh"
+
+// VX_uop_wldst: Micro-op sequencer for bulk load/store instructions.
+//
+// Expands one bulk vx_wld/vx_wst instruction into N sequential LSU uops,
+// one per float register.  N is encoded in ibuf_in.op_args.lsu.offset[1:0]
+// which carries funct3[1:0] from the original instruction:
+//   01 (1) -> 2 regs,  10 (2) -> 4 regs,  11 (3) -> 8 regs
+//
+// Decode-stage register layout (from VX_decode.sv):
+//   rs1  = integer base address
+//   rs2  = first float data register (stores only, base f0)
+//   rs3  = integer stride
+//   rd   = first float destination register (loads only, base f10)
+//
+// Each uop increments rd (load) or rs2 (store) by uop_idx.
+// uop_idx is placed in offset[3:0] so the dispatcher can compute:
+//   effective_rs1[lane] = rs1[lane] + rs3[lane] * uop_idx  (shift-and-add)
+
+module VX_uop_wldst import VX_gpu_pkg::*; (
+    input  wire      clk,
+    input  wire      reset,
+    input  wire      start,
+    input  wire      next,
+    input  ibuffer_t ibuf_in,
+    output ibuffer_t ibuf_out,
+    output reg       done
+);
+    // Derive parameters from the incoming instruction
+    wire is_store = ibuf_in.op_args.lsu.is_store;
+
+    // vcnt: 1=2regs, 2=4regs, 3=8regs
+    wire [3:0] uop_count = (4'd1 << ibuf_in.op_args.lsu.vcnt);
+
+    // Uop counter
+    reg [3:0] uop_idx;
+    reg busy;
+
+    always_ff @(posedge clk) begin
+        if (reset) begin
+            uop_idx <= '0;
+            busy    <= 1'b0;
+            done    <= 1'b0;
+        end else if (~busy && start) begin
+            uop_idx <= '0;
+            busy    <= 1'b1;
+            done    <= (uop_count == 4'd1);
+        end else if (busy && next) begin
+            uop_idx <= uop_idx + 4'd1;
+            done    <= (uop_idx == (uop_count - 4'd2));
+            busy    <= ~done;
+        end
+    end
+
+    // Stamp uop_idx into the low bits of uuid so each uop is uniquely traceable
+`ifdef UUID_ENABLE
+    localparam CTR_W = 4;
+    wire [UUID_WIDTH-1:0] uop_uuid = {ibuf_in.uuid[UUID_WIDTH-1:32],
+                                      {uop_idx, ibuf_in.uuid[0 +: (32-CTR_W)]}};
+`else
+    wire [UUID_WIDTH-1:0] uop_uuid = ibuf_in.uuid;
+`endif
+
+    // Preserve register type bits: only add uop_idx to the index field within RV_REGS_BITS
+    wire [NUM_REGS_BITS-1:0] rd  = ibuf_in.rd  + NUM_REGS_BITS'(uop_idx); // rd+idx for loads
+    wire [NUM_REGS_BITS-1:0] rs2 = ibuf_in.rs2 + NUM_REGS_BITS'(uop_idx); // rs2+idx  for stores
+
+    // Build the output uop: copy ibuf_in wholesale, then patch register and offset
+    ibuffer_t ibuf_r;
+
+    always_comb begin
+        ibuf_r = ibuf_in;
+        ibuf_r.uuid = uop_uuid;
+        if (is_store)
+            ibuf_r.rs2 = rs2;  // store: source register
+        else
+            ibuf_r.rd = rd;   // load: destination register
+        // Encode uop_idx in offset[3:0]; dispatcher multiplies by stride
+        ibuf_r.op_args.lsu.offset = {8'd0, uop_idx};
+    end
+
+    assign ibuf_out = ibuf_r;
+
+endmodule
