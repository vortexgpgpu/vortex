    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # rtlsim tests (NT=16)
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=uint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=bf16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # rtlsim tests (NT=32)
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=uint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DISSUE_WIDTH=2 -DITYPE=fp16 -DOTYPE=fp32 -DPROFILE_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=bf16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DTCU_TYPE_DPI -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    echo "tensor_sp tests done!"
}

tensor_mx() {

    echo "begin tensor tensor_mx tests..."

    make -C sw/kernel

    # simx tests
    # mxfp8 tests
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    # mxint8 tests
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    # nvfp4 tests
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    echo "tensor_mx tests done!"
}

tensor_wg() {

    echo "begin tensor tensor_wg tests..."

    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu

    make -C tests/regression/sgemm_tcu_sp clean && CONFIGS="-DNUM_THREADS=8 -DITYPE=fp16 -DOTYPE=fp32" make -C tests/regression/sgemm_tcu_sp
    make -C tests/regression/sgemm2_dxa clean && CONFIGS="-DNUM_THREADS=8 -DITYPE=fp16 -DOTYPE=fp32" make -C tests/regression/sgemm2_dxa

    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    CONFIGS="-DNUM_THREADS=8 -DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa
    CONFIGS="-DNUM_THREADS=8 -DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa

    # WGMMA dense tests — Latin-square coverage of {NT,NRC,Type,Driver}
    # All tests use NUM_WARPS=8, RS mode.
    # SimX:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=1 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg --args="-w 1"
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=2 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg --args="-w 2"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg --args="-w 4"
    # RTLsim:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg --args="-w 4"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg --args="-w 4"

    # WGMMA sparse tests — rotate NRC across NT/Driver
    # SimX:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=2 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp --args="-w 2"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp --args="-w 4"
    # RTLsim:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp --args="-w 4"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp --args="-w 4"

    # WGMMA+DXA dense tests — rotate NRC across NT/Type/Driver
    # SimX:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_dxa --args="-w 4"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=2 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_dxa --args="-w 2"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_dxa --args="-w 4"
    # RTLsim:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=2 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa --args="-w 2"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa --args="-w 4"

    # WGMMA+DXA sparse tests — rotate NRC across NT/Driver (fp16/fp32)
    # SimX:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp_dxa --args="-w 4"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=2 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp_dxa --args="-w 2"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp_dxa --args="-w 4"
    # RTLsim:
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp_dxa --args="-w 4"
    CONFIGS="-DNUM_THREADS=16 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp_dxa --args="-w 4"
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DTCU_SPARSE_ENABLE -DEXT_DXA_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp_dxa --args="-w 4"

    # Additional TCU coverage
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=32 -DEXT_TCU_ENABLE -DTCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DNUM_THREADS=32 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg --args="-w 4"

    echo "tensor tensor_wg tests done!"
}

cupbop() {

    echo "begin cupbop tests..."

    if [ "$XLEN" == "32" ]; then
        echo "cupbop tests skipped for 32-bit"
        return
    fi


    echo "downloading cupbop binaries..."
    CUPBOP_URL="https://www.dropbox.com/scl/fi/qxiofb0ejfxoog9m7tmae/cupbop.zip?rlkey=kcboy03c08xcn6yizd4nv8h88&st=7yuqftef&dl=1"

    wget -O cupbop.zip "${CUPBOP_URL}" || curl -L -o cupbop.zip "${CUPBOP_URL}"
    unzip -o cupbop.zip -d tests/
    rm cupbop.zip

    echo "building simx runtime..."
    make -C sw/runtime/simx

    PERF_CLASS=2
    VORTEX_RUNTIME_DIR="sw/runtime"
    CUPBOP_RUNTIME_DIR="tests/cupbop/runtime"

    tests=("bfs" "nn")
    tests_args=("./graph20.txt" "./filelist.txt -r 10 -lat 30 -lng 90")

    for i in "${!tests[@]}"; do
        test="${tests[$i]}"
        args="${tests_args[$i]}"
        echo "running test: $test"
        (
            cd "tests/cupbop/$test" || exit
            chmod +x "./host_${XLEN}.out"
            LD_LIBRARY_PATH="../../../${CUPBOP_RUNTIME_DIR}:../../../${VORTEX_RUNTIME_DIR}/simx:../../../${VORTEX_RUNTIME_DIR}:${LD_LIBRARY_PATH}" \
            ./host_${XLEN}.out ${args}
        )
    done

    echo "cupbop tests done!"
}

hip()
{
    # chipStar's hipcc emits SPIR-V with OpMemoryModel Physical64; POCL
    # refuses it on a 32-bit Vortex device with CL_INVALID_OPERATION.
    # Skip on rv32 -- documented in vortex-toolchain-prebuilt v3.0 README.
    if [ "$XLEN" == "32" ]; then
        echo "hip tests skipped for 32-bit (chipStar emits Physical64 SPIR-V; see v3.0 release notes)"
        return
    fi

    echo "begin hip tests..."

    make -C sw/runtime/simx
    make -C sw/runtime/rtlsim

    make -C tests/hip run-simx
    make -C tests/hip run-rtlsim

    echo "hip tests done!"
}

show_usage()
{
    echo "Vortex Regression Test"
    echo "Usage: $0 [--clean] [--unittest] [--runtime] [--riscv] [--kernel] [--regression] [--amo] [--dxa] [--opencl] [--cache] [--vm] [--rvc] [--config1] [--config2] [--debug] [--scope] [--stress] [--synthesis] [--vector] [--graphics] [--tensor] [--tensor_sp] [--tensor_mx] [--tensor_wg] [--cupbop] [--hip] [--sst] [--gem5] [--dtm] [--mpi] [--all] [--h|--help]"
}

declare -a tests=()
clean=0

while [ "$1" != "" ]; do
    case $1 in
        --clean )
                clean=1
                ;;
        --unittest )
                tests+=("unittest")
                ;;
        --runtime )
                tests+=("runtime")
                ;;
        --riscv )
                tests+=("riscv")
                ;;
        --kernel )
                tests+=("kernel")
                ;;
        --regression )
                tests+=("regression")
                ;;
        --amo )
                tests+=("amo")
                ;;
        --dxa )
                tests+=("dxa")
                ;;
        --graphics )
                tests+=("graphics")
                ;;
        --mpi )
                tests+=("mpi")
                ;;
        --dtm )
                tests+=("dtm")
                ;;
        --opencl )
                tests+=("opencl")
                ;;
        --cache )
                tests+=("cache")
                ;;
        --vm )
                tests+=("vm")
                ;;
        --rvc )
                tests+=("rvc")
                ;;
        --config1 )
                tests+=("config1")
                ;;
        --config2 )
                tests+=("config2")
                ;;
        --debug )
                tests+=("debug")
                ;;
        --scope )
                tests+=("scope")
                ;;
        --stress )
                tests+=("stress")
                ;;
        --synthesis )
                tests+=("synthesis")
                ;;
        --vector )
                tests+=("vector")
                ;;
        --tensor )
                tests+=("tensor")
                ;;
        --tensor_sp )
                tests+=("tensor_sp")
                ;;
        --tensor_mx )
                tests+=("tensor_mx")
                ;;
        --tensor_wg )
                tests+=("tensor_wg")
                ;;
        --cupbop )
                tests+=("cupbop")
                ;;
        --hip )
                tests+=("hip")
                ;;
        --sst )
                tests+=("sst")
                ;;
        --gem5 )
                tests+=("gem5")
                ;;
        --dtm )
                tests+=("dtm")
                ;;
        --all )
                tests=()
                tests+=("unittest")
                tests+=("runtime")
                tests+=("riscv")
                tests+=("kernel")
                tests+=("regression")
                tests+=("amo")
                tests+=("dxa")
                tests+=("graphics")
                tests+=("mpi")
                tests+=("opencl")
                tests+=("cache")
                tests+=("vm")
                tests+=("rvc")
                tests+=("config1")
                tests+=("config2")
                tests+=("debug")
                tests+=("scope")
                tests+=("stress")
                tests+=("synthesis")
                tests+=("tensor")
                tests+=("tensor_sp")
                tests+=("tensor_mx")
                tests+=("tensor_wg")
                tests+=("cupbop")
                tests+=("hip")
                tests+=("dtm")
                ;;
        -h | --help )
                show_usage
                exit
                ;;
        * )
                show_usage
                exit 1
    esac
    shift
done

if [ $clean -eq 1 ];
then
    make clean
    make -s
fi

start=$SECONDS

for test in "${tests[@]}"; do
    $test
done

echo "Regression completed!"

duration=$(( SECONDS - start ))
awk -v t=$duration 'BEGIN{t=int(t*1000); printf "Elapsed Time: %d:%02d:%02d\n", t/3600000, t/60000%60, t/1000%60}'
