# exit when any command fails
set -e

# clear blackbox cache
rm -f blackbox.*.cache

# HW: add a test "VM Test" to make sure VM feature is enabled

XLEN=${XLEN:=@XLEN@}

XSIZE=$((XLEN / 8))

echo "Vortex Regression Test: XLEN=$XLEN"

unittest()
{
    make -C tests/unittest run
    make -C hw/unittest > /dev/null
}

runtime()
{
    echo "begin runtime tests..."

    # vortex2.h runtime API integration tests (tests/runtime/). Unlike
    # tests/unittest these dlopen a backend and spin up the simulator, so
    # they need the dispatcher + simx backend built. test_module_kernel
    # also needs a kernel image — reuse the `basic` regression .vxbin.
    make -C sw/kernel
    make -C sw/runtime/stub
    make -C sw/runtime/simx
    make -C tests/regression/basic kernel.vxbin

    make -C tests/runtime run-simx

    echo "runtime tests done!"
}

riscv()
{
    echo "begin riscv tests..."

    make -C sim/simx
    make -C sim/rtlsim

    make -C tests/riscv run-simx
    make -C tests/riscv run-rtlsim

    CONFIGS="-DFPU_TYPE_STD" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DFPU_TYPE_FPNEW" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DFPU_TYPE_DPI" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DFPU_TYPE_DSP" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f

    if [ "$XLEN" == "64" ]
    then
        CONFIGS="-DFPU_TYPE_FPNEW" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64d
        CONFIGS="-DFPU_TYPE_DPI" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64d
        CONFIGS="-DFPU_TYPE_STD -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
        CONFIGS="-DFPU_TYPE_DPI -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
        CONFIGS="-DFPU_TYPE_DSP -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
    fi

    echo "riscv tests done!"
}

kernel()
{
    echo "begin kernel tests..."

    make -C sw/kernel
    make -C sim/simx
    make -C sim/rtlsim

    make -C tests/kernel run-simx
    make -C tests/kernel run-rtlsim

    echo "kernel tests done!"
}

dtm()
{
    echo "begin dtm tests..."

    make -C sim/simx
    make -C tests/kernel

    DTM_XLEN=@XLEN@ python3 ci/dtm_test.py

    echo "dtm tests done!"
}

sst()
{
    echo "begin sst tests..."

    make -C sim/simx USE_SST=1
    make -C tests/kernel

    cp sim/simx/libvortex.so $SST_ELEMENTS_HOME/lib/sst-elements-library/   # alternatively - $ sst --add-lib-path `pwd` myConfig.py

    BUILD_DIR=$(pwd)

    # Hostless SST runner (ci/sst_run_hostless_app.py) parameterized
    # by VORTEX_TEST_DIR + VORTEX_TEST_KERNEL — same shape as
    # ci/gem5_run_hostless_app.py. SST is hostless-only today (no
    # CPU component wired to Vortex); the ci/sst_run_app.py name
    # slot is reserved for a future host-CPU SST integration.
    for spec in "hello:hello.vxbin" "fibonacci:fibonacci.vxbin" \
                "vecadd:vecadd.vxbin" "conform:conform.vxbin"; do
        kern="${spec%%:*}"
        vxbin="${spec#*:}"
        echo "=== sst: $kern ==="
        VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/$kern \
        VORTEX_TEST_KERNEL=$vxbin \
            sst ci/sst_run_hostless_app.py
    done

    echo "sst tests done!"
}

# gem5 integration tests — see docs/proposals/gem5_v2_cp_migration_proposal.md
# for the v2 CP-first design and docs/gem5_integration.md for the operator
# manual. Two layers:
#
#   1. Phase 3 standalone: kernel preloaded via the SimObject's
#      `kernel=` Python param; runs entirely inside the gem5 event
#      loop, no host CPU needed. Fast smoke test for the device
#      library wiring.
#
#   2. Phase 5 e2e: an x86 (or aarch64) SE-mode workload drives the
#      device via the CP regfile (cp_mmio_*) + BAR-mapped VRAM
#      (mem_upload through identity-mapped PIN region). The
#      dispatcher's CP submission path handles all command building;
#      the host runtime is a thin platform shim.
#
# ARM matrix is opt-in via VORTEX_GEM5_ARM=1 (needs gcc-aarch64-linux-gnu
# installed; not part of the default hosted-runner image).
gem5()
{
    echo "begin gem5 tests..."

    if [ -z "$GEM5_HOME" ]; then
        GEM5_HOME=$HOME/tools/gem5
    fi
    if [ ! -x "$GEM5_HOME/build/X86/gem5.opt" ]; then
        echo "error: $GEM5_HOME/build/X86/gem5.opt not found — run ci/gem5_install.sh first"
        exit 1
    fi

    # Build prerequisites. The host runtime is gated on HOST_ARCH;
    # default x86 needs no cross-toolchain.
    make -C sim/simx USE_GEM5=1
    make -C sw/runtime/stub
    make -C sw/runtime/gem5 HOST_ARCH=x86_64
    make -C sw/kernel
    make -C tests/kernel/hello
    make -C tests/regression/vecadd
    make -C tests/regression/sgemm

    BUILD_DIR=$(pwd)
    LIB_GEM5_DEV=$BUILD_DIR/sim/simx/libvortex-gem5.so
    HOST_RT_DIR=$BUILD_DIR/sw/runtime

    # Hostless smoke — no host CPU, kernel preloaded via SimObject param.
    # env-vars MUST precede the binary (gem5.opt would otherwise treat
    # them as positional args).
    echo "=== gem5 hostless: hello ==="
    VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
    VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/hello \
    VORTEX_TEST_KERNEL=hello.vxbin \
        timeout 120 $GEM5_HOME/build/X86/gem5.opt \
        ci/gem5_run_hostless_app.py

    # E2E — CP-driven path through the host runtime. Generic runner
    # (ci/gem5_run_app.py) parameterized by VORTEX_TEST_BIN +
    # VORTEX_TEST_ARGS. Sizes fit the 120s per-test budget
    # (feedback_test_timeout_120s):
    #   - vecadd -n16   small vector add
    #   - sgemm  -n4    4x4 matrix multiply
    # Larger sizes overrun because the simulated host CPU's CP poll
    # loop burns gem5 wall time proportional to kernel runtime.
    # Run on local dev box for larger sizes by overriding VORTEX_TEST_ARGS.
    for spec in "vecadd:-n16" "sgemm:-n4"; do
        app="${spec%%:*}"
        args="${spec#*:}"
        echo "=== gem5 e2e: $app $args ==="
        VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
        VORTEX_GEM5_HOST_RT_DIR=$HOST_RT_DIR \
        VORTEX_TEST_DIR=$BUILD_DIR/tests/regression/$app \
        VORTEX_TEST_BIN=$app \
        VORTEX_TEST_ARGS=$args \
            timeout 120 $GEM5_HOME/build/X86/gem5.opt \
            ci/gem5_run_app.py
    done

    # ARM matrix (opt-in). The device library (libvortex-gem5.so) is
    # always x86 — gem5.opt is an x86 binary regardless of which
    # simulated ISA it models. Only the simulated host's ISA changes.
    if [ -n "$VORTEX_GEM5_ARM" ]; then
        if [ ! -x "$GEM5_HOME/build/ARM/gem5.opt" ]; then
            echo "error: $GEM5_HOME/build/ARM/gem5.opt not found"
            exit 1
        fi

        # Cross-compile the host runtime, stub, and test binaries for
        # aarch64. All outputs land in $arch/ subdirs alongside the
        # native x86 builds so they coexist cleanly.
        make -C sw/runtime/stub HOST_ARCH=aarch64
        make -C sw/runtime/gem5 HOST_ARCH=aarch64
        make -C tests/regression/vecadd HOST_ARCH=aarch64
        make -C tests/regression/sgemm  HOST_ARCH=aarch64

        ARM_HOST_RT_DIR=$BUILD_DIR/sw/runtime/aarch64

        echo "=== gem5 ARM hostless: hello ==="
        VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
        VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/hello \
        VORTEX_TEST_KERNEL=hello.vxbin \
            timeout 120 $GEM5_HOME/build/ARM/gem5.opt \
            ci/gem5_run_hostless_app.py

        for spec in "vecadd:-n16" "sgemm:-n4"; do
            app="${spec%%:*}"
            args="${spec#*:}"
            echo "=== gem5 ARM e2e: $app $args ==="
            VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
            VORTEX_GEM5_HOST_RT_DIR=$ARM_HOST_RT_DIR \
            VORTEX_TEST_DIR=$BUILD_DIR/tests/regression/$app \
            VORTEX_TEST_BIN=$app-aarch64 \
            VORTEX_TEST_ARGS=$args \
            VORTEX_DRIVER=gem5-aarch64 \
                timeout 120 $GEM5_HOME/build/ARM/gem5.opt \
                ci/gem5_run_app.py
        done
    fi

    echo "gem5 tests done!"
}

mpi()
{
    echo "begin mpi tests..."

    make -C sw/runtime/simx

    make -C tests/regression/mpi_dotproduct          run-simx MPI=1 NP=4
    make -C tests/regression/mpi_put_dotproduct      run-simx MPI=1 NP=4
    make -C tests/regression/mpi_diverge             run-simx MPI=1 NP=4
    make -C tests/regression/mpi_vecadd              run-simx MPI=1 NP=4
    make -C tests/regression/mpi_sgemm               run-simx MPI=1 NP=4
    make -C tests/regression/mpi_blocked_sgemm       run-simx MPI=1 NP=4
    make -C tests/regression/mpi_conv3               run-simx MPI=1 NP=4
    make -C tests/regression/mpi_neighbor_a2a_conv3  run-simx MPI=1 NP=4

    echo "mpi tests done!"
}

regression()
{
    echo "begin regression tests..."

    make -C sw/kernel
    make -C sw/runtime/stub
    make -C sw/runtime/simx
    make -C sw/runtime/rtlsim

    make -C tests/regression run-simx
    make -C tests/regression run-rtlsim

    # test kernel occupancy
    ./ci/blackbox.sh --driver=simx   --app=occupancy --threads=32
    ./ci/blackbox.sh --driver=rtlsim --app=occupancy --threads=32
    ./ci/blackbox.sh --driver=simx   --app=occupancy --threads=32 --cores=4
    ./ci/blackbox.sh --driver=rtlsim --app=occupancy --threads=32 --cores=4

    # test global barrier
    ./ci/blackbox.sh --driver=simx --app=dogfood --args="-n1 -tgbar" --cores=2
    ./ci/blackbox.sh --driver=opae --app=dogfood --args="-n1 -tgbar" --cores=2
    ./ci/blackbox.sh --driver=xrt --app=dogfood --args="-n1 -tgbar" --cores=2

    # test local barrier
    ./ci/blackbox.sh --driver=simx --app=dogfood --args="-n1 -tbar"
    ./ci/blackbox.sh --driver=opae --app=dogfood --args="-n1 -tbar"
    ./ci/blackbox.sh --driver=xrt --app=dogfood --args="-n1 -tbar"

    # test temp driver mode for
    ./ci/blackbox.sh --driver=simx --app=vecadd --nohup

    echo "regression tests done!"
}

amo()
{
    echo "begin amo tests..."

    CONFIGS="-DEXT_A_ENABLE" make -C sim/simx
    CONFIGS="-DEXT_A_ENABLE" make -C sim/rtlsim

    make -C sw/kernel
    make -C sw/runtime/simx
    make -C sw/runtime/rtlsim

    # RISC-V 'A' ISA conformance (rv${XLEN}ua-p-{amo*,lrsc}).
    CONFIGS="-DEXT_A_ENABLE" make -C tests/riscv/isa run-simx-${XLEN}a
    CONFIGS="-DEXT_A_ENABLE" make -C tests/riscv/isa run-rtlsim-${XLEN}a

    # Single-core L1 = LLC. Default config (4 warps × 4 threads = 16 harts).
    CONFIGS="-DEXT_A_ENABLE" ./ci/blackbox.sh --driver=simx   --app=amo
    CONFIGS="-DEXT_A_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DEXT_A_ENABLE -DDCACHE_WRITEBACK=1 -DDCACHE_DIRTYBYTES=0 -DDCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DEXT_A_ENABLE -DDCACHE_WRITEBACK=1 -DDCACHE_DIRTYBYTES=1 -DDCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DEXT_A_ENABLE -DDCACHE_WRITEBACK=1 -DDCACHE_NUM_WAYS=4"                       ./ci/blackbox.sh --driver=simx   --app=amo
    CONFIGS="-DEXT_A_ENABLE" ./ci/blackbox.sh --driver=simx   --threads=8 --args=-n1 --app=amo
    CONFIGS="-DEXT_A_ENABLE" ./ci/blackbox.sh --driver=rtlsim --threads=8 --args=-n1 --app=amo

    echo "amo tests done!"
}

dxa()
{
    echo "begin dxa tests..."

    make -C sw/kernel
    make -C sw/runtime/simx
    make -C sw/runtime/rtlsim

    # dxa_copy 1D-5D
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d1" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d2" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d3" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d4" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d5" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d1" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d2" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d3" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d4" --debug=3
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d5" --debug=3

    # dxa_multicast: disabled — multicast path not yet supported
    # CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_multicast --debug=3
    # CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_multicast --debug=3

    CONFIGS="-DEXT_DXA_ENABLE -DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --threads=8
    CONFIGS="-DEXT_DXA_ENABLE -DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --threads=8

    CONFIGS="-DEXT_DXA_ENABLE -DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --threads=32 --perf=6
    CONFIGS="-DEXT_DXA_ENABLE -DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --threads=32 --perf=6

    # single-core without L2 cache
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa
    CONFIGS="-DEXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa

    # single-core with L2 cache
    CONFIGS="-DEXT_DXA_ENABLE -DL2_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa
    CONFIGS="-DEXT_DXA_ENABLE -DL2_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa

    # multi-core without L2 cache
    CONFIGS="-DEXT_DXA_ENABLE -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2
    CONFIGS="-DEXT_DXA_ENABLE -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2

    # multi-core with L2 cache
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2

    # multi-core with 2 sockets
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSOCKET_SIZE=2 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=4
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSOCKET_SIZE=2 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=4

    # multi-core with 2 clusters
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2 --clusters=2
    CONFIGS="-DEXT_DXA_ENABLE -DNUM_DXA_UNITS=4 -DSTALL_TIMEOUT=1000000" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2 --clusters=2

    echo "dxa tests done!"
}

graphics()
{
    echo "begin graphics tests..."

    make -C sw/kernel
    make -C sw/runtime/rtlsim

    # ---- full PNG-driven tests (with reference image diff) --------------
    # tex: 64x64 palette texture, point-filter, scale=1.0
    CONFIGS="-DEXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=tex \
        --args="-i palette64.png -r palette64_ref_g0.png"

    # om: 32x32 white-box gradient render
    CONFIGS="-DEXT_OM_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=om \
        --args="-w 32 -h 32 -c 16777215 -r whitebox_32.png"

    # raster: 32x32 single triangle from cgltrace
    CONFIGS="-DEXT_RASTER_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=raster \
        --args="-w 32 -h 32 -t triangle.cgltrace -r triangle_ref_32.png"

    # draw3d: full-pipeline (TEX+RASTER+OM) build-and-run smoke. Functional
    # output is gated on raster bcoord/pos_mask CSR plumbing (deferred);
    # this verifies the v2 KMU launch path and kernel binary build.
    CONFIGS="-DEXT_TEX_ENABLE -DEXT_RASTER_ENABLE -DEXT_OM_ENABLE" \
        ./ci/blackbox.sh --driver=rtlsim --app=draw3d \
        --args="-w 32 -h 32 -t triangle.cgltrace -o /tmp/draw3d_out.png"

    # NOTE: draw3d (full-pipeline test) is gated on raster bcoord/pos_mask
    # CSR plumbing which is deferred. SimX support is gated on simx_v3
    # Phase 5 — graphics ops abort on --driver=simx until the SimX
    # functional model lands.

    echo "graphics tests done!"
}

opencl()
{
    echo "begin opencl tests..."

    make -C sw/kernel
    make -C sw/runtime/stub
    make -C sw/runtime/simx
    make -C sw/runtime/rtlsim

    make -C tests/opencl run-simx
    make -C tests/opencl run-rtlsim

    ./ci/blackbox.sh --driver=simx --app=lbm --warps=8
    ./ci/blackbox.sh --driver=rtlsim --app=lbm --warps=8

    echo "opencl tests done!"
}

rvc()
{
    echo "begin rvc tests..."

    # Rebuild kernel + simulators with the C extension enabled.
    make -C sw/kernel clean && CONFIGS="-DEXT_C_ENABLE" make -C sw/kernel
    make -C sim/simx clean && CONFIGS="-DEXT_C_ENABLE" make -C sim/simx
    make -C sim/rtlsim clean && CONFIGS="-DEXT_C_ENABLE" make -C sim/rtlsim

    # ISA conformance for rv*uc-p-* (compressed instruction tests).
    make -C tests/riscv/isa run-simx-32c
    make -C tests/riscv/isa run-rtlsim-32c

    if [ "$XLEN" == "64" ]
    then
        make -C tests/riscv/isa run-simx-64c
        make -C tests/riscv/isa run-rtlsim-64c
    fi

    make -C sw/runtime/simx clean && CONFIGS="-DEXT_C_ENABLE" make -C sw/runtime/simx
    make -C sw/runtime/rtlsim clean && CONFIGS="-DEXT_C_ENABLE" make -C sw/runtime/rtlsim
    make -C tests/regression/sgemm run-simx
    make -C tests/regression/sgemm run-rtlsim
    make -C tests/regression/diverge run-simx
    make -C tests/regression/diverge run-rtlsim
    make -C tests/regression/dogfood run-simx
    make -C tests/regression/dogfood run-rtlsim
    make -C tests/regression/raycast run-simx
    make -C tests/regression/raycast run-rtlsim

    echo "rvc tests done!"
}

vm(){
    echo "begin vm tests..."

    make -C sw/kernel

    # Pass 1: default VM mode (SV32 on rv32, SV39 on rv64). VM_ENABLE must
    # reach the stub (VMManager bodies are #ifdef VM_ENABLE), both sim
    # drivers, AND each test invocation (test app rebuilds its own
    # vx_start.S which gates `csrw satp` on VM_ENABLE).
    CONFIGS="-DVM_ENABLE" make -C sw/runtime/stub clean && CONFIGS="-DVM_ENABLE" make -C sw/runtime/stub
    CONFIGS="-DVM_ENABLE" make -C sw/runtime/simx clean && CONFIGS="-DVM_ENABLE" make -C sw/runtime/simx
    CONFIGS="-DVM_ENABLE" make -C sw/runtime/rtlsim clean && CONFIGS="-DVM_ENABLE" make -C sw/runtime/rtlsim
    CONFIGS="-DVM_ENABLE" make -C tests/regression/sgemm run-simx
    CONFIGS="-DVM_ENABLE" make -C tests/regression/sgemm run-xrt
    CONFIGS="-DVM_ENABLE" make -C tests/regression/diverge run-simx
    CONFIGS="-DVM_ENABLE" make -C tests/regression/diverge run-xrt
    CONFIGS="-DVM_ENABLE" make -C tests/regression/dogfood run-simx
    CONFIGS="-DVM_ENABLE" make -C tests/regression/dogfood run-rtlsim
    CONFIGS="-DVM_ENABLE" make -C tests/regression/raycast run-simx
    CONFIGS="-DVM_ENABLE" make -C tests/regression/raycast run-rtlsim
    CONFIGS="-DVM_ENABLE" make -C tests/regression/draw3d run-simx
    CONFIGS="-DVM_ENABLE" make -C tests/regression/draw3d run-xrt

    # Pass 2: BARE mode (identity translation only, no PTW). Same propagation.
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/stub clean && CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/stub
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/simx clean && CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/rtlsim clean && CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C sw/runtime/rtlsim
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/sgemm run-simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/sgemm run-xrt
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/diverge run-simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/diverge run-xrt
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/dogfood run-simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/dogfood run-rtlsim
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/raycast run-simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/raycast run-rtlsim
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/draw3d run-simx
    CONFIGS="-DVM_ENABLE -DVM_ADDR_MODE=BARE" make -C tests/regression/draw3d run-xrt

    echo "vm tests done!"
}

cache()
{
    echo "begin cache tests..."

    make -C sw/kernel

    # disable local memory
    CONFIGS="-DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=demo --perf=1
    CONFIGS="-DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx --app=demo --perf=1

    # disable L1 cache
    CONFIGS="-DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_DISABLE -DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm

    # reduce l1 line size
    CONFIGS="-DL1_LINE_SIZE=$XSIZE" ./ci/blackbox.sh --driver=rtlsim --app=io_addr
    CONFIGS="-DL1_LINE_SIZE=$XSIZE -DICACHE_DISABLE -DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=io_addr
    CONFIGS="-DL1_LINE_SIZE=$XSIZE" ./ci/blackbox.sh --driver=simx --app=io_addr
    CONFIGS="-DL1_LINE_SIZE=$XSIZE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DL1_LINE_SIZE=$XSIZE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test cache ways
    CONFIGS="-DICACHE_NUM_WAYS=1 -DDCACHE_NUM_WAYS=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_NUM_WAYS=4 -DDCACHE_NUM_WAYS=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_NUM_WAYS=4 -DDCACHE_NUM_WAYS=8" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test cache banking
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DLMEM_NUM_BANKS=4 -DDCACHE_NUM_BANKS=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DLMEM_NUM_BANKS=4 -DDCACHE_NUM_BANKS=1" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DLMEM_NUM_BANKS=2 -DDCACHE_NUM_BANKS=4" ./ci/blackbox.sh --driver=rtlsim --app=sgemm --threads=8
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DLMEM_NUM_BANKS=2 -DDCACHE_NUM_BANKS=4" ./ci/blackbox.sh --driver=simx --app=sgemm --threads=8

    # replacement policy
    CONFIGS="-DDCACHE_REPL_POLICY=0" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DDCACHE_REPL_POLICY=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DDCACHE_REPL_POLICY=2" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DDCACHE_REPL_POLICY=0" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DDCACHE_REPL_POLICY=1" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DDCACHE_REPL_POLICY=2" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test writeback
    CONFIGS="-DDCACHE_WRITEBACK=1 -DDCACHE_DIRTYBYTES=0 -DDCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DDCACHE_WRITEBACK=1 -DDCACHE_DIRTYBYTES=1 -DDCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DDCACHE_WRITEBACK=1 -DDCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=simx --app=mstress
    CONFIGS="-DSOCKET_SIZE=1 -DL2_WRITEBACK=1 -DL3_WRITEBACK=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --l2cache --l3cache --app=mstress
    CONFIGS="-DSOCKET_SIZE=1 -DL2_WRITEBACK=1 -DL3_WRITEBACK=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --l3cache --app=mstress

    # cache clustering
    CONFIGS="-DSOCKET_SIZE=4 -DNUM_DCACHES=4 -DNUM_ICACHES=2" ./ci/blackbox.sh --driver=rtlsim --app=sgemm --cores=4 --warps=1 --threads=2

    # L2/L3
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=4 --l2cache --app=diverge --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=4 --l2cache --app=diverge --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --l2cache --l3cache --app=diverge --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --l3cache --app=diverge --args="-n1"

    echo "begin cache tests..."
}

config1()
{
    echo "begin configuration-1 tests..."

    make -C sw/kernel

    # warp/threads
    ./ci/blackbox.sh --driver=rtlsim --warps=1 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=1 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=8 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=8 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=simx --warps=1 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=simx --warps=2 --threads=16 --app=diverge

    # 2D block dim (block_dim.x < NUM_LANES triggers CTA thread-ID decomposition)
    ./ci/blackbox.sh --driver=simx --threads=8 --app=demo --args="-x1 -y4"
    ./ci/blackbox.sh --driver=simx --threads=8 --app=demo --args="-x2 -y4"
    ./ci/blackbox.sh --driver=rtlsim --threads=8 --app=demo --args="-x1 -y4"
    ./ci/blackbox.sh --driver=rtlsim --threads=8 --app=demo --args="-x2 -y4"

    # cores clustering
    ./ci/blackbox.sh --driver=rtlsim --cores=4 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=simx --cores=4 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --app=diverge --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --app=diverge --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --app=diverge --args="-n1"

    # issue width
    CONFIGS="-DISSUE_WIDTH=2" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DISSUE_WIDTH=4" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DISSUE_WIDTH=2" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DISSUE_WIDTH=4" ./ci/blackbox.sh --driver=simx --app=diverge

    # simd width
    CONFIGS="-DSIMD_WIDTH=1" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-ttrig"
    CONFIGS="-DSIMD_WIDTH=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-ttrig"
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=32 --app=sgemm
    CONFIGS="-DSIMD_WIDTH=32" ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=32 --app=sgemm
    CONFIGS="-DSIMD_WIDTH=1" ./ci/blackbox.sh --driver=simx --app=dogfood --args="-ttrig"
    CONFIGS="-DSIMD_WIDTH=2" ./ci/blackbox.sh --driver=simx --app=dogfood --args="-ttrig"

    # ALU scaling
    CONFIGS="-DISSUE_WIDTH=1 -DNUM_ALU_BLOCK=1 -DNUM_ALU_LANES=1" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_ALU_BLOCK=2 -DNUM_ALU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_ALU_BLOCK=4 -DNUM_ALU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DISSUE_WIDTH=1 -DNUM_ALU_BLOCK=1 -DNUM_ALU_LANES=1" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_ALU_BLOCK=2 -DNUM_ALU_LANES=2" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_ALU_BLOCK=4 -DNUM_ALU_LANES=4" ./ci/blackbox.sh --driver=simx --app=diverge

    # FPU scaling
    CONFIGS="-DISSUE_WIDTH=2 -DNUM_FPU_BLOCK=1 -DNUM_FPU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_FPU_BLOCK=4 -DNUM_FPU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=2 -DNUM_FPU_BLOCK=1 -DNUM_FPU_LANES=2" ./ci/blackbox.sh --driver=simx --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_FPU_BLOCK=4 -DNUM_FPU_LANES=4" ./ci/blackbox.sh --driver=simx --app=regression/vecadd

    # FPU's PE scaling
    CONFIGS="-DFMA_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfmadd"
    CONFIGS="-DFCVT_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tftoi"
    CONFIGS="-DFDIV_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfdiv"
    CONFIGS="-DFSQRT_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfsqrt"
    CONFIGS="-DFNCP_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfclamp"

    # LSU scaling
    CONFIGS="-DISSUE_WIDTH=2 -DNUM_LSU_BLOCK=1 -DNUM_LSU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_LSU_BLOCK=4 -DNUM_LSU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=2 -DNUM_LSU_BLOCK=1 -DNUM_LSU_LANES=2" ./ci/blackbox.sh --driver=simx --app=regression/vecadd
    CONFIGS="-DISSUE_WIDTH=4 -DNUM_LSU_BLOCK=4 -DNUM_LSU_LANES=4" ./ci/blackbox.sh --driver=simx --app=regression/vecadd

    echo "configuration-1 tests done!"
}

config2()
{
    echo "begin configuration-2 tests..."

    make -C sw/kernel

    # test opaesim
    ./ci/blackbox.sh --driver=opae --app=printf
    ./ci/blackbox.sh --driver=opae --app=diverge
    ./ci/blackbox.sh --driver=xrt --app=diverge

    # disable DPI
    if [ "$XLEN" == "64" ]; then
        # need to disable trig on 64-bit due to a bug inside fpnew's sqrt core.
        # TODO: disabled due to ASSERT macro collision with fpNew
        #CONFIGS="-DFPU_TYPE_FPNEW" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-xtrig -xbar -xgbar"
        #CONFIGS="-DFPU_TYPE_FPNEW" ./ci/blackbox.sh --driver=opae --app=dogfood --args="-xtrig -xbar -xgbar"
        #CONFIGS="-DFPU_TYPE_FPNEW" ./ci/blackbox.sh --driver=xrt --app=dogfood --args="-xtrig -xbar -xgbar"
        :
    else
        CONFIGS="-DFPU_TYPE_STD" ./ci/blackbox.sh --driver=rtlsim --app=dogfood
        CONFIGS="-DFPU_TYPE_STD" ./ci/blackbox.sh --driver=opae --app=dogfood
        CONFIGS="-DFPU_TYPE_STD" ./ci/blackbox.sh --driver=xrt --app=dogfood
    fi

    # custom program startup address
    make -C tests/regression/dogfood clean-kernel
    STARTUP_ADDR=0x80000000 make -C tests/regression/dogfood
    ./ci/blackbox.sh --driver=simx --app=dogfood
    ./ci/blackbox.sh --driver=rtlsim --app=dogfood
    make -C tests/regression/dogfood clean-kernel

    # disabling M & F extensions
    CONFIGS="-DEXT_M_DISABLE -DEXT_F_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32i

    # disabling ZICOND extension
    CONFIGS="-DEXT_ZICOND_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=demo

    # test 128-bit memory block
    CONFIGS="-DMEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=opae --app=mstress
    CONFIGS="-DMEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=xrt --app=mstress

    # test XLEN-bit memory block
    CONFIGS="-DMEM_BLOCK_SIZE=$XSIZE" ./ci/blackbox.sh --driver=opae --app=mstress
    CONFIGS="-DMEM_BLOCK_SIZE=$XSIZE" ./ci/blackbox.sh --driver=simx --app=mstress

    # test memory coalescing
    CONFIGS="-DMEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=rtlsim --app=mstress --threads=8
    CONFIGS="-DMEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=simx --app=mstress --threads=8

    # test single-bank memory
    if [ "$XLEN" == "64" ]; then
        CONFIGS="-DPLATFORM_MEMORY_NUM_BANKS=1" ./ci/blackbox.sh --driver=opae --app=mstress
        CONFIGS="-DPLATFORM_MEMORY_NUM_BANKS=1" ./ci/blackbox.sh --driver=xrt --app=mstress
    else
        CONFIGS="-DPLATFORM_MEMORY_NUM_BANKS=1" ./ci/blackbox.sh --driver=opae --app=mstress
        CONFIGS="-DPLATFORM_MEMORY_NUM_BANKS=1" ./ci/blackbox.sh --driver=xrt --app=mstress
    fi

    # test larger memory address
    if [ "$XLEN" == "64" ]; then
        CONFIGS="-DPLATFORM_MEMORY_ADDR_WIDTH=49" ./ci/blackbox.sh --driver=opae --app=mstress
        CONFIGS="-DPLATFORM_MEMORY_ADDR_WIDTH=49" ./ci/blackbox.sh --driver=xrt --app=mstress
    else
        CONFIGS="-DPLATFORM_MEMORY_ADDR_WIDTH=33" ./ci/blackbox.sh --driver=opae --app=mstress
        CONFIGS="-DPLATFORM_MEMORY_ADDR_WIDTH=33" ./ci/blackbox.sh --driver=xrt --app=mstress
    fi

    # test memory banks interleaving
    CONFIGS="-DPLATFORM_MEMORY_INTERLEAVE=1" ./ci/blackbox.sh --driver=opae --app=mstress
    CONFIGS="-DPLATFORM_MEMORY_INTERLEAVE=0" ./ci/blackbox.sh --driver=opae --app=mstress

    # test memory ports
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DPLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=simx --app=mstress
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DPLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=simx --app=mstress --threads=8
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DPLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DMEM_BLOCK_SIZE=8 -DPLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=rtlsim --app=mstress --threads=8
    CONFIGS="-DMEM_BLOCK_SIZE=8" ./ci/blackbox.sh --driver=opae --app=mstress --threads=8
    CONFIGS="-DMEM_BLOCK_SIZE=8" ./ci/blackbox.sh --driver=xrt --app=mstress --threads=8

    echo "configuration-2 tests done!"
}

test_csv_trace32()
{
    # test CSV trace generation
    DEBUG=3 make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DGPR_RESET" make -C sim/rtlsim > /dev/null
    make -C tests/riscv/isa run-simx-32imf > run_simx.log
    make -C tests/riscv/isa run-rtlsim-32imf > run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    diff trace_rtlsim.csv trace_simx.csv

    # test CSV trace generation for TCU (single warp to avoid CTA scheduling divergence)
    CONFIGS="-DEXT_TCU_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --warps=1 --debug=3 --log=run_simx.log
    CONFIGS="-DEXT_TCU_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --warps=1 --debug=3 --log=run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    diff trace_rtlsim.csv trace_simx.csv

    # test CSV trace generation for DXA (compare instruction counts due to CTA dispatch ordering differences)
    CONFIGS="-DEXT_DXA_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --warps=1 --args="-t 2 -n 4" --debug=3 --log=run_simx.log
    CONFIGS="-DEXT_DXA_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --warps=1 --args="-t 2 -n 4" --debug=3 --log=run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    diff trace_rtlsim.csv trace_simx.csv
}

test_csv_trace64()
{
    # test CSV trace generation
    DEBUG=3 make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DGPR_RESET" make -C sim/rtlsim > /dev/null
    make -C tests/riscv/isa run-simx-64imf > run_simx.log
    make -C tests/riscv/isa run-rtlsim-64imf > run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    diff trace_rtlsim.csv trace_simx.csv
}

debug()
{
    echo "begin debugging tests..."

    make -C sw/kernel

    test_csv_trace32

    if [ "$XLEN" == "64" ]
    then
        test_csv_trace64
    fi

    CONFIGS="-O0" ./ci/blackbox.sh --driver=opae --app=demo --args="-n1"
    CONFIGS="-O0" ./ci/blackbox.sh --driver=xrt --app=demo --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=opae --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=xrt --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"
    CONFIGS="-DSOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"

    # test perfetto trace generation
    DEBUG=3 CONFIGS="-DEXT_TCU_ENABLE" make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DEXT_TCU_ENABLE -DGPR_RESET" make -C sim/rtlsim > /dev/null
    DEBUG=3 CONFIGS="-DEXT_TCU_ENABLE" make -C sw/runtime/simx > /dev/null
    CONFIGS="-DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --debug=3 --log=run_simx.log
    ./ci/perfetto.py run_simx.log -t simx -o trace_simx.perfetto.json
    CONFIGS="-DEXT_TCU_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --debug=3 --log=run_rtlsim.log
    ./ci/perfetto.py run_rtlsim.log -t rtlsim -o trace_rtlsim.perfetto.json

    echo "debugging tests done!"
}

scope()
{
    echo "begin scope tests..."

    make -C sw/kernel

    SCOPE_DEPTH=128 ./ci/blackbox.sh --driver=opae --app=demo --args="-n1" --scope
    SCOPE_DEPTH=128 ./ci/blackbox.sh --driver=xrt --app=demo --args="-n1" --scope

    echo "debugging scope done!"
}

stress()
{
    echo "begin stress tests..."

    make -C sw/kernel

    # test verilator reset values
    CONFIGS="-DVERILATOR_RESET_VALUE=1 -DSOCKET_SIZE=1 -DDCACHE_WRITEBACK=1 -DL2_WRITEBACK=1 -DL3_WRITEBACK=1" ./ci/blackbox.sh --driver=opae --cores=2 --clusters=2 --l2cache --l3cache --app=dogfood
    CONFIGS="-DVERILATOR_RESET_VALUE=1" ./ci/blackbox.sh --driver=xrt --app=sgemm --args="-n128" --l2cache

    echo "stress tests done!"
}

synthesis()
{
    echo "begin synthesis tests..."

    make -C hw/syn/yosys

    # synthesis with TCU + TF32 + sparse + WGMMA + DXA
    CONFIGS="-DEXT_TCU_ENABLE -DTCU_TYPE_TFR -DTCU_SPARSE_ENABLE -DTCU_WGMMA_ENABLE -DEXT_DXA_ENABLE" make -C hw/syn/yosys

    echo "synthesis tests done!"
}

vector()
{
    echo "begin vector tests..."

    CONFIGS="-DVLEN=256 -DEXT_V_ENABLE" make -C sim/simx
    VLEN=256 ./tests/riscv/riscv-vector-tests/run-test.sh

    echo "vector tests done!"
}

tensor()
{
    echo "begin tensor tests..."

    make -C sw/kernel

    # simx tests
    CONFIGS="-DNUM_THREADS=2 -DEXT_TCU_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --debug=3 --log=run_simx.log
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DISSUE_WIDTH=2 -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DITYPE=bf16 -DOTYPE=bf16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DISSUE_WIDTH=2 -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DITYPE=bf8 -DOTYPE=bf8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm2_tcu --args="-w 4"

    # rtlsim tests
    CONFIGS="-DNUM_THREADS=2 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --debug=3 --log=run_rtlsim.log
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=uint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=bf16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DISSUE_WIDTH=2 -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DISSUE_WIDTH=4 -DITYPE=fp16 -DOTYPE=fp32 -DPROFILE_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DEXT_TCU_ENABLE -DTCU_TYPE_TFR -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=16 -DEXT_TCU_ENABLE -DTCU_TYPE_TFR -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DNUM_THREADS=8 -DNUM_WARPS=8 -DISSUE_WIDTH=4 -DEXT_TCU_ENABLE -DTCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_tcu --args="-w 4"

    # test fp16
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1  --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DSP" NUM_REGS=1 LATENCY=31 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --no-fused --ulp=3
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --W=25
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP -DTCU_BF16_DISABLE -DTCU_TF32_DISABLE -DTCU_FP8_DISABLE -DTCU_INT_DISABLE" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --W=25

    # test bf16
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" NUM_REGS=1 LATENCY=4  make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DSP" NUM_REGS=1 LATENCY=31 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4  make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --W=25

    # test fp8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --no-fused --features="normals;subnormals;zeros" --ulp=2
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=4 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --W=25

    # test bf8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --no-fused --ulp=4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=4 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --W=25

    # test tf32
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5  --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5 --W=25

    # test int8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=9
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=9

    # test uint8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=10
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=10

    # test int4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=11
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=11

    # test uint4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=12
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DTCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=12

    echo "tensor tests done!"
}

