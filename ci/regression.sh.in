# exit when any command fails
set -e

# clear blackbox cache
rm -f blackbox.*.cache

# HW: add a test "VM Test" to make sure VM feature is enabled

XLEN=${XLEN:=@XLEN@}

XSIZE=$((XLEN / 8))

echo "Vortex Regression Test: XLEN=$XLEN"

# Enforce the HW/SW config layering boundary: VX_config.h is HW/sim-private
# and must not leak into software or tests.
# See docs/proposals/config_hw_sw_layering_proposal.md.
"@VORTEX_HOME@/ci/check_config_boundary.sh"

# Enforce the sw/ ↔ sim/+hw/ bidirectional isolation boundary.
# See AGENTS.md §6 and docs/coding_guidelines_cpp.md §8.
"@VORTEX_HOME@/ci/check_sw_sim_boundary.sh"

unittest()
{
    make -C tests/unittest run
    make -C hw/unittest > /dev/null
}

runtime()
{
    echo "begin runtime tests..."

    # vortex2.h runtime API integration tests (tests/runtime/). Unlike
    # tests/unittest these dlopen a backend and spin up the simulator;
    # the runtime/backend libs auto-build via `make -C tests/runtime
    # run-simx`. test_module_kernel needs an explicit kernel image — the
    # `basic` regression .vxbin is not produced by the run-simx path.
    make -C tests/regression/basic kernel.vxbin

    make -C tests/runtime run-simx

    echo "runtime tests done!"
}

riscv()
{
    echo "begin riscv tests..."

    # The ISA suite (run-{simx,rtlsim}-$XLEN) exercises the full imafdc
    # ISA, so the sims must be built with the A and C extensions even
    # though VX_config.toml defaults them off.
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_EXT_C_ENABLE" make -C sim/simx
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_EXT_C_ENABLE" make -C sim/rtlsim

    make -C tests/riscv run-simx
    make -C tests/riscv run-rtlsim

    CONFIGS="-DVX_CFG_FPU_TYPE_STD" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DVX_CFG_FPU_TYPE_FPNEW" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DVX_CFG_FPU_TYPE_DPI" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f
    CONFIGS="-DVX_CFG_FPU_TYPE_DSP" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32f

    if [ "$XLEN" == "64" ]
    then
        CONFIGS="-DVX_CFG_FPU_TYPE_STD" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64d
        CONFIGS="-DVX_CFG_FPU_TYPE_DPI" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64d
        CONFIGS="-DVX_CFG_FPU_TYPE_STD -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
        CONFIGS="-DVX_CFG_FPU_TYPE_DPI -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
        CONFIGS="-DVX_CFG_FPU_TYPE_DSP -DEXT_D_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-64f
    fi

    echo "riscv tests done!"
}

kernel()
{
    echo "begin kernel tests..."

    make -C tests/kernel run-simx
    make -C tests/kernel run-rtlsim

    echo "kernel tests done!"
}

dtm()
{
    echo "begin dtm tests..."

    # dtm_test.py spawns sim/simx/simx directly (not via a test
    # makefile's run-* target), so the simx binary needs an explicit
    # pre-build. `make -C tests/kernel` builds the fibonacci.vxbin
    # the script loads — auto-pulls sw/kernel via libvortex.a.
    make -C sim/simx
    make -C tests/kernel

    DTM_XLEN=@XLEN@ python3 ci/dtm_test.py

    echo "dtm tests done!"
}

sst()
{
    echo "begin sst tests..."

    make -C sim/simx USE_SST=1
    make -C tests/kernel

    cp sim/simx/libvortex.so $SST_ELEMENTS_HOME/lib/sst-elements-library/   # alternatively - $ sst --add-lib-path `pwd` myConfig.py

    BUILD_DIR=$(pwd)

    # Hostless SST runner (ci/sst_run_hostless_app.py) parameterized
    # by VORTEX_TEST_DIR + VORTEX_TEST_KERNEL — same shape as
    # ci/gem5_run_hostless_app.py. SST is hostless-only today (no
    # CPU component wired to Vortex); the ci/sst_run_app.py name
    # slot is reserved for a future host-CPU SST integration.
    # `sst` is also the name of this shell function — without `command`
    # bash would resolve the call below back to ourselves and loop until
    # the timeout. `command sst` forces external-binary lookup.
    #
    # Only standalone `int main()` kernels (no spawn_threads, no args
    # struct) work in hostless SST today — the hostless runner only
    # primes the KMU PC and ticks; there is no host CPU to stage an
    # args buffer. vecadd / conform need a future ci/sst_run_app.py
    # (CPU-component variant) to drive them.
    for spec in "hello:hello.vxbin" "fibonacci:fibonacci.vxbin"; do
        kern="${spec%%:*}"
        vxbin="${spec#*:}"
        echo "=== sst: $kern ==="
        VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/$kern \
        VORTEX_TEST_KERNEL=$vxbin \
            command sst ci/sst_run_hostless_app.py
    done

    echo "sst tests done!"
}

# gem5 integration tests — see docs/designs/vortex_gem5_integration.md for the
# v2 CP-first design and operator manual. Two layers:
#
#   1. Phase 3 standalone: kernel preloaded via the SimObject's
#      `kernel=` Python param; runs entirely inside the gem5 event
#      loop, no host CPU needed. Fast smoke test for the device
#      library wiring.
#
#   2. Phase 5 e2e: an x86 (or aarch64) SE-mode workload drives the
#      device via the CP regfile (cp_mmio_*) + BAR-mapped VRAM
#      (mem_upload through identity-mapped PIN region). The
#      dispatcher's CP submission path handles all command building;
#      the host runtime is a thin platform shim.
#
# ARM matrix is opt-in via VORTEX_GEM5_ARM=1 (needs gcc-aarch64-linux-gnu
# installed; not part of the default hosted-runner image).
gem5()
{
    echo "begin gem5 tests..."

    if [ -z "$GEM5_HOME" ]; then
        GEM5_HOME=$HOME/tools/gem5
    fi
    if [ ! -x "$GEM5_HOME/build/X86/gem5.opt" ]; then
        echo "error: $GEM5_HOME/build/X86/gem5.opt not found — run ci/gem5_install.sh first"
        exit 1
    fi

    # Build prerequisites. The gem5 device library + host runtime are
    # config/cross-arch-specific so they don't get auto-built by the
    # tests' default `all` target. sw/kernel + sw/runtime/stub are
    # pulled in automatically by tests/{kernel,regression}/* — no
    # plain pre-build needed.
    make -C sim/simx USE_GEM5=1
    make -C sw/runtime/gem5 HOST_ARCH=x86_64
    make -C tests/kernel/hello
    make -C tests/regression/vecadd
    make -C tests/regression/sgemm

    BUILD_DIR=$(pwd)
    LIB_GEM5_DEV=$BUILD_DIR/sim/simx/libvortex-gem5.so
    HOST_RT_DIR=$BUILD_DIR/sw/runtime

    # Hostless smoke — no host CPU, kernel preloaded via SimObject param.
    # env-vars MUST precede the binary (gem5.opt would otherwise treat
    # them as positional args).
    echo "=== gem5 hostless: hello ==="
    VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
    VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/hello \
    VORTEX_TEST_KERNEL=hello.vxbin \
        timeout 120 $GEM5_HOME/build/X86/gem5.opt \
        ci/gem5_run_hostless_app.py

    # E2E — CP-driven path through the host runtime. Generic runner
    # (ci/gem5_run_app.py) parameterized by VORTEX_TEST_BIN +
    # VORTEX_TEST_ARGS. Sizes fit the 120s per-test budget
    # (feedback_test_timeout_120s):
    #   - vecadd -n16   small vector add
    #   - sgemm  -n4    4x4 matrix multiply
    # Larger sizes overrun because the simulated host CPU's CP poll
    # loop burns gem5 wall time proportional to kernel runtime.
    # Run on local dev box for larger sizes by overriding VORTEX_TEST_ARGS.
    for spec in "vecadd:-n16" "sgemm:-n4"; do
        app="${spec%%:*}"
        args="${spec#*:}"
        echo "=== gem5 e2e: $app $args ==="
        VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
        VORTEX_GEM5_HOST_RT_DIR=$HOST_RT_DIR \
        VORTEX_TEST_DIR=$BUILD_DIR/tests/regression/$app \
        VORTEX_TEST_BIN=$app \
        VORTEX_TEST_ARGS=$args \
            timeout 120 $GEM5_HOME/build/X86/gem5.opt \
            ci/gem5_run_app.py
    done

    # ARM matrix (opt-in). The device library (libvortex-gem5.so) is
    # always x86 — gem5.opt is an x86 binary regardless of which
    # simulated ISA it models. Only the simulated host's ISA changes.
    if [ -n "$VORTEX_GEM5_ARM" ]; then
        if [ ! -x "$GEM5_HOME/build/ARM/gem5.opt" ]; then
            echo "error: $GEM5_HOME/build/ARM/gem5.opt not found"
            exit 1
        fi

        # Cross-compile the host runtime, stub, and test binaries for
        # aarch64. All outputs land in $arch/ subdirs alongside the
        # native x86 builds so they coexist cleanly.
        make -C sw/runtime/stub HOST_ARCH=aarch64
        make -C sw/runtime/gem5 HOST_ARCH=aarch64
        make -C tests/regression/vecadd HOST_ARCH=aarch64
        make -C tests/regression/sgemm  HOST_ARCH=aarch64

        ARM_HOST_RT_DIR=$BUILD_DIR/sw/runtime/aarch64

        echo "=== gem5 ARM hostless: hello ==="
        VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
        VORTEX_TEST_DIR=$BUILD_DIR/tests/kernel/hello \
        VORTEX_TEST_KERNEL=hello.vxbin \
            timeout 120 $GEM5_HOME/build/ARM/gem5.opt \
            ci/gem5_run_hostless_app.py

        for spec in "vecadd:-n16" "sgemm:-n4"; do
            app="${spec%%:*}"
            args="${spec#*:}"
            echo "=== gem5 ARM e2e: $app $args ==="
            VORTEX_GEM5_DEV_LIB=$LIB_GEM5_DEV \
            VORTEX_GEM5_HOST_RT_DIR=$ARM_HOST_RT_DIR \
            VORTEX_TEST_DIR=$BUILD_DIR/tests/regression/$app \
            VORTEX_TEST_BIN=$app-aarch64 \
            VORTEX_TEST_ARGS=$args \
            VORTEX_DRIVER=gem5-aarch64 \
                timeout 120 $GEM5_HOME/build/ARM/gem5.opt \
                ci/gem5_run_app.py
        done
    fi

    echo "gem5 tests done!"
}

mpi()
{
    echo "begin mpi tests..."

    make -C tests/mpi/mpi_dotproduct          run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_put_dotproduct      run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_diverge             run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_vecadd              run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_sgemm               run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_blocked_sgemm       run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_conv3               run-simx MPI=1 NP=4
    make -C tests/mpi/mpi_neighbor_a2a_conv3  run-simx MPI=1 NP=4

    echo "mpi tests done!"
}

regression()
{
    echo "begin regression tests..."

    make -C tests/regression run-simx
    make -C tests/regression run-rtlsim

    # test kernel occupancy
    ./ci/blackbox.sh --driver=simx   --app=occupancy --threads=32
    ./ci/blackbox.sh --driver=rtlsim --app=occupancy --threads=32
    ./ci/blackbox.sh --driver=simx   --app=occupancy --threads=32 --cores=4
    ./ci/blackbox.sh --driver=rtlsim --app=occupancy --threads=32 --cores=4

    # test global barrier (one emulation driver: opae; xrt AFU smoked on the
    # local barrier below — both shims wrap the same RTL barrier path)
    ./ci/blackbox.sh --driver=simx --app=dogfood --args="-n1 -tgbar" --cores=2
    ./ci/blackbox.sh --driver=opae --app=dogfood --args="-n1 -tgbar" --cores=2

    # test local barrier (one emulation driver: xrt)
    ./ci/blackbox.sh --driver=simx --app=dogfood --args="-n1 -tbar"
    ./ci/blackbox.sh --driver=xrt --app=dogfood --args="-n1 -tbar"

    # test temp driver mode for
    ./ci/blackbox.sh --driver=simx --app=vecadd --nohup

    echo "regression tests done!"
}

amo()
{
    echo "begin amo tests..."

    CONFIGS="-DVX_CFG_EXT_A_ENABLE" make -C sim/simx
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" make -C sim/rtlsim

    # RISC-V 'A' ISA conformance (rv${XLEN}ua-p-{amo*,lrsc}).
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" make -C tests/riscv/isa run-simx-${XLEN}a
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" make -C tests/riscv/isa run-rtlsim-${XLEN}a

    # Single-core L1 = LLC. Default config (4 warps × 4 threads = 16 harts).
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" ./ci/blackbox.sh --driver=simx   --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_DIRTYBYTES=0 -DVX_CFG_DCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_DIRTYBYTES=1 -DVX_CFG_DCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_NUM_WAYS=4"                       ./ci/blackbox.sh --driver=simx   --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" ./ci/blackbox.sh --driver=simx   --threads=8 --args=-n1 --app=amo
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" ./ci/blackbox.sh --driver=rtlsim --threads=8 --args=-n1 --app=amo

    # Multi-core AMO across a shared cache hierarchy (atomics resolve at the
    # LLC). Exercises cross-core LR/SC forward progress and the load-then-AMO
    # fill/probe ordering that single-core runs never hit.
    # 4x L1 -> 1x L2 (multi-core base configuration).
    CONFIGS="-DVX_CFG_EXT_A_ENABLE" ./ci/blackbox.sh --driver=simx --cores=4 --l2cache --args=-n8 --app=amo
    # 4x L2 -> 1x L3 (two-level shared hierarchy). L3 is the LLC where atomics
    # resolve, so L2 (above it) must be write-through for AMO correctness.
    CONFIGS="-DVX_CFG_EXT_A_ENABLE -DVX_CFG_L2_WRITEBACK=0" ./ci/blackbox.sh --driver=simx --cores=4 --l2cache --l3cache --args=-n8 --app=amo

    echo "amo tests done!"
}

dxa()
{
    echo "begin dxa tests..."

    # dxa_copy 1D-5D
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d1" --debug=3 --perf=6
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d2" --perf=6
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d3" --cores=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d4"
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=dxa_copy --args="-d5"
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d1" --debug=3 --perf=6
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d2" --perf=6
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d3" --cores=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d4"
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy --args="-d5"

    # dxa_copy_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx   --app=dxa_copy_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_L2_ENABLE" ./ci/blackbox.sh --driver=simx   --app=dxa_copy_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_L2_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=dxa_copy_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_WARPS=8" ./ci/blackbox.sh --driver=simx --app=dxa_copy_mcast --threads=8 --args="-r16 -c16 -R16 -C8"

    # single-core without L2 cache
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa

    # sgemm2_dxa_mcast — single-warp CTAs; mc_group_size CTAs share one B block.
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx   --app=sgemm2_dxa_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa_mcast
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa_mcast --args="-n32 -t4"

    # sgemm_tcu_wg_dxa_mcast — WGMMA 4-warp CTAs; Makefile pins NUM_WARPS=16 /
    # ISSUE_WIDTH=4 so 4 CTAs (mc_group_size) are co-resident.
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx   --app=sgemm_tcu_wg_dxa_mcast
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa_mcast
    # Multi-K-tile shape exercises the K-loop multicast refill path.
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_dxa_mcast --args="-m 128 -n 64 -k 32"
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa_mcast --args="-m 128 -n 64 -k 32"

    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_EXT_TCU_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --threads=8
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_EXT_TCU_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --threads=8

    # multi-core without L2 cache
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2

    # multi-units with 2 cores
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4 -DVX_CFG_SOCKET_SIZE=2" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=4
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4 -DVX_CFG_SOCKET_SIZE=2" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=4
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --cores=2 --clusters=2
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DVX_CFG_NUM_DXA_UNITS=4" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --cores=2 --clusters=2

    # WGMMA+DXA dense tests
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_EXT_DXA_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_dxa --threads=32 --warps=8
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_EXT_DXA_ENABLE -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_dxa --threads=32 --warps=8
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_EXT_DXA_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp_dxa --threads=32 --warps=8
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_EXT_DXA_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp_dxa --threads=32 --warps=8

    echo "dxa tests done!"
}

graphics()
{
    echo "begin graphics tests..."

    GFX_ALL="-DVX_CFG_EXT_TEX_ENABLE -DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_EXT_OM_ENABLE"

    ##########################################################################
    # gfx_tex: TEX block — texture sampler + TCACHE
    ##########################################################################

    # Format coverage (-f0..f6) on rtlsim — exercises every pixel-format
    # decode path in the texture sampler.
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f0.png -f 0 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f1.png -f 1 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f2.png -f 2 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f3.png -f 3 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f4.png -f 4 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f5.png -f 5 -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i toad.png -r toad_ref_f6.png -f 6 -g 0"

    # Filter / wrap-mode coverage (-g0..g2) on soccer texture, both drivers.
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_tex --args="-i soccer.png -r soccer_ref_g0.png -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i soccer.png -r soccer_ref_g0.png -g 0"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_tex --args="-i soccer.png -r soccer_ref_g1.png -g 1" --perf=3
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i soccer.png -r soccer_ref_g1.png -g 1" --perf=3
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_tex --args="-i soccer.png -r soccer_ref_g2.png -g 2"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --args="-i soccer.png -r soccer_ref_g2.png -g 2"

    # NUM_TEX_CORES + NUM_TCACHES sweeps — exercise the tex/tcache arb network.
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE -DVX_CFG_NUM_TEX_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_tex --cores=4 --warps=1 --threads=2 --args="-i soccer.png -r soccer_ref_g1.png -g 1"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE -DVX_CFG_NUM_TEX_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --cores=2 --warps=1 --threads=2 --args="-i soccer.png -r soccer_ref_g1.png -g 1"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE -DVX_CFG_NUM_TEX_CORES=1 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --cores=2 --warps=1 --threads=2 --args="-i soccer.png -r soccer_ref_g1.png -g 1"
    CONFIGS="-DVX_CFG_EXT_TEX_ENABLE -DVX_CFG_NUM_TEX_CORES=4 -DVX_CFG_NUM_TCACHES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_tex --cores=4 --warps=1 --threads=2 --args="-i soccer.png -r soccer_ref_g1.png -g 1"

    ##########################################################################
    # gfx_om: OM block — depth / blend / OCACHE
    ##########################################################################

    # Depth / blend mode coverage (-d, -b, -db) at 128x128 on both drivers.
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_om --args="-w 128 -h 128 -r whitebox_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_om --args="-w 128 -h 128 -d -r whitebox_d_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_om --args="-w 128 -h 128 -b -r whitebox_b_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_om --args="-w 128 -h 128 -d -b -r whitebox_db_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --args="-w 128 -h 128 -r whitebox_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --args="-w 128 -h 128 -d -r whitebox_d_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --args="-w 128 -h 128 -b -r whitebox_b_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --args="-w 128 -h 128 -d -b -r whitebox_db_128.png"

    # OCACHE banking sweep (perf path).
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE -DVX_CFG_OCACHE_NUM_BANKS=8" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --args="-w 128 -h 128 -r whitebox_128.png" --perf=5

    # NUM_OM_CORES + NUM_OCACHES sweeps.
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE -DVX_CFG_NUM_OM_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_om --cores=4 --warps=1 --threads=2 --args="-w 128 -h 128 -r whitebox_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE -DVX_CFG_NUM_OM_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -r whitebox_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE -DVX_CFG_NUM_OM_CORES=1 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -r whitebox_128.png"
    CONFIGS="-DVX_CFG_EXT_OM_ENABLE -DVX_CFG_NUM_OM_CORES=4 -DVX_CFG_NUM_OCACHES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_om --cores=4 --warps=1 --threads=2 --args="-w 128 -h 128 -r whitebox_128.png"

    ##########################################################################
    # gfx_raster: RASTER block — binning, tile/slice topology, RCACHE
    ##########################################################################

    # Baseline 128x128 triangle (perf path).
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png" --perf=4
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png" --perf=4

    # RCACHE banking sweep (perf path).
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_RCACHE_NUM_BANKS=4" ./ci/blackbox.sh --driver=rtlsim --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png" --perf=4

    # Tile-size sweeps: 16x16 (logsize=4) and 64x64 (logsize=6) tiles.
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_RASTER_TILE_LOGSIZE=4" ./ci/blackbox.sh --driver=simx   --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png"
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_RASTER_TILE_LOGSIZE=6" ./ci/blackbox.sh --driver=simx   --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png"
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_RASTER_TILE_LOGSIZE=4" ./ci/blackbox.sh --driver=rtlsim --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png"
    CONFIGS="-DVX_CFG_EXT_RASTER_ENABLE -DVX_CFG_RASTER_TILE_LOGSIZE=6" ./ci/blackbox.sh --driver=rtlsim --app=gfx_raster --args="-w 128 -h 128 -t triangle.cgltrace -r triangle_ref_128.png"

    # NUM_RASTER_CORES + NUM_RCACHES sweeps (exercise raster-cluster arb).
    # Multi-instance raster front-end (clustering): N raster_cores per cluster
    # with stripe tile partitioning; cluster arb merges into per-socket buses.
    CONFIGS="$GFX_ALL -DVX_CFG_NUM_RASTER_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d --cores=4 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL -DVX_CFG_NUM_RASTER_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL -DVX_CFG_NUM_RASTER_CORES=1 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL -DVX_CFG_NUM_RASTER_CORES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --cores=4 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL -DVX_CFG_NUM_RASTER_CORES=4 -DVX_CFG_NUM_RCACHES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --cores=4 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png" || true

    # RASTER_NUM_SLICES sweep (slice-parallel rasterization).
    CONFIGS="$GFX_ALL -DVX_CFG_RASTER_NUM_SLICES=2 -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --threads=2 --args="-w 128 -h 128 -t evilskull.cgltrace -r evilskull_ref_128.png" || true

    ##########################################################################
    # gfx_draw3d: full pipeline — TEX + RASTER + OM cross-block interactions
    ##########################################################################

    # Default config — full pipeline smoke (simx + every backend).
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=xrt    --app=gfx_draw3d --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=opae   --app=gfx_draw3d --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"

    # SOCKET_SIZE=1 (no socket-internal sharing) + multi-core.
    CONFIGS="$GFX_ALL -DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --cores=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"

    # Multi-cluster + caches disabled — stresses cross-cluster arb.
    CONFIGS="$GFX_ALL -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d --clusters=2 --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"
    CONFIGS="$GFX_ALL -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --clusters=2 --cores=2 --warps=1 --threads=2 --args="-w 128 -h 128 -t box.cgltrace -r box_ref_128.png"

    # Triangle micro-renders (debug coverage at small sizes).
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d --warps=1 --threads=2 --debug=3 --args="-w 8  -h 8  -t triangle.cgltrace -r triangle_ref_8.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --warps=1 --threads=2 --debug=3 --args="-w 8  -h 8  -t triangle.cgltrace -r triangle_ref_8.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d                                  --args="-w 64 -h 64 -t triangle.cgltrace -r triangle_ref_64.png"
    CONFIGS="$GFX_ALL" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d                                  --args="-w 64 -h 64 -t triangle.cgltrace -r triangle_ref_64.png"

    # Asset scenes — exercise multi-prim binning + non-trivial textures.
    CONFIGS="$GFX_ALL -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx   --app=gfx_draw3d --threads=2 --args="-w 32 -h 32 -t evilskull.cgltrace -r evilskull_ref_32.png"
    CONFIGS="$GFX_ALL -DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=gfx_draw3d --threads=2 --args="-w 32 -h 32 -t evilskull.cgltrace -r evilskull_ref_32.png" || true

    echo "graphics tests done!"
}

opencl()
{
    echo "begin opencl tests..."

    make -C tests/opencl run-simx
    make -C tests/opencl run-rtlsim

    ./ci/blackbox.sh --driver=simx --app=lbm --warps=8
    ./ci/blackbox.sh --driver=rtlsim --app=lbm --warps=8

    echo "opencl tests done!"
}

vulkan()
{
    echo "begin vulkan tests..."

    MESA_PATH=${MESA_PATH:-@TOOLDIR@/mesa-vortex}
    if [ ! -f "$MESA_PATH/share/vulkan/icd.d/lvp_icd.x86_64.json" ]; then
        echo "error: Mesa with vortexpipe not found at $MESA_PATH — run ci/mesa_install.sh first"
        exit 1
    fi

    # vortexpipe compiles shader kernels against sw/kernel's
    make -C tests/vulkan run-simx
    make -C tests/vulkan run-rtlsim
    make -C tests/vulkan run-opae
    make -C tests/vulkan run-xrt

    echo "vulkan tests done!"
}

rvc()
{
    echo "begin rvc tests..."

    # Rebuild kernel + simulators with the C extension enabled.
    make -C sw/kernel clean && CONFIGS="-DVX_CFG_EXT_C_ENABLE" make -C sw/kernel
    make -C sim/simx clean && CONFIGS="-DVX_CFG_EXT_C_ENABLE" make -C sim/simx
    make -C sim/rtlsim clean && CONFIGS="-DVX_CFG_EXT_C_ENABLE" make -C sim/rtlsim

    # ISA conformance for rv*uc-p-* (compressed instruction tests).
    make -C tests/riscv/isa run-simx-32c
    make -C tests/riscv/isa run-rtlsim-32c

    if [ "$XLEN" == "64" ]
    then
        make -C tests/riscv/isa run-simx-64c
        make -C tests/riscv/isa run-rtlsim-64c
    fi

    make -C sw/runtime/simx clean && CONFIGS="-DVX_CFG_EXT_C_ENABLE" make -C sw/runtime/simx
    make -C sw/runtime/rtlsim clean && CONFIGS="-DVX_CFG_EXT_C_ENABLE" make -C sw/runtime/rtlsim
    make -C tests/regression/sgemm run-simx
    make -C tests/regression/sgemm run-rtlsim
    make -C tests/regression/diverge run-simx
    make -C tests/regression/diverge run-rtlsim
    make -C tests/regression/dogfood run-simx
    make -C tests/regression/dogfood run-rtlsim
    make -C tests/regression/raycast run-simx
    make -C tests/regression/raycast run-rtlsim

    echo "rvc tests done!"
}

vm(){
    echo "begin vm tests..."


    # v3 release: VM support is SimX-only. RTL VM bring-up (xrtsim/xrt/rtlsim)
    # is deferred to a future release; the CP RTL does not yet implement a
    # shared MMU. RTL invocations are kept commented out below so they can be
    # restored verbatim once Phase 2 lands.

    # Pass 1: default VM mode (SV32 on rv32, SV39 on rv64). VM_ENABLE must
    # reach the stub (VMManager bodies are #ifdef VM_ENABLE), both sim
    # drivers, AND each test invocation (test app rebuilds its own
    # vx_start.S which gates `csrw satp` on VM_ENABLE).
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/stub clean && CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/stub
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/simx clean && CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/rtlsim clean && CONFIGS="-DVX_CFG_VM_ENABLE" make -C sw/runtime/rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/sgemm run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/sgemm run-xrt
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/diverge run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/diverge run-xrt
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/dogfood run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/dogfood run-rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/raycast run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/regression/raycast run-rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/graphics/gfx_draw3d run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE" make -C tests/graphics/gfx_draw3d run-xrt

    # Pass 2: BARE mode (identity translation only, no PTW). Same propagation.
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/stub clean && CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/stub
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/simx clean && CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/rtlsim clean && CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C sw/runtime/rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/sgemm run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/sgemm run-xrt
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/diverge run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/diverge run-xrt
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/dogfood run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/dogfood run-rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/raycast run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/regression/raycast run-rtlsim
    CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/graphics/gfx_draw3d run-simx
    #CONFIGS="-DVX_CFG_VM_ENABLE -DVX_CFG_VM_ADDR_MODE=BARE" make -C tests/graphics/gfx_draw3d run-xrt

    echo "vm tests done!"
}

cache()
{
    echo "begin cache tests..."


    # disable local memory
    CONFIGS="-DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=demo --perf=1
    CONFIGS="-DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx --app=demo --perf=1

    # disable L1 cache
    CONFIGS="-DICACHE_DISABLE -DDCACHE_DISABLE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_DISABLE -DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DICACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm

    # reduce l1 line size
    CONFIGS="-DVX_CFG_L1_LINE_SIZE=$XSIZE" ./ci/blackbox.sh --driver=rtlsim --app=io_addr
    CONFIGS="-DVX_CFG_L1_LINE_SIZE=$XSIZE -DICACHE_DISABLE -DDCACHE_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=io_addr
    CONFIGS="-DVX_CFG_L1_LINE_SIZE=$XSIZE" ./ci/blackbox.sh --driver=simx --app=io_addr
    CONFIGS="-DVX_CFG_L1_LINE_SIZE=$XSIZE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_L1_LINE_SIZE=$XSIZE -DLMEM_DISABLE" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test cache ways
    CONFIGS="-DVX_CFG_ICACHE_NUM_WAYS=1 -DVX_CFG_DCACHE_NUM_WAYS=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_ICACHE_NUM_WAYS=4 -DVX_CFG_DCACHE_NUM_WAYS=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_ICACHE_NUM_WAYS=4 -DVX_CFG_DCACHE_NUM_WAYS=8" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test cache banking
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_LMEM_NUM_BANKS=4 -DVX_CFG_DCACHE_NUM_BANKS=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_LMEM_NUM_BANKS=4 -DVX_CFG_DCACHE_NUM_BANKS=1" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_LMEM_NUM_BANKS=2 -DVX_CFG_DCACHE_NUM_BANKS=4" ./ci/blackbox.sh --driver=rtlsim --app=sgemm --threads=8
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_LMEM_NUM_BANKS=2 -DVX_CFG_DCACHE_NUM_BANKS=4" ./ci/blackbox.sh --driver=simx --app=sgemm --threads=8

    # replacement policy
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=0" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=1" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=2" ./ci/blackbox.sh --driver=rtlsim --app=sgemm
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=0" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=1" ./ci/blackbox.sh --driver=simx --app=sgemm
    CONFIGS="-DVX_CFG_DCACHE_REPL_POLICY=2" ./ci/blackbox.sh --driver=simx --app=sgemm

    # test writeback
    CONFIGS="-DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_DIRTYBYTES=0 -DVX_CFG_DCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_DIRTYBYTES=1 -DVX_CFG_DCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_DCACHE_NUM_WAYS=4" ./ci/blackbox.sh --driver=simx --app=mstress
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1 -DVX_CFG_L2_WRITEBACK=1 -DVX_CFG_L3_WRITEBACK=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --l2cache --l3cache --app=mstress
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1 -DVX_CFG_L2_WRITEBACK=1 -DVX_CFG_L3_WRITEBACK=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --l3cache --app=mstress

    # cache clustering
    CONFIGS="-DVX_CFG_SOCKET_SIZE=4 -DVX_CFG_NUM_DCACHES=4 -DVX_CFG_NUM_ICACHES=2" ./ci/blackbox.sh --driver=rtlsim --app=sgemm --cores=4 --warps=1 --threads=2

    # L2/L3
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=4 --l2cache --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=4 --l2cache --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --l2cache --l3cache --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --l3cache --app=diverge --args="-n1"

    echo "begin cache tests..."
}

config1()
{
    echo "begin configuration-1 tests..."

    # warp/threads
    ./ci/blackbox.sh --driver=rtlsim --warps=1 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=1 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=8 --app=diverge
    ./ci/blackbox.sh --driver=rtlsim --warps=8 --threads=2 --app=diverge
    ./ci/blackbox.sh --driver=simx --warps=1 --threads=1 --app=diverge
    ./ci/blackbox.sh --driver=simx --warps=2 --threads=16 --app=diverge

    # 2D block dim (block_dim.x < NUM_LANES triggers CTA thread-ID decomposition)
    ./ci/blackbox.sh --driver=simx --threads=8 --app=demo --args="-x1 -y4"
    ./ci/blackbox.sh --driver=simx --threads=8 --app=demo --args="-x2 -y4"
    ./ci/blackbox.sh --driver=rtlsim --threads=8 --app=demo --args="-x1 -y4"
    ./ci/blackbox.sh --driver=rtlsim --threads=8 --app=demo --args="-x2 -y4"

    # cores clustering
    ./ci/blackbox.sh --driver=rtlsim --cores=4 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=simx --cores=4 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --app=diverge --args="-n1"
    ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=rtlsim --cores=2 --clusters=2 --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=4" ./ci/blackbox.sh --driver=rtlsim --cores=4 --app=diverge --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=4" ./ci/blackbox.sh --driver=simx --cores=4 --app=diverge --args="-n1"

    # issue width
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4" ./ci/blackbox.sh --driver=simx --app=diverge

    # simd width
    CONFIGS="-DVX_CFG_SIMD_WIDTH=1" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-ttrig"
    CONFIGS="-DVX_CFG_SIMD_WIDTH=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-ttrig"
    ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=32 --app=sgemm
    CONFIGS="-DVX_CFG_SIMD_WIDTH=32" ./ci/blackbox.sh --driver=rtlsim --warps=2 --threads=32 --app=sgemm
    CONFIGS="-DVX_CFG_SIMD_WIDTH=1" ./ci/blackbox.sh --driver=simx --app=dogfood --args="-ttrig"
    CONFIGS="-DVX_CFG_SIMD_WIDTH=2" ./ci/blackbox.sh --driver=simx --app=dogfood --args="-ttrig"

    # ALU scaling
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=1 -DNUM_ALU_BLOCK=1 -DVX_CFG_NUM_ALU_LANES=1" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_ALU_BLOCK=2 -DVX_CFG_NUM_ALU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_ALU_BLOCK=4 -DVX_CFG_NUM_ALU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=1 -DNUM_ALU_BLOCK=1 -DVX_CFG_NUM_ALU_LANES=1" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_ALU_BLOCK=2 -DVX_CFG_NUM_ALU_LANES=2" ./ci/blackbox.sh --driver=simx --app=diverge
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_ALU_BLOCK=4 -DVX_CFG_NUM_ALU_LANES=4" ./ci/blackbox.sh --driver=simx --app=diverge

    # FPU scaling
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DNUM_FPU_BLOCK=1 -DVX_CFG_NUM_FPU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_FPU_BLOCK=4 -DVX_CFG_NUM_FPU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DNUM_FPU_BLOCK=1 -DVX_CFG_NUM_FPU_LANES=2" ./ci/blackbox.sh --driver=simx --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_FPU_BLOCK=4 -DVX_CFG_NUM_FPU_LANES=4" ./ci/blackbox.sh --driver=simx --app=regression/vecadd

    # FPU's PE scaling
    CONFIGS="-DVX_CFG_FMA_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfmadd"
    CONFIGS="-DVX_CFG_FCVT_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tftoi"
    CONFIGS="-DVX_CFG_FDIV_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfdiv"
    CONFIGS="-DVX_CFG_FSQRT_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfsqrt"
    CONFIGS="-DVX_CFG_FNCP_PE_RATIO=2" ./ci/blackbox.sh --driver=rtlsim --app=dogfood --args="-tfclamp"

    # LSU scaling
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DNUM_LSU_BLOCK=1 -DVX_CFG_NUM_LSU_LANES=2" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_LSU_BLOCK=4 -DVX_CFG_NUM_LSU_LANES=4" ./ci/blackbox.sh --driver=rtlsim --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=2 -DNUM_LSU_BLOCK=1 -DVX_CFG_NUM_LSU_LANES=2" ./ci/blackbox.sh --driver=simx --app=regression/vecadd
    CONFIGS="-DVX_CFG_ISSUE_WIDTH=4 -DNUM_LSU_BLOCK=4 -DVX_CFG_NUM_LSU_LANES=4" ./ci/blackbox.sh --driver=simx --app=regression/vecadd

    echo "configuration-1 tests done!"
}

config2()
{
    echo "begin configuration-2 tests..."

    # test opaesim
    ./ci/blackbox.sh --driver=opae --app=printf
    ./ci/blackbox.sh --driver=opae --app=diverge
    ./ci/blackbox.sh --driver=xrt --app=diverge

    # disable DPI (exercise the in-house native STD FPU: F32 on rv32, F32+F64 on rv64)
    CONFIGS="-DVX_CFG_FPU_TYPE_STD" ./ci/blackbox.sh --driver=rtlsim --app=dogfood
    CONFIGS="-DVX_CFG_FPU_TYPE_STD" ./ci/blackbox.sh --driver=opae --app=dogfood

    # custom program startup address
    make -C tests/regression/dogfood clean-kernel
    STARTUP_ADDR=0x80000000 make -C tests/regression/dogfood
    ./ci/blackbox.sh --driver=simx --app=dogfood
    ./ci/blackbox.sh --driver=rtlsim --app=dogfood
    make -C tests/regression/dogfood clean-kernel

    # disabling M & F extensions
    CONFIGS="-DEXT_M_DISABLE -DEXT_F_DISABLE" make -C sim/rtlsim > /dev/null && make -C tests/riscv/isa run-rtlsim-32i

    # disabling ZICOND extension
    CONFIGS="-DEXT_ZICOND_DISABLE" ./ci/blackbox.sh --driver=rtlsim --app=demo

    # memory subsystem tests. The memory subsystem lives in the RTL core, so opae
    # exercises it; the xrt AFU shim is smoked via the diverge case above. One
    # emulation driver (opae) per config, plus simx/rtlsim, not duplicate opae+xrt.

    # 128-bit memory block
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=opae --app=mstress

    # XLEN-bit memory block
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=$XSIZE" ./ci/blackbox.sh --driver=opae --app=mstress
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=$XSIZE" ./ci/blackbox.sh --driver=simx --app=mstress

    # memory coalescing
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=rtlsim --app=mstress --threads=8
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=16" ./ci/blackbox.sh --driver=simx --app=mstress --threads=8

    # single-bank memory
    CONFIGS="-DVX_CFG_PLATFORM_MEMORY_NUM_BANKS=1" ./ci/blackbox.sh --driver=opae --app=mstress

    # larger memory address
    if [ "$XLEN" == "64" ]; then
        CONFIGS="-DVX_CFG_PLATFORM_MEMORY_ADDR_WIDTH=49" ./ci/blackbox.sh --driver=opae --app=mstress
    else
        CONFIGS="-DVX_CFG_PLATFORM_MEMORY_ADDR_WIDTH=33" ./ci/blackbox.sh --driver=opae --app=mstress
    fi

    # memory banks interleaving
    CONFIGS="-DVX_CFG_PLATFORM_MEMORY_INTERLEAVE=1" ./ci/blackbox.sh --driver=opae --app=mstress
    CONFIGS="-DVX_CFG_PLATFORM_MEMORY_INTERLEAVE=0" ./ci/blackbox.sh --driver=opae --app=mstress

    # memory ports
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_PLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=simx --app=mstress
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_PLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=simx --app=mstress --threads=8
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_PLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=rtlsim --app=mstress
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8 -DVX_CFG_PLATFORM_MEMORY_NUM_BANKS=2" ./ci/blackbox.sh --driver=rtlsim --app=mstress --threads=8
    CONFIGS="-DVX_CFG_MEM_BLOCK_SIZE=8" ./ci/blackbox.sh --driver=opae --app=mstress --threads=8

    echo "configuration-2 tests done!"
}

test_csv_trace32()
{
    # test CSV trace generation
    DEBUG=3 make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DGPR_RESET" make -C sim/rtlsim > /dev/null
    make -C tests/riscv/isa run-simx-32imf > run_simx.log
    make -C tests/riscv/isa run-rtlsim-32imf > run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    # The riscv-tests `write_tohost` loop (PC 0x80000044 AUIPC) gets a
    # few extra iterations on rtlsim because its HTIF watcher detects
    # the halt one or two cycles later than simx's. Strip those entries
    # before the strict diff; behavior is identical (one tohost write).
    csv_diff_no_htif() { diff <(grep -vE "0x8000003c|0x80000044|0x80000024|,\\?," "$1") <(grep -vE "0x8000003c|0x80000044|0x80000024|,\\?," "$2"); }
    csv_diff_no_htif trace_rtlsim.csv trace_simx.csv

    # test CSV trace generation for TCU (single warp to avoid CTA scheduling divergence)
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --warps=1 --debug=3 --log=run_simx.log
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --warps=1 --debug=3 --log=run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    csv_diff_no_htif trace_rtlsim.csv trace_simx.csv

    # test CSV trace generation for DXA (compare instruction counts due to CTA dispatch ordering differences)
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=simx --app=sgemm2_dxa --warps=1 --args="-t 2 -n 4" --debug=3 --log=run_simx.log
    CONFIGS="-DVX_CFG_EXT_DXA_ENABLE -DGPR_RESET" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_dxa --warps=1 --args="-t 2 -n 4" --debug=3 --log=run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    csv_diff_no_htif trace_rtlsim.csv trace_simx.csv
}

test_csv_trace64()
{
    # test CSV trace generation
    DEBUG=3 make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DGPR_RESET" make -C sim/rtlsim > /dev/null
    make -C tests/riscv/isa run-simx-64imf > run_simx.log
    make -C tests/riscv/isa run-rtlsim-64imf > run_rtlsim.log
    ./ci/trace_csv.py -tsimx run_simx.log -otrace_simx.csv
    ./ci/trace_csv.py -trtlsim run_rtlsim.log -otrace_rtlsim.csv
    # Same HTIF-detect-latency divergence as the 32-bit case. The RV64
    # tests use the same write_tohost loop layout from upstream
    # riscv-tests (entry point is identical bytecode at the same
    # virtual offset because the test framework's crt.S is XLEN-agnostic
    # for this routine). Reuse the filtering helper.
    csv_diff_no_htif() { diff <(grep -vE "0x8000003c|0x80000044|0x80000024|,\\?," "$1") <(grep -vE "0x8000003c|0x80000044|0x80000024|,\\?," "$2"); }
    csv_diff_no_htif trace_rtlsim.csv trace_simx.csv
}

debug()
{
    echo "begin debugging tests..."

    test_csv_trace32

    if [ "$XLEN" == "64" ]
    then
        test_csv_trace64
    fi

    CONFIGS="-O0" ./ci/blackbox.sh --driver=opae --app=demo --args="-n1"
    CONFIGS="-O0" ./ci/blackbox.sh --driver=xrt --app=demo --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=opae --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=xrt --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"
    CONFIGS="-DVX_CFG_SOCKET_SIZE=1" ./ci/blackbox.sh --driver=simx --cores=2 --clusters=2 --l2cache --debug=1 --perf=1 --app=demo --args="-n1"

    # test perfetto trace generation
    DEBUG=3 CONFIGS="-DVX_CFG_EXT_TCU_ENABLE" make -C sim/simx > /dev/null
    DEBUG=3 CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DGPR_RESET" make -C sim/rtlsim > /dev/null
    DEBUG=3 CONFIGS="-DVX_CFG_EXT_TCU_ENABLE" make -C sw/runtime/simx > /dev/null
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --debug=3 --log=run_simx.log
    ./ci/perfetto.py run_simx.log -t simx -o trace_simx.perfetto.json
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --debug=3 --log=run_rtlsim.log
    ./ci/perfetto.py run_rtlsim.log -t rtlsim -o trace_rtlsim.perfetto.json

    echo "debugging tests done!"
}

scope()
{
    echo "begin scope tests..."

    SCOPE_DEPTH=128 ./ci/blackbox.sh --driver=opae --app=demo --args="-n1" --scope
    SCOPE_DEPTH=128 ./ci/blackbox.sh --driver=xrt --app=demo --args="-n1" --scope

    echo "debugging scope done!"
}

stress()
{
    echo "begin stress tests..."

    # test verilator reset values
    CONFIGS="-DVERILATOR_RESET_VALUE=1 -DVX_CFG_SOCKET_SIZE=1 -DVX_CFG_DCACHE_WRITEBACK=1 -DVX_CFG_L2_WRITEBACK=1 -DVX_CFG_L3_WRITEBACK=1" ./ci/blackbox.sh --driver=opae --cores=2 --clusters=2 --l2cache --l3cache --app=dogfood
    CONFIGS="-DVERILATOR_RESET_VALUE=1" ./ci/blackbox.sh --driver=xrt --app=sgemm --args="-n128" --l2cache

    echo "stress tests done!"
}

synthesis()
{
    echo "begin synthesis tests..."

    make -C hw/syn/yosys

    # synthesis with TCU + sparsity + AMO + RVC
    CONFIGS="-DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_TFR -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_EXT_AMO_ENABLE -DVX_CFG_EXT_RVC_ENABLE" make -C hw/syn/yosys

    echo "synthesis tests done!"
}

vector()
{
    echo "begin vector tests..."

    CONFIGS="-DVX_CFG_VLEN=256 -DVX_CFG_EXT_V_ENABLE" make -C sim/simx
    VLEN=256 ./tests/riscv/riscv-vector-tests/run-test.sh

    echo "vector tests done!"
}

tensor()
{
    echo "begin tensor tests..."

    # simx tests
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu --debug=3 --log=run_simx.log
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_ISSUE_WIDTH=2 -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=bf16 -DOTYPE=bf16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_ISSUE_WIDTH=2 -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=bf8 -DOTYPE=bf8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm2_tcu --args="-w 4"

    # rtlsim tests
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu --debug=3 --log=run_rtlsim.log
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=uint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=uint4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=bf16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DVX_CFG_ISSUE_WIDTH=2 -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DVX_CFG_ISSUE_WIDTH=4 -DITYPE=fp16 -DOTYPE=fp32 -DPROFILE_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_TFR -DITYPE=fp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_TFR -DITYPE=bf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm2_tcu --args="-w 4"

    # test fp16
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1  --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DSP" NUM_REGS=1 LATENCY=31 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --no-fused --ulp=3
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_FPNEW" NUM_REGS=1 LATENCY=21 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --W=25
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP -DVX_CFG_TCU_TF32_DISABLE -DVX_CFG_TCU_FP8_DISABLE -DVX_CFG_TCU_INT8_DISABLE -DVX_CFG_TCU_INT4_DISABLE" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=1 --W=25

    # test bf16
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" NUM_REGS=1 LATENCY=4  make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_FPNEW" NUM_REGS=1 LATENCY=21 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DSP" NUM_REGS=1 LATENCY=31 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4  make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=2 --W=25

    # test fp8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --no-fused --features="normals;subnormals;zeros" --ulp=2
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=4 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=3 --W=25

    # test bf8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --no-fused --ulp=4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=4 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=4 --W=25

    # test tf32
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" NUM_REGS=1 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5  --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_BHF" NUM_REGS=1 LATENCY=10 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5 --no-fused
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR -DUSE_FEDP" NUM_REGS=2 LATENCY=4 make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=5 --W=25

    # test int8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=17
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=17

    # test uint8
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=18
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=18

    # test int4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=19
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=19

    # test uint4
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_DPI" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=20
    make -C hw/unittest/tcu_fedp clean && CONFIGS="-DVX_CFG_TCU_TYPE_TFR" make -C hw/unittest/tcu_fedp && hw/unittest/tcu_fedp/tcu_fedp --fmt=20

    echo "tensor tests done!"
}

tensor_sp()
{
    echo "begin tensor_sp tests..."

    # Coverage axis is operand SIZE, not format: same-width formats share the
    # width-dependent TCU RTL, so {int4}=4b, {int8}=8b, {fp16}=16b, {tf32}=32b
    # represent uint4 / uint8,fp8,bf8 / bf16. The NT x size grid is kept in full:
    # the 2:4 sparse metadata storage (kMetaBanks slots, sp_num_meta_loads, per-
    # element packing) varies with both NT and operand width, so each pair is a
    # distinct path. The grid runs on both simx and rtlsim (rtlsim coverage = simx).

    # NT=2
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp --debug=3 --log=run_simx.log
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp --debug=3 --log=run_rtlsim.log
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # NT=4
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # NT=8
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # NT=16
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # NT=32
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int4 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=tf32 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    echo "tensor_sp tests done!"
}

tensor_mx() {

    echo "begin tensor tensor_mx tests..."

    # simx tests

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k128"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k128"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_mx --args="-k64"

    # rtlsim tests

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxbf8 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_MXFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_MXFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_MXFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_MXFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k128"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_NVFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_NVFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_NVFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_FP4_ENABLE -DVX_CFG_TCU_NVFP4_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=nvfp4 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k128"

    CONFIGS="-DVX_CFG_NUM_THREADS=4  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=8  -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k32"
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_MX_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=mxint8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_mx --args="-k64"

    echo "tensor_mx tests done!"
}

tensor_wg() {

    echo "begin tensor tensor_wg tests..."

    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu

    make -C tests/regression/sgemm_tcu_sp clean && CONFIGS="-DVX_CFG_NUM_THREADS=8 -DITYPE=fp16 -DOTYPE=fp32" make -C tests/regression/sgemm_tcu_sp

    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # Coverage guard for the NT < kMetaBanks small-tile sparse regime (NT=2/4).
    # Only this regime exercises the multi-slot TCU_LD metadata path (the host
    # emits sp_num_meta_loads==2 TCU_LDs, each filling a sub-store of banks).
    # The rest of tensor_wg's sparse coverage is NT>=8 (single-slot), so a
    # regression in the multi-slot bank/col + per-slot-base address mapping
    # (SimX tcu_unit, RTL VX_tcu_agu/VX_tcu_sp_meta) slips past it — exactly how
    # the NT=2 metadata-aliasing bug reached main. int8 and fp16 cover the
    # int and float FEDP paths.
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=simx   --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=int8 -DOTYPE=int32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx   --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DVX_CFG_TCU_TYPE_DPI -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_sp

    # WGMMA dense tests — Latin-square coverage of {NT,NRC,Type,Driver}
    # These dense tests use NUM_WARPS=8, RS mode (SS mode covered separately below).
    # SimX:
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=1 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg
    # RTLsim:
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=int8 -DOTYPE=int32 -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=tf32 -DOTYPE=fp32 -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg

    # WGMMA sparse tests — rotate NRC across NT/Driver
    # SimX:
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=2 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=16" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp
    # RTLsim:
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=16 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=32" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp

    # WGMMA SS-mode tests — the dense/sparse blocks above are RS mode; these
    # exercise the shared-source (SS) operand path off the DXA path, dense and sparse.
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8 -DWGMMA_SS" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8 -DWGMMA_SS" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=8 -DWGMMA_SS" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=8 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DWGMMA_NRC=8 -DWGMMA_SS" ./ci/blackbox.sh --driver=rtlsim --app=sgemm_tcu_wg_sp

    # Note: all WGMMA+DXA tests (dense / multicast / sparse) live in the --dxa
    # group; see dxa(). They were moved out of tensor_wg to consolidate DXA
    # coverage under a single test group.

    # Additional TCU coverage
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_SPARSE_ENABLE -DITYPE=fp16 -DOTYPE=fp32" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_sp
    CONFIGS="-DVX_CFG_NUM_THREADS=32 -DVX_CFG_NUM_WARPS=8 -DVX_CFG_ISSUE_WIDTH=4 -DVX_CFG_EXT_TCU_ENABLE -DVX_CFG_TCU_WGMMA_ENABLE -DITYPE=fp16 -DOTYPE=fp32 -DWGMMA_NRC=8" ./ci/blackbox.sh --driver=simx --app=sgemm_tcu_wg

    echo "tensor tensor_wg tests done!"
}

cupbop() {

    echo "begin cupbop tests..."

    if [ "$XLEN" == "32" ]; then
        echo "cupbop tests skipped for 32-bit"
        return
    fi


    echo "downloading cupbop binaries..."
    CUPBOP_URL="https://www.dropbox.com/scl/fi/qxiofb0ejfxoog9m7tmae/cupbop.zip?rlkey=kcboy03c08xcn6yizd4nv8h88&st=7yuqftef&dl=1"

    wget -O cupbop.zip "${CUPBOP_URL}" || curl -L -o cupbop.zip "${CUPBOP_URL}"
    unzip -o cupbop.zip -d tests/
    rm cupbop.zip

    echo "building simx runtime..."
    make -C sw/runtime/simx

    PERF_CLASS=2
    VORTEX_RUNTIME_DIR="sw/runtime"
    CUPBOP_RUNTIME_DIR="tests/cupbop/runtime"

    tests=("bfs" "nn")
    tests_args=("./graph20.txt" "./filelist.txt -r 10 -lat 30 -lng 90")

    for i in "${!tests[@]}"; do
        test="${tests[$i]}"
        args="${tests_args[$i]}"
        echo "running test: $test"
        (
            cd "tests/cupbop/$test" || exit
            chmod +x "./host_${XLEN}.out"
            LD_LIBRARY_PATH="../../../${CUPBOP_RUNTIME_DIR}:../../../${VORTEX_RUNTIME_DIR}/simx:../../../${VORTEX_RUNTIME_DIR}:${LD_LIBRARY_PATH}" \
            ./host_${XLEN}.out ${args}
        )
    done

    echo "cupbop tests done!"
}

hip()
{
    echo "begin hip tests..."

    make -C tests/hip run-simx
    make -C tests/hip run-rtlsim
    make -C tests/hip run-opae
    make -C tests/hip run-xrt

    echo "hip tests done!"
}

show_usage()
{
    echo "Vortex Regression Test"
    echo "Usage: $0 [--clean] [--unittest] [--runtime] [--riscv] [--kernel] [--regression] [--amo] [--dxa] [--opencl] [--cache] [--vm] [--rvc] [--config1] [--config2] [--debug] [--scope] [--stress] [--synthesis] [--vector] [--graphics] [--vulkan] [--tensor] [--tensor_sp] [--tensor_mx] [--tensor_wg] [--cupbop] [--hip] [--sst] [--gem5] [--dtm] [--mpi] [--all] [--h|--help]"
}

declare -a tests=()
clean=0

while [ "$1" != "" ]; do
    case $1 in
        --clean )
                clean=1
                ;;
        --unittest )
                tests+=("unittest")
                ;;
        --runtime )
                tests+=("runtime")
                ;;
        --riscv )
                tests+=("riscv")
                ;;
        --kernel )
                tests+=("kernel")
                ;;
        --regression )
                tests+=("regression")
                ;;
        --amo )
                tests+=("amo")
                ;;
        --dxa )
                tests+=("dxa")
                ;;
        --graphics )
                tests+=("graphics")
                ;;
        --mpi )
                tests+=("mpi")
                ;;
        --dtm )
                tests+=("dtm")
                ;;
        --opencl )
                tests+=("opencl")
                ;;
        --vulkan )
                tests+=("vulkan")
                ;;
        --cache )
                tests+=("cache")
                ;;
        --vm )
                tests+=("vm")
                ;;
        --rvc )
                tests+=("rvc")
                ;;
        --config1 )
                tests+=("config1")
                ;;
        --config2 )
                tests+=("config2")
                ;;
        --debug )
                tests+=("debug")
                ;;
        --scope )
                tests+=("scope")
                ;;
        --stress )
                tests+=("stress")
                ;;
        --synthesis )
                tests+=("synthesis")
                ;;
        --vector )
                tests+=("vector")
                ;;
        --tensor )
                tests+=("tensor")
                ;;
        --tensor_sp )
                tests+=("tensor_sp")
                ;;
        --tensor_mx )
                tests+=("tensor_mx")
                ;;
        --tensor_wg )
                tests+=("tensor_wg")
                ;;
        --cupbop )
                tests+=("cupbop")
                ;;
        --hip )
                tests+=("hip")
                ;;
        --sst )
                tests+=("sst")
                ;;
        --gem5 )
                tests+=("gem5")
                ;;
        --dtm )
                tests+=("dtm")
                ;;
        --all )
                tests=()
                tests+=("unittest")
                tests+=("runtime")
                tests+=("riscv")
                tests+=("kernel")
                tests+=("regression")
                tests+=("amo")
                tests+=("dxa")
                tests+=("graphics")
                tests+=("mpi")
                tests+=("opencl")
                tests+=("cache")
                tests+=("vm")
                tests+=("rvc")
                tests+=("config1")
                tests+=("config2")
                tests+=("debug")
                tests+=("scope")
                tests+=("stress")
                tests+=("synthesis")
                tests+=("tensor")
                tests+=("tensor_sp")
                tests+=("tensor_mx")
                tests+=("tensor_wg")
                tests+=("cupbop")
                tests+=("hip")
                tests+=("gem5")
                tests+=("sst")
                tests+=("vulkan")
                tests+=("dtm")
                ;;
        -h | --help )
                show_usage
                exit
                ;;
        * )
                show_usage
                exit 1
    esac
    shift
done

if [ $clean -eq 1 ];
then
    make clean
    make -s
fi

start=$SECONDS

for test in "${tests[@]}"; do
    $test
done

echo "Regression completed!"

duration=$(( SECONDS - start ))
awk -v t=$duration 'BEGIN{t=int(t*1000); printf "Elapsed Time: %d:%02d:%02d\n", t/3600000, t/60000%60, t/1000%60}'
