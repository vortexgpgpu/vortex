TOOLDIR=${TOOLDIR:=@TOOLDIR@}
export PATH=$TOOLDIR/verilator/bin:$PATH

export SV2V_PATH=$TOOLDIR/sv2v
export PATH=$SV2V_PATH/bin:$PATH

export YOSYS_PATH=$TOOLDIR/yosys
export PATH=$YOSYS_PATH/bin:$PATH

export STA_PATH=$TOOLDIR/sta
export PATH=$STA_PATH/bin:$PATH

# Mesa with the vortexpipe Gallium driver (the Vulkan backend).
# libgallium links libLLVM shared from llvm-vortex, so that lib dir
# must be on LD_LIBRARY_PATH too. VK_ICD_FILENAMES points the Vulkan
# loader at the lavapipe ICD; select vortexpipe at run time with
# GALLIUM_DRIVER=vortexpipe (see tests/vulkan/common.mk).
export MESA_PATH=$TOOLDIR/mesa-vortex
export PATH=$MESA_PATH/bin:$PATH
export LD_LIBRARY_PATH=$MESA_PATH/lib:$TOOLDIR/llvm-vortex/lib:$LD_LIBRARY_PATH
export VK_ICD_FILENAMES=$MESA_PATH/share/vulkan/icd.d/lvp_icd.x86_64.json
