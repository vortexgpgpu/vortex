#
# Mesa install for the Vortex Vulkan backend — see
# docs/proposals/vulkan_support_proposal.md for the design.
#
# Builds Mesa (lavapipe + llvmpipe) into $TOOLDIR/mesa-vortex, using
# the Vortex LLVM toolchain ($TOOLDIR/llvm-vortex) as Mesa's host
# LLVM so that llvmpipe codegen and the Vortex device backend share
# one LLVM install (proposal §8 risk 5). No second/distro LLVM is
# pulled in.
#
# Prerequisite: $TOOLDIR/llvm-vortex must already be installed
# (ci/toolchain_install.sh). The apt steps need sudo.
#
# Phase 0 of the proposal builds *vanilla* lavapipe from upstream
# Mesa as the "I haven't broken Mesa" baseline. The defaults below
# therefore point at upstream Mesa. Once the Vortex Mesa fork
#   https://github.com/vortexgpgpu/mesa
# (with the `vortexpipe` Gallium driver) is populated, repoint by
# exporting MESA_REPO=https://github.com/vortexgpgpu/mesa.git plus a
# MESA_REV on that fork, and append `vortexpipe` to GALLIUM_DRIVERS.
#
# Idempotent: re-running with the same MESA_REV is a no-op once
# $MESA_PREFIX/lib/libvulkan_lvp.so exists.

# exit when any command fails
set -e

TOOLDIR=${TOOLDIR:=@TOOLDIR@}

# Pinned versions. Override via env to track the Vortex Mesa fork
# (https://github.com/vortexgpgpu/mesa.git) once it is populated.
MESA_REPO=${MESA_REPO:=https://gitlab.freedesktop.org/mesa/mesa.git}
MESA_REV=${MESA_REV:=mesa-25.1.0}

# Gallium / Vulkan driver set. `llvmpipe` (Gallium) + `swrast`
# (Vulkan) is lavapipe — the Phase 0 baseline. Append `vortexpipe`
# to GALLIUM_DRIVERS once the fork's driver lands (proposal Phase 1).
GALLIUM_DRIVERS=${GALLIUM_DRIVERS:=llvmpipe}
VULKAN_DRIVERS=${VULKAN_DRIVERS:=swrast}
# Windowing backends — needed for `vkcube` on a display (Phase 0/3).
# Set MESA_PLATFORMS= (empty) for a headless CI build.
MESA_PLATFORMS=${MESA_PLATFORMS:=x11,wayland}

LLVM_HOME=$TOOLDIR/llvm-vortex
MESA_SRC=$TOOLDIR/mesa-src
MESA_PREFIX=$TOOLDIR/mesa-vortex
MESA_BUILD=$MESA_SRC/build

# ----------------------------------------------------------------------
# 1. Build tooling + Mesa build dependencies
# ----------------------------------------------------------------------
# python3-mako is a hard requirement of Mesa's codegen. flex/bison
# parse the shader grammars. libzstd-dev backs the shader cache. The
# libx*/wayland packages back the WSI platforms in MESA_PLATFORMS.
DEBIAN_FRONTEND=noninteractive sudo apt install -y \
    build-essential git pkg-config ninja-build \
    python3 python3-dev python3-pip python3-mako \
    flex bison \
    libdrm-dev libexpat1-dev zlib1g-dev libzstd-dev libelf-dev \
    libwayland-dev wayland-protocols \
    libx11-dev libxext-dev libxshmfence-dev libxrandr-dev libxfixes-dev \
    libxcb1-dev libxcb-glx0-dev libxcb-shm0-dev libxcb-dri2-0-dev \
    libxcb-dri3-dev libxcb-present-dev libxcb-sync-dev libxcb-xfixes0-dev

# The distro meson (0.61 on Ubuntu 22.04) is too old for Mesa 25.x,
# which needs meson >= 1.4. Pull a current one from pip into ~/.local.
python3 -m pip install --user --upgrade 'meson>=1.4.0'
export PATH=$HOME/.local/bin:$PATH
if ! grep -q '\.local/bin' ~/.bashrc 2>/dev/null; then
    echo 'export PATH=$HOME/.local/bin:$PATH' >> ~/.bashrc
fi

# ----------------------------------------------------------------------
# 2. Host LLVM — reuse the Vortex LLVM toolchain
# ----------------------------------------------------------------------
# Mesa's llvmpipe needs a host LLVM. $TOOLDIR/llvm-vortex is a full
# LLVM build with both X86 (host) and RISCV (Vortex device) targets
# and shared libraries — usable directly. Putting its bin first lets
# Mesa's meson discover its llvm-config.
if [ ! -x "$LLVM_HOME/bin/llvm-config" ]; then
    echo "error: $LLVM_HOME/bin/llvm-config not found."
    echo "       run ci/toolchain_install.sh first (installs llvm-vortex)."
    exit 1
fi
export PATH=$LLVM_HOME/bin:$PATH

# Mesa's C++ RTTI setting must match LLVM's. LLVM is conventionally
# built without RTTI; detect it rather than hard-coding.
if "$LLVM_HOME/bin/llvm-config" --cxxflags | grep -q -- '-fno-rtti'; then
    CPP_RTTI=false
else
    CPP_RTTI=true
fi

# ----------------------------------------------------------------------
# 3. Vulkan runtime stack (loader, layers, tools, shader compilers)
# ----------------------------------------------------------------------
# These are what actually runs the ICD Mesa builds: the loader finds
# our driver via VK_ICD_FILENAMES; vulkaninfo/vkcube are the Phase 0
# smoke tests; glslang/spirv-tools compile GLSL -> SPIR-V for tests.
DEBIAN_FRONTEND=noninteractive sudo apt install -y \
    libvulkan-dev vulkan-tools vulkan-validationlayers \
    spirv-tools glslang-tools

# ----------------------------------------------------------------------
# 4. Fetch + build Mesa
# ----------------------------------------------------------------------
mkdir -p "$TOOLDIR"

# Fetch (or update) the Mesa working tree at the pinned revision.
if [ -d "$MESA_SRC/.git" ]; then
    echo "mesa working tree exists at $MESA_SRC"
    pushd "$MESA_SRC" > /dev/null
    current_rev=$(git describe --tags --always 2>/dev/null || echo "unknown")
    if [ "$current_rev" != "$MESA_REV" ]; then
        echo "checked-out rev $current_rev != pinned $MESA_REV; refetching"
        git fetch --depth=1 origin "$MESA_REV"
        git checkout "$MESA_REV"
    fi
    popd > /dev/null
else
    echo "cloning mesa $MESA_REV into $MESA_SRC"
    git clone --depth=1 --branch "$MESA_REV" "$MESA_REPO" "$MESA_SRC"
fi

# -j$(nproc) on the self-hosted runner; cap at 4 on hosted runners to
# avoid OOM (the LLVM-linked Mesa link step is memory-heavy).
JOBS=$(nproc)
if [ -n "$GITHUB_ACTIONS" ] && [ -z "$VORTEX_SELF_HOSTED" ]; then
    JOBS=4
fi

# Skip the build if the lavapipe ICD is already installed.
if [ -f "$MESA_PREFIX/lib/libvulkan_lvp.so" ]; then
    echo "mesa already installed at $MESA_PREFIX"
else
    echo "configuring mesa ($GALLIUM_DRIVERS / $VULKAN_DRIVERS) with -j$JOBS"
    rm -rf "$MESA_BUILD"
    meson setup "$MESA_BUILD" "$MESA_SRC" \
        --prefix="$MESA_PREFIX" \
        --libdir=lib \
        --buildtype=release \
        -D cpp_rtti="$CPP_RTTI" \
        -D gallium-drivers="$GALLIUM_DRIVERS" \
        -D vulkan-drivers="$VULKAN_DRIVERS" \
        -D platforms="$MESA_PLATFORMS" \
        -D llvm=enabled \
        -D gallium-extra-hud=false \
        -D video-codecs=

    meson compile -C "$MESA_BUILD" -j"$JOBS"
    meson install -C "$MESA_BUILD"
fi

# ----------------------------------------------------------------------
# 5. Environment
# ----------------------------------------------------------------------
# VK_ICD_FILENAMES points the Vulkan loader at the Mesa ICD. Starts on
# lavapipe (lvp); repoint at vortex_icd.x86_64.json once the vortexpipe
# driver is installed (proposal Phase 1). LD_LIBRARY_PATH must carry
# llvm-vortex/lib too — the driver links libLLVM shared.
MESA_ICD=$MESA_PREFIX/share/vulkan/icd.d/lvp_icd.x86_64.json
MESA_LD_PATH=$MESA_PREFIX/lib:$LLVM_HOME/lib

export MESA_HOME=$MESA_PREFIX
export LD_LIBRARY_PATH=$MESA_LD_PATH:$LD_LIBRARY_PATH
export VK_ICD_FILENAMES=$MESA_ICD

add_bashrc() { grep -q "^export $1=" ~/.bashrc 2>/dev/null || echo "export $1=$2" >> ~/.bashrc; }
add_bashrc MESA_HOME "$MESA_PREFIX"
add_bashrc VK_ICD_FILENAMES "$MESA_ICD"
if ! grep -q "mesa-vortex/lib" ~/.bashrc 2>/dev/null; then
    echo 'export LD_LIBRARY_PATH='"$MESA_LD_PATH"':$LD_LIBRARY_PATH' >> ~/.bashrc
fi

# GitHub Actions: propagate to subsequent steps.
if [ -n "$GITHUB_ENV" ]; then
    {
        echo "MESA_HOME=$MESA_PREFIX"
        echo "VK_ICD_FILENAMES=$MESA_ICD"
        echo "LD_LIBRARY_PATH=$MESA_LD_PATH:$LD_LIBRARY_PATH"
    } >> "$GITHUB_ENV"
fi
if [ -n "$GITHUB_PATH" ]; then
    echo "$MESA_PREFIX/bin" >> "$GITHUB_PATH"
    echo "$HOME/.local/bin" >> "$GITHUB_PATH"
fi

echo ""
echo "mesa $MESA_REV installed at $MESA_PREFIX"
echo "  ICD:     $MESA_ICD"
echo "  drivers: gallium=$GALLIUM_DRIVERS vulkan=$VULKAN_DRIVERS"
echo "  llvm:    $($LLVM_HOME/bin/llvm-config --version) ($LLVM_HOME)"
echo "  verify:  vulkaninfo --summary"
echo "  (re-source ~/.bashrc to pick up MESA_HOME in new shells)"
